@model EmployeeAccessSystem.Models.AccessControlMenuModel

<div class="modal-header">
    <h5 class="modal-title">Add Menu</h5>

    <button type="button" class="close" data-dismiss="modal">
        <span>&times;</span>
    </button>
</div>

<form asp-action="CreateMenu" method="post">
    @Html.AntiForgeryToken()

    <div class="modal-body">

        <div class="form-group">
            <label>Menu Name</label>
            <input asp-for="MenuName"
                   class="form-control form-control-sm"
                   placeholder="Enter menu name" />
        </div>

        <div class="form-group mb-0">
            <label>Parent Menu</label>

            <select asp-for="ParentMenuId"
                    asp-items="ViewBag.ParentMenus"
                    class="form-control form-control-sm">
                <option value="">Main Menu</option>
            </select>
        </div>

        <input type="hidden" asp-for="ControllerName" />
        <input type="hidden" asp-for="ActionName" />
        <input type="hidden" asp-for="SortBy" value="1" />

    </div>

    <div class="modal-footer">
        <button type="button"
                class="btn btn-secondary btn-sm"
                data-dismiss="modal">
            Back
        </button>

        <button type="submit"
                class="btn btn-primary btn-sm">
            Save
        </button>
    </div>
</form>