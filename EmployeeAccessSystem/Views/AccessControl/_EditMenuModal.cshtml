@model EmployeeAccessSystem.Models.AccessControlMenuModel

<div class="modal-header">
    <h5 class="modal-title">Edit Menu</h5>

    <button type="button" class="close" data-dismiss="modal">
        <span>&times;</span>
    </button>
</div>

<form asp-action="EditMenu" method="post">
    @Html.AntiForgeryToken()

    <div class="modal-body">

        <input type="hidden" asp-for="MenuId" />

        <div class="form-group">
            <label>Menu Name</label>

            <input asp-for="MenuName"
                   class="form-control form-control-sm" />
        </div>

        <div class="form-group">
            <label>Parent Menu</label>

            <select asp-for="ParentMenuId"
                    asp-items="ViewBag.ParentMenus"
                    class="form-control form-control-sm">
                <option value="">Main Menu</option>
            </select>
        </div>

        <div class="custom-control custom-switch">
            <input type="checkbox"
                   class="custom-control-input"
                   asp-for="IsActive" />

            <label class="custom-control-label font-weight-bold"
                   asp-for="IsActive">
                Active
            </label>
        </div>

        <input type="hidden" asp-for="ControllerName" />
        <input type="hidden" asp-for="ActionName" />
        <input type="hidden" asp-for="SortBy" />

    </div>

    <div class="modal-footer">
        <button type="button"
                class="btn btn-secondary btn-sm"
                data-dismiss="modal">
            Back
        </button>

        <button type="submit"
                class="btn btn-primary btn-sm">
            Update
        </button>
    </div>
</form>