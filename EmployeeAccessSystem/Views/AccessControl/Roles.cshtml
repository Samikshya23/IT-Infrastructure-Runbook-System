@model List<EmployeeAccessSystem.Models.AccessControlRoleModel>

@{
    ViewData["Title"] = "Manage Roles";
    int sn = 1;
}

<section class="content pt-2 pb-0">

    <div class="container-fluid px-0">

        <div class="row mb-2 mx-0 align-items-center">

            <div class="col-sm-6 px-0">
                <h3 class="mb-0">Manage Roles</h3>
            </div>

            <div class="col-sm-6 text-right px-0">

                <a href="/AccessControl/Index"
                   class="btn btn-secondary btn-sm mr-1">
                    <i class="fas fa-arrow-left mr-1"></i>
                    Dashboard
                </a>

                <button type="button"
                        class="btn btn-primary btn-sm"
                        id="btnAddRole">
                    <i class="fas fa-plus mr-1"></i>
                    Add Role
                </button>

            </div>

        </div>

        <div class="card card-outline card-primary mb-0 shadow-none">

            <div class="card-header bg-white pt-2 pb-2 px-3">

                <div class="row align-items-center">

                    <div class="col-md-6 d-flex align-items-center">

                        <label class="mb-0 mr-2 font-weight-normal">
                            Show
                        </label>

                        <select id="roleCustomLength"
                                class="custom-select custom-select-sm form-control form-control-sm"
                                style="width:70px;">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>

                        <label class="mb-0 ml-2 font-weight-normal">
                            entries
                        </label>

                    </div>

                    <div class="col-md-6 text-right">

                        <input type="text"
                               id="roleCustomSearch"
                               class="form-control form-control-sm d-inline-block"
                               placeholder="Search"
                               style="width:220px;" />

                    </div>

                </div>

            </div>

            <div class="card-body p-0">

                <table id="roleTable"
                       class="table table-bordered table-hover table-sm mb-0">

                    <thead class="bg-light">

                        <tr>
                            <th class="text-center align-middle" style="width:70px;">
                                SN
                            </th>

                            <th class="align-middle">
                                Role Name
                            </th>

                            <th class="text-center align-middle" style="width:170px;">
                                Actions
                            </th>
                        </tr>

                    </thead>

                    <tbody>

                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td class="text-center align-middle">
                                        @sn
                                    </td>

                                    <td class="align-middle">
                                        @item.RoleName
                                    </td>

                                    <td class="text-center align-middle">

                                        @if (string.Equals(item.RoleName, "Administrator", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge badge-success">
                                                Full Access
                                            </span>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn btn-xs btn-outline-primary btnEditRole"
                                                    data-role-id="@item.RoleId"
                                                    title="Edit">
                                                <i class="fas fa-pen"></i>
                                            </button>

                                            <button type="button"
                                                    class="btn btn-xs btn-outline-danger btnDeleteRole ml-1"
                                                    data-role-id="@item.RoleId"
                                                    data-role-name="@item.RoleName"
                                                    title="Delete">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        }

                                    </td>

                                </tr>

                                sn++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3"
                                    class="text-center text-muted py-3">
                                    No roles found.
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</section>

<div class="modal fade"
     id="roleModal"
     tabindex="-1"
     role="dialog"
     aria-hidden="true">

    <div class="modal-dialog modal-sm modal-dialog-centered"
         role="document">

        <div class="modal-content"
             id="roleModalContent">
        </div>

    </div>

</div>

<div class="modal fade"
     id="deleteRoleModal"
     tabindex="-1"
     role="dialog"
     aria-hidden="true">

    <div class="modal-dialog modal-sm modal-dialog-centered"
         role="document">

        <div class="modal-content border-0 shadow">

            <form asp-action="DeleteRole"
                  asp-controller="AccessControl"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       id="deleteRoleId"
                       name="roleId" />

                <div class="modal-body text-center p-4">

                    <div class="mb-3">

                        <span class="d-inline-flex align-items-center justify-content-center bg-danger text-white rounded-circle"
                              style="width:65px; height:65px;">

                            <i class="fas fa-exclamation-triangle fa-lg"></i>

                        </span>

                    </div>

                    <h4 class="font-weight-bold mb-3">
                        Are you sure?
                    </h4>

                    <p class="text-muted mb-1">
                        Do you want to delete this role?
                    </p>

                    <p class="font-weight-bold text-secondary mb-4">
                        "<span id="deleteRoleName"></span>"
                    </p>

                    <div class="d-flex justify-content-center">

                        <button type="button"
                                class="btn btn-secondary btn-sm px-4 mr-2"
                                data-dismiss="modal">
                            Cancel
                        </button>

                        <button type="submit"
                                class="btn btn-danger btn-sm px-4">
                            Confirm
                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/AccessControl/roles.js" asp-append-version="true"></script>
}