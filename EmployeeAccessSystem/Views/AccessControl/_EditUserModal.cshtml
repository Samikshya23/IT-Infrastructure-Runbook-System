@model EmployeeAccessSystem.Models.AccessControlUserModel

<div class="modal-header bg-primary py-2 text-white">

    <h6 class="modal-title text-white mb-0">
        Edit User
    </h6>

    <button type="button"
            class="close text-white"
            data-dismiss="modal"
            aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>

</div>

<form asp-action="UpdateUser"
      asp-controller="AccessControl"
      method="post"
      id="editUserForm">

    @Html.AntiForgeryToken()

    <div class="modal-body p-2">

        <input type="hidden" asp-for="AccountId" />

        <div class="form-group mb-2">
            <label class="mb-1">Full Name</label>

            <input asp-for="FullName"
                   class="form-control form-control-sm"
                   placeholder="Enter full name" />
        </div>

        <div class="form-group mb-2">
            <label class="mb-1">Email</label>

            <input asp-for="Email"
                   class="form-control form-control-sm"
                   placeholder="Enter email" />
        </div>

        <div class="form-group mb-2">
            <label class="mb-1">Role</label>

            <select asp-for="RoleId"
                    asp-items="ViewBag.Roles"
                    class="form-control form-control-sm">

                <option value="0">
                    Select Role
                </option>

            </select>
        </div>

        <div class="form-group mb-0">
            <label class="mb-1">Status</label>

            <div class="custom-control custom-switch">
                <input asp-for="IsActive"
                       type="checkbox"
                       class="custom-control-input"
                       id="editUserStatus" />

                <label class="custom-control-label"
                       for="editUserStatus">
                    Active
                </label>
            </div>
        </div>

    </div>

    <div class="modal-footer justify-content-between py-2 bg-light">

        <button type="button"
                class="btn btn-secondary btn-sm"
                data-dismiss="modal">
            Back
        </button>

        <button type="submit"
                class="btn btn-primary btn-sm px-3">
            Update
        </button>

    </div>

</form>