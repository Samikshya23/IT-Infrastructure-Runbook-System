@model EmployeeAccessSystem.Models.AccessControlUserModel

<div class="modal-header bg-white">

    <h5 class="modal-title">
        <i class="fas fa-pen mr-1"></i>
        Edit User
    </h5>

</div>

<form asp-action="UpdateUser" asp-controller="AccessControl" method="post" id="editUserForm">

    @Html.AntiForgeryToken()

    <div class="modal-body">

        <input type="hidden" asp-for="AccountId" />

        <div class="form-group">
            <label>Full Name</label>
            <input asp-for="FullName" class="form-control form-control-sm" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input asp-for="Email" class="form-control form-control-sm" />
        </div>

        <div class="form-group">
            <label>Role</label>

            <select asp-for="RoleId" asp-items="ViewBag.Roles" class="form-control form-control-sm">
                <option value="0">Select Role</option>
            </select>
        </div>

        <div class="form-group mb-0">
            <label>Status</label>

            <div class="custom-control custom-switch">
                <input asp-for="IsActive"
                       type="checkbox"
                       class="custom-control-input"
                       id="editUserStatus" />

                <label class="custom-control-label" for="editUserStatus">
                    Active
                </label>
            </div>
        </div>

    </div>

    <div class="modal-footer">

        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">
            Back
        </button>

        <button type="submit" class="btn btn-primary btn-sm">
            Update
        </button>

    </div>

</form>