@model List<EmployeeAccessSystem.Models.AccessControlUserModel>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="content-header py-2">
    <div class="container-fluid">

        <div class="row align-items-center">

            <div class="col-sm-6">
                <h4 class="m-0 font-weight-bold">
                    Manage Users
                </h4>
            </div>

            <div class="col-sm-6 text-right">

                <a asp-controller="AccessControl"
                   asp-action="Index"
                   class="btn btn-secondary btn-sm">

                    <i class="fas fa-arrow-left mr-1"></i>
                    Dashboard

                </a>

                <button type="button"
                        id="btnCreateUser"
                        class="btn btn-primary btn-sm">

                    <i class="fas fa-user-plus mr-1"></i>
                    Add User

                </button>

            </div>

        </div>

    </div>
</div>

<section class="content">

    <div class="container-fluid">

        <div class="card card-outline card-primary mb-0">

            <div class="card-body p-2">

                <div class="row mb-2 align-items-center">

                    <div class="col-md-6">

                        <label class="font-weight-normal mb-0">

                            Show

                            <select id="customLength"
                                    class="form-control form-control-sm d-inline-block mx-1"
                                    style="width:75px;">

                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>

                            </select>

                            entries

                        </label>

                    </div>

                    <div class="col-md-6 text-right">

                        <input type="text"
                               id="customSearch"
                               class="form-control form-control-sm d-inline-block"
                               style="width:230px;"
                               placeholder="Search" />

                    </div>

                </div>

                <div class="table-responsive">

                    <table id="usersTable"
                           class="table table-bordered table-hover table-sm mb-0">

                        <thead>

                            <tr>

                                <th class="text-center" style="width:60px;">
                                    SN
                                </th>

                                <th>
                                    Full Name
                                </th>

                                <th>
                                    Email
                                </th>

                                <th class="text-center" style="width:150px;">
                                    Role
                                </th>

                                <th class="text-center" style="width:145px;">
                                    Actions
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            @if (Model != null && Model.Count > 0)
                            {
                                int sn = 1;

                                foreach (var item in Model)
                                {
                                    <tr>

                                        <td class="text-center align-middle">
                                            @sn
                                        </td>

                                        <td class="align-middle">
                                            @item.FullName
                                        </td>

                                        <td class="align-middle">
                                            @item.Email
                                        </td>

                                        <td class="text-center align-middle">
                                            @item.RoleName
                                        </td>

                                        <td class="text-center align-middle">

                                            @if (!string.Equals(item.RoleName, "Administrator", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <button type="button"
                                                        class="btn btn-xs btn-outline-primary btnEditUser"
                                                        data-account-id="@item.AccountId"
                                                        title="Edit">

                                                    <i class="fas fa-edit"></i>

                                                </button>

                                                <button type="button"
                                                        class="btn btn-xs btn-outline-dark btnUserPermission"
                                                        data-account-id="@item.AccountId"
                                                        title="Permission">

                                                    <i class="fas fa-key"></i>

                                                </button>

                                                <button type="button"
                                                        class="btn btn-xs btn-outline-warning btnForgotPassword"
                                                        data-account-id="@item.AccountId"
                                                        data-user-name="@item.FullName"
                                                        title="Forgot Password">

                                                    <i class="fas fa-unlock-alt"></i>

                                                </button>

                                                <button type="button"
                                                        class="btn btn-xs btn-outline-danger btnDeleteUser"
                                                        data-account-id="@item.AccountId"
                                                        data-user-name="@item.FullName"
                                                        title="Delete">

                                                    <i class="fas fa-trash-alt"></i>

                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="btn btn-xs btn-outline-primary btnEditUser"
                                                        data-account-id="@item.AccountId"
                                                        title="Edit">

                                                    <i class="fas fa-edit"></i>

                                                </button>

                                                <span class="badge badge-success ml-1">
                                                    Full Access
                                                </span>
                                            }

                                        </td>

                                    </tr>

                                    sn++;
                                }
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</section>

<div class="modal fade"
     id="createUserModal"
     tabindex="-1"
     role="dialog"
     aria-hidden="true">

    <div class="modal-dialog modal-md"
         role="document">

        <div class="modal-content"
             id="createUserModalContent">
        </div>

    </div>

</div>

<div class="modal fade"
     id="editUserModal"
     tabindex="-1"
     role="dialog"
     aria-hidden="true">

    <div class="modal-dialog modal-md"
         role="document">

        <div class="modal-content"
             id="editUserModalContent">
        </div>

    </div>

</div>

<div class="modal fade"
     id="userPermissionModal"
     tabindex="-1"
     role="dialog"
     aria-hidden="true">

    <div class="modal-dialog modal-xl"
         role="document">

        <div class="modal-content"
             id="userPermissionModalContent">
        </div>

    </div>

</div>

<div class="modal fade"
     id="deleteUserModal"
     tabindex="-1"
     role="dialog"
     aria-hidden="true">

    <div class="modal-dialog modal-sm modal-dialog-centered"
         role="document">

        <div class="modal-content border-0 shadow">

            <form asp-controller="AccessControl"
                  asp-action="DeleteUser"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       id="deleteAccountId"
                       name="accountId" />

                <div class="modal-body text-center p-4">

                    <div class="mb-3">

                        <span class="d-inline-flex align-items-center justify-content-center bg-danger text-white rounded-circle"
                              style="width:65px; height:65px;">

                            <i class="fas fa-exclamation-triangle fa-lg"></i>

                        </span>

                    </div>

                    <h4 class="font-weight-bold mb-3">
                        Are you sure?
                    </h4>

                    <p class="text-muted mb-1">
                        Do you want to delete this user?
                    </p>

                    <p class="font-weight-bold text-secondary mb-4">

                        "<span id="deleteUserName"></span>"

                    </p>

                    <div class="d-flex justify-content-center">

                        <button type="button"
                                class="btn btn-secondary btn-sm px-4 mr-2"
                                data-dismiss="modal">

                            Cancel

                        </button>

                        <button type="submit"
                                class="btn btn-danger btn-sm px-4">

                            Confirm

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

</div>

<div class="modal fade"
     id="forgotPasswordModal"
     tabindex="-1"
     role="dialog"
     aria-hidden="true">

    <div class="modal-dialog modal-md modal-dialog-centered"
         role="document">

        <div class="modal-content border-0 shadow-sm">

            <div class="modal-header bg-white py-2">

                <h6 class="modal-title mb-0">
                    <i class="fas fa-key mr-1 text-warning"></i>
                    Reset Password
                </h6>

                <button type="button"
                        class="close"
                        data-dismiss="modal"
                        aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>

            </div>

            <form asp-controller="AccessControl"
                  asp-action="ResetUserPassword"
                  method="post"
                  id="forgotPasswordForm">

                @Html.AntiForgeryToken()

                <div class="modal-body p-3">

                    <input type="hidden"
                           id="forgotAccountId"
                           name="accountId" />

                    <div class="alert alert-info py-2 px-3 text-sm mb-3">
                        Resetting password for user: <strong id="forgotUserName"></strong>
                    </div>

                    <div class="form-group mb-2">
                        <label class="mb-1 text-sm font-weight-normal">New Password</label>
                        <input type="password"
                               id="forgotNewPassword"
                               name="password"
                               class="form-control form-control-sm"
                               placeholder="Enter new password"
                               required />
                    </div>

                    <div class="form-group mb-0">
                        <label class="mb-1 text-sm font-weight-normal">Confirm New Password</label>
                        <input type="password"
                               id="forgotConfirmPassword"
                               name="confirmPassword"
                               class="form-control form-control-sm"
                               placeholder="Confirm new password"
                               required />
                    </div>

                </div>

                <div class="modal-footer justify-content-between py-2">

                    <button type="button"
                            class="btn btn-secondary btn-sm"
                            data-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit"
                            class="btn btn-warning btn-sm text-white px-3">
                        <i class="fas fa-paper-plane mr-1"></i>
                        Send
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <script src="~/js/accesscontrol/users.js"></script>

    <script src="~/js/accesscontrol/permission.js"></script>

}