@model List<EmployeeAccessSystem.Models.AccessControlUserModel>

@{
    ViewData["Title"] = "Manage Users";
    int sn = 1;
}

<section class="content pt-2 pb-0">

    <div class="container-fluid px-0">

        @* Page Header *@
        <div class="row mb-2 mx-0 align-items-center">

            <div class="col-sm-6 px-0">
                <h3 class="mb-0">Manage Users</h3>
            </div>

            <div class="col-sm-6 text-right px-0">

                <a href="/AccessControl/Index" class="btn btn-secondary btn-sm mr-1">
                    <i class="fas fa-arrow-left mr-1"></i>
                    Dashboard
                </a>

                <button type="button"
                        class="btn btn-primary btn-sm"
                        id="btnCreateUser">

                    <i class="fas fa-user-plus mr-1"></i>
                    Add User

                </button>

            </div>

        </div>

        @* User Table *@
        <div class="card card-outline card-primary mb-0 shadow-none">

            <div class="card-header bg-white pt-2 pb-2 px-3">

                <div class="row align-items-center">

                    <div class="col-md-6 d-flex align-items-center">

                        <label class="mb-0 mr-2 font-weight-normal">Show</label>

                        <select id="customLength"
                                class="custom-select custom-select-sm form-control form-control-sm"
                                style="width:70px;">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>

                        <label class="mb-0 ml-2 font-weight-normal">entries</label>

                    </div>

                    <div class="col-md-6 text-right">

                        <input type="text"
                               id="customSearch"
                               class="form-control form-control-sm d-inline-block"
                               placeholder="Search"
                               style="width:220px;" />

                    </div>

                </div>

            </div>

            <div class="card-body p-0">

                <table id="usersTable" class="table table-bordered table-hover table-sm mb-0">

                    <thead class="bg-light">

                        <tr>
                            <th class="text-center align-middle" style="width:70px;">SN</th>
                            <th class="align-middle">Full Name</th>
                            <th class="align-middle">Email</th>
                            <th class="text-center align-middle" style="width:150px;">Role</th>
                            <th class="text-center align-middle" style="width:190px;">Actions</th>
                        </tr>

                    </thead>

                    <tbody>

                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td class="text-center align-middle">@sn</td>

                                    <td class="align-middle">@item.FullName</td>

                                    <td class="align-middle">@item.Email</td>

                                    <td class="text-center align-middle">@item.RoleName</td>

                                    <td class="text-center align-middle">

                                        <button type="button"
                                                class="btn btn-xs btn-light border btnDetailsUser"
                                                data-account-id="@item.AccountId"
                                                title="Details">
                                            <i class="fas fa-eye"></i>
                                        </button>

                                        <button type="button"
                                                class="btn btn-xs btn-light border btnEditUser ml-1"
                                                data-account-id="@item.AccountId"
                                                title="Edit">
                                            <i class="fas fa-pen"></i>
                                        </button>

                                        @if (item.RoleName != "Administrator")
                                        {
                                            <button type="button"
                                                    class="btn btn-xs btn-light border btnUserPermission ml-1"
                                                    data-account-id="@item.AccountId"
                                                    title="Permission">
                                                <i class="fas fa-key"></i>
                                            </button>

                                            <button type="button"
                                                    class="btn btn-xs btn-outline-danger btnDeleteUser ml-1"
                                                    data-account-id="@item.AccountId"
                                                    data-user-name="@item.FullName"
                                                    title="Delete">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="badge badge-success ml-1">Full Access</span>
                                        }

                                    </td>

                                </tr>

                                sn++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-3">
                                    No users found.
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</section>

@* Create User Modal *@
<div class="modal fade" id="createUserModal" tabindex="-1" role="dialog" aria-hidden="true">

    <div class="modal-dialog modal-md" role="document">

        <div class="modal-content" id="createUserModalContent">
        </div>

    </div>

</div>

@* Details Modal *@
<div class="modal fade" id="detailsModal" tabindex="-1" role="dialog" aria-hidden="true">

    <div class="modal-dialog modal-md" role="document">

        <div class="modal-content" id="detailsModalContent">
        </div>

    </div>

</div>

@* Edit User Modal *@
<div class="modal fade" id="editUserModal" tabindex="-1" role="dialog" aria-hidden="true">

    <div class="modal-dialog modal-md" role="document">

        <div class="modal-content" id="editUserModalContent">
        </div>

    </div>

</div>

@* User Permission Modal *@
<div class="modal fade" id="userPermissionModal" tabindex="-1" role="dialog" aria-hidden="true">

    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">

        <div class="modal-content" id="userPermissionModalContent">
        </div>

    </div>

</div>

@* Delete User Modal *@
<div class="modal fade" id="deleteUserModal" tabindex="-1" role="dialog" aria-hidden="true">

    <div class="modal-dialog modal-sm" role="document">

        <div class="modal-content">

            <form asp-action="DeleteUser" asp-controller="AccessControl" method="post">

                @Html.AntiForgeryToken()

                <div class="modal-header bg-white">

                    <h5 class="modal-title">
                        <i class="fas fa-trash-alt mr-1"></i>
                        Delete User
                    </h5>

                </div>

                <div class="modal-body text-center">

                    <input type="hidden" id="deleteAccountId" name="accountId" />

                    <div class="mb-2">
                        <i class="fas fa-exclamation-triangle text-danger fa-2x"></i>
                    </div>

                    <p class="mb-0">
                        Are you sure you want to delete this user?
                    </p>

                    <strong id="deleteUserName" class="d-block mt-2"></strong>

                </div>

                <div class="modal-footer">

                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">
                        Back
                    </button>

                    <button type="submit" class="btn btn-danger btn-sm">
                        Delete
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/AccessControl/permission.js" asp-append-version="true"></script>
    <script src="~/js/AccessControl/users.js" asp-append-version="true"></script>
}