@{
    ViewData["Title"] = "Access Denied";
}

<section class="content pt-3">

    <div class="container-fluid">

        <div class="row justify-content-center">

            <div class="col-md-6">

                <div class="card card-outline card-danger shadow-none">

                    <div class="card-header bg-white text-center">

                        <h3 class="card-title float-none mb-0 text-danger">
                            <i class="fas fa-ban mr-1"></i>
                            Access Denied
                        </h3>

                    </div>

                    <div class="card-body text-center">

                        <div class="mb-3">
                            <i class="fas fa-lock text-danger fa-3x"></i>
                        </div>

                        <h5 class="mb-2">
                            You do not have permission.
                        </h5>

                        <p class="text-muted mb-3">
                            This page or action is restricted. Please contact the administrator if you need access.
                        </p>

                        <a href="/Home/Index" class="btn btn-secondary btn-sm mr-1">
                            <i class="fas fa-home mr-1"></i>
                            Go to Dashboard
                        </a>

                        <a href="javascript:history.back()" class="btn btn-primary btn-sm">
                            <i class="fas fa-arrow-left mr-1"></i>
                            Go Back
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>