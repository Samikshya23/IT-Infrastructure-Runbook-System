@model EmployeeAccessSystem.Models.AccessControlUserModel

<div class="modal-header bg-white">

    <h5 class="modal-title">
        <i class="fas fa-user mr-1"></i>
        User Details
    </h5>

</div>

<div class="modal-body">

    <div class="form-group">
        <label>Full Name</label>
        <input type="text" class="form-control form-control-sm" value="@Model.FullName" readonly />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input type="text" class="form-control form-control-sm" value="@Model.Email" readonly />
    </div>

    <div class="form-group">
        <label>Role</label>
        <input type="text" class="form-control form-control-sm" value="@Model.RoleName" readonly />
    </div>

    <div class="form-group mb-0">
        <label>Status</label>

        <div class="custom-control custom-switch">
            <input type="checkbox"
                   class="custom-control-input"
                   id="detailsUserStatus"
                   disabled
                   @(Model.IsActive ? "checked" : "") />

            <label class="custom-control-label" for="detailsUserStatus">
                @(Model.IsActive ? "Active" : "Inactive")
            </label>
        </div>
    </div>

</div>

<div class="modal-footer">

    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">
        Back
    </button>

</div>