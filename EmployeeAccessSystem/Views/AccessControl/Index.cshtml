@model EmployeeAccessSystem.Models.AccessControlDashboardModel

@{
    ViewData["Title"] = "Access Control";
}

<section class="content pt-2 pb-0">

    <div class="container-fluid px-0">

        <div class="row mb-2 mx-0 align-items-center">

            <div class="col-sm-6 px-0">
                <h3 class="mb-0">Access Control</h3>
            </div>

            @* <div class="col-sm-6 text-right px-0">

                <button type="button"
                        id="btnCreateUser"
                        class="btn btn-primary btn-sm">
                    <i class="fas fa-user-plus mr-1"></i>
                    Add User
                </button>

            </div> *@

        </div>

        <div class="row">

            <div class="col-lg-6 col-md-6 col-sm-6 col-12">

                <div class="small-box bg-info">

                    <div class="inner">
                        <h3>@Model.TotalUsers</h3>
                        <p>Users</p>
                    </div>

                    <div class="icon">
                        <i class="fas fa-users"></i>
                    </div>

                    <a href="/AccessControl/Users" class="small-box-footer">
                        Manage Users
                        <i class="fas fa-arrow-circle-right"></i>
                    </a>

                </div>

            </div>

            <div class="col-lg-6 col-md-6 col-sm-6 col-12">

                <div class="small-box bg-success">

                    <div class="inner">
                        <h3>@Model.TotalRoles</h3>
                        <p>Roles</p>
                    </div>

                    <div class="icon">
                        <i class="fas fa-user-shield"></i>
                    </div>

                    <a href="/AccessControl/Roles" class="small-box-footer">
                        Manage Roles
                        <i class="fas fa-arrow-circle-right"></i>
                    </a>

                </div>

            </div>

        </div>

    </div>

</section>

<div class="modal fade" id="createUserModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" id="createUserModalContent"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/accesscontrol/users.js" asp-append-version="true"></script>
}