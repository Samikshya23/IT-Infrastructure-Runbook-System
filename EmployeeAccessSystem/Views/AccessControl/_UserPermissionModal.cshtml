@using System
@using System.Collections.Generic
@using System.Linq
@model List<EmployeeAccessSystem.Models.AccessControlRoleActionModel>

@{
    int accountId = ViewBag.AccountId;

    List<EmployeeAccessSystem.Models.AccessControlRoleActionModel> permissionItems =
        new List<EmployeeAccessSystem.Models.AccessControlRoleActionModel>();

    if (Model != null)
    {
        foreach (var item in Model)
        {
            bool isDashboard =
                string.Equals(item.MenuName, "Dashboard", StringComparison.OrdinalIgnoreCase);

            bool isPrivacy =
                string.Equals(item.MenuName, "Privacy Dashboard", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(item.ActionName, "Privacy", StringComparison.OrdinalIgnoreCase);

            if (!isDashboard && !isPrivacy)
            {
                permissionItems.Add(item);
            }
        }
    }

    List<EmployeeAccessSystem.Models.AccessControlRoleActionModel> rootItems =
        permissionItems
            .Where(x => x.ParentMenuId == null)
            .OrderBy(x => x.MenuId)
            .ToList();

    List<EmployeeAccessSystem.Models.AccessControlRoleActionModel> GetChildren(int menuId)
    {
        return permissionItems
            .Where(x => x.ParentMenuId == menuId)
            .OrderBy(x => x.MenuId)
            .ToList();
    }
}

<div class="modal-header bg-white py-2">

    <h5 class="modal-title font-weight-bold">
        <i class="fas fa-key mr-1"></i>
        User Permission
    </h5>

    <button type="button"
            class="close"
            data-dismiss="modal"
            aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>

</div>

<form asp-action="SaveUserAccess"
      asp-controller="AccessControl"
      method="post"
      id="userPermissionForm">

    @Html.AntiForgeryToken()

    <input type="hidden"
           name="accountId"
           value="@accountId" />

    <div class="modal-body p-2 overflow-auto"
         style="max-height:70vh;">

        <div class="mb-2 text-right">

            <div class="custom-control custom-checkbox d-inline-block">

                <input type="checkbox"
                       class="custom-control-input"
                       id="selectAllPermission" />

                <label class="custom-control-label font-weight-normal"
                       for="selectAllPermission">
                    Select All
                </label>

            </div>

        </div>

        @if (permissionItems.Count > 0)
        {
            foreach (var root in rootItems)
            {
                List<EmployeeAccessSystem.Models.AccessControlRoleActionModel> rootChildren =
                GetChildren(root.MenuId);

                string rootCheckboxId = "permission_" + root.MenuId;
                string rootCollapseId = "collapse_" + root.MenuId;

                <div class="border rounded mb-2 permission-node-wrapper">

                    <div class="px-2 py-2 bg-light font-weight-bold text-dark d-flex align-items-center">

                        @if (rootChildren.Count > 0)
                        {
                            <span data-toggle="collapse"
                                  data-target="#@rootCollapseId"
                                  style="cursor:pointer;">
                                <i class="fas fa-angle-down mr-1"></i>
                            </span>
                        }
                        else
                        {
                            <span class="mr-3"></span>
                        }

                        <div class="custom-control custom-checkbox">

                            <input type="checkbox"
                                   class="custom-control-input permission-checkbox"
                                   id="@rootCheckboxId"
                                   name="checkedMenuIds"
                                   value="@root.MenuId"
                                   data-menu-id="@root.MenuId"
                                   data-parent-menu-id=""
                                   @(root.IsChecked ? "checked" : "") />

                            <label class="custom-control-label font-weight-bold"
                                   for="@rootCheckboxId">
                                @root.MenuName
                            </label>

                        </div>

                    </div>

                    <div id="@rootCollapseId"
                         class="collapse show">

                        @foreach (var level1 in rootChildren)
                        {
                            List<EmployeeAccessSystem.Models.AccessControlRoleActionModel> level1Children =
                            GetChildren(level1.MenuId);

                            string level1CheckboxId = "permission_" + level1.MenuId;
                            string level1CollapseId = "collapse_" + level1.MenuId;

                            <div class="ml-4 mt-2 mb-1">

                                <div class="d-flex align-items-center">

                                    @if (level1Children.Count > 0)
                                    {
                                        <span data-toggle="collapse"
                                              data-target="#@level1CollapseId"
                                              style="cursor:pointer;">
                                            <i class="fas fa-angle-down mr-1"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="mr-3"></span>
                                    }

                                    <div class="custom-control custom-checkbox">

                                        <input type="checkbox"
                                               class="custom-control-input permission-checkbox"
                                               id="@level1CheckboxId"
                                               name="checkedMenuIds"
                                               value="@level1.MenuId"
                                               data-menu-id="@level1.MenuId"
                                               data-parent-menu-id="@level1.ParentMenuId"
                                               @(level1.IsChecked ? "checked" : "") />

                                        <label class="custom-control-label font-weight-bold"
                                               for="@level1CheckboxId">
                                            @level1.MenuName
                                        </label>

                                    </div>

                                </div>

                                <div id="@level1CollapseId"
                                     class="collapse show">

                                    @foreach (var level2 in level1Children)
                                    {
                                        List<EmployeeAccessSystem.Models.AccessControlRoleActionModel> level2Children =
                                        GetChildren(level2.MenuId);

                                        string level2CheckboxId = "permission_" + level2.MenuId;
                                        string level2CollapseId = "collapse_" + level2.MenuId;

                                        <div class="ml-4 mt-2 mb-1">

                                            <div class="d-flex align-items-center">

                                                @if (level2Children.Count > 0)
                                                {
                                                    <span data-toggle="collapse"
                                                          data-target="#@level2CollapseId"
                                                          style="cursor:pointer;">
                                                        <i class="fas fa-angle-down mr-1"></i>
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="mr-3"></span>
                                                }

                                                <div class="custom-control custom-checkbox">

                                                    <input type="checkbox"
                                                           class="custom-control-input permission-checkbox"
                                                           id="@level2CheckboxId"
                                                           name="checkedMenuIds"
                                                           value="@level2.MenuId"
                                                           data-menu-id="@level2.MenuId"
                                                           data-parent-menu-id="@level2.ParentMenuId"
                                                           @(level2.IsChecked ? "checked" : "") />

                                                    <label class="custom-control-label font-weight-normal"
                                                           for="@level2CheckboxId">
                                                        @level2.MenuName
                                                    </label>

                                                </div>

                                            </div>

                                            <div id="@level2CollapseId"
                                                 class="collapse show">

                                                @foreach (var level3 in level2Children)
                                                {
                                                    List<EmployeeAccessSystem.Models.AccessControlRoleActionModel> level3Children =
                                                    GetChildren(level3.MenuId);

                                                    string level3CheckboxId = "permission_" + level3.MenuId;
                                                    string level3CollapseId = "collapse_" + level3.MenuId;

                                                    <div class="ml-4 mt-2 mb-1">

                                                        <div class="d-flex align-items-center">

                                                            @if (level3Children.Count > 0)
                                                            {
                                                                <span data-toggle="collapse"
                                                                      data-target="#@level3CollapseId"
                                                                      style="cursor:pointer;">
                                                                    <i class="fas fa-angle-down mr-1"></i>
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="mr-3"></span>
                                                            }

                                                            <div class="custom-control custom-checkbox">

                                                                <input type="checkbox"
                                                                       class="custom-control-input permission-checkbox"
                                                                       id="@level3CheckboxId"
                                                                       name="checkedMenuIds"
                                                                       value="@level3.MenuId"
                                                                       data-menu-id="@level3.MenuId"
                                                                       data-parent-menu-id="@level3.ParentMenuId"
                                                                       @(level3.IsChecked ? "checked" : "") />

                                                                <label class="custom-control-label font-weight-normal"
                                                                       for="@level3CheckboxId">
                                                                    @level3.MenuName
                                                                </label>

                                                            </div>

                                                        </div>

                                                        <div id="@level3CollapseId"
                                                             class="collapse show">

                                                            @foreach (var level4 in level3Children)
                                                            {
                                                                string level4CheckboxId = "permission_" + level4.MenuId;

                                                                <div class="ml-4 mt-2 mb-1">

                                                                    <div class="custom-control custom-checkbox">

                                                                        <input type="checkbox"
                                                                               class="custom-control-input permission-checkbox"
                                                                               id="@level4CheckboxId"
                                                                               name="checkedMenuIds"
                                                                               value="@level4.MenuId"
                                                                               data-menu-id="@level4.MenuId"
                                                                               data-parent-menu-id="@level4.ParentMenuId"
                                                                               @(level4.IsChecked ? "checked" : "") />

                                                                        <label class="custom-control-label font-weight-normal"
                                                                               for="@level4CheckboxId">
                                                                            @level4.MenuName
                                                                        </label>

                                                                    </div>

                                                                </div>
                                                            }

                                                        </div>

                                                    </div>
                                                }

                                            </div>

                                        </div>
                                    }

                                </div>

                            </div>
                        }

                    </div>

                </div>
            }
        }
        else
        {
            <div class="text-center text-muted py-3">
                No permission items found.
            </div>
        }

    </div>

    <div class="modal-footer py-2">

        <button type="button"
                class="btn btn-secondary btn-sm"
                data-dismiss="modal">
            Back
        </button>

        <button type="submit"
                class="btn btn-primary btn-sm">
            <i class="fas fa-save mr-1"></i>
            Save
        </button>

    </div>

</form>