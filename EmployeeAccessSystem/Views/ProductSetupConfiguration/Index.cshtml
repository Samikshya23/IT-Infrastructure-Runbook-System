@model List<EmployeeAccessSystem.Models.ProductSetupConfiguration>

@{
    ViewData["Title"] = "Product Setup Configuration";

    int selectedProductId = ViewBag.SelectedProductId;

    string successMessage = ViewBag.SuccessMessage;

    var products =
        ViewBag.Products as IEnumerable<EmployeeAccessSystem.Models.ProductSetupConfiguration>;
}

<section class="content pt-2 pb-0">

    <div class="container-fluid px-2">

        <input type="hidden" id="successMessage" value="@successMessage" />
        <input type="hidden" id="tempSuccessMessage" value="@TempData["Success"]" />
        <input type="hidden" id="tempErrorMessage" value="@TempData["Error"]" />
        <input type="hidden" id="selectedProductId" value="@selectedProductId" />

        <!-- Page header -->
        <div class="row mb-2 mx-0 align-items-center">

            <div class="col-sm-6 px-0">

                <h3 class="mb-0">
                    Product Setup Configuration
                </h3>

            </div>

            <div class="col-sm-6 text-right px-0">

                <button type="button"
                        id="btnAddSetupConfiguration"
                        class="btn btn-primary btn-sm">

                    <i class="fas fa-plus mr-1"></i>
                    Add

                </button>

            </div>

        </div>

        <!-- Main card -->
        <div class="card card-outline card-primary mb-0 shadow-none">

            <div class="card-header bg-white py-2 px-2">

                <div class="row mx-0">

                    <div class="col-md-4 px-0">

                        <label class="font-weight-bold mb-1">
                            Select
                        </label>

                        <select id="showProductId"
                                class="form-control form-control-sm">

                            <option value="">
                                Select
                            </option>

                            @if (products != null)
                            {
                                foreach (var product in products)
                                {
                                    if (selectedProductId == product.ProductId)
                                    {
                                        <option value="@product.ProductId" selected>
                                            @product.ProductName
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@product.ProductId">
                                            @product.ProductName
                                        </option>
                                    }
                                }
                            }

                        </select>

                    </div>

                </div>

            </div>

            <div id="setupTableContainer"></div>

        </div>

    </div>

</section>

<!-- Setup configuration modal -->
<div class="modal fade"
     id="setupConfigurationModal"
     tabindex="-1"
     role="dialog"
     data-backdrop="static"
     data-keyboard="false">

    <div class="modal-dialog modal-xl"
         role="document">

        <!-- Empty by default. Do not keep Loading here. -->
        <div class="modal-content rounded-0"
             id="setupConfigurationModalContent">
        </div>

    </div>

</div>

@section Scripts {

    <script src="~/js/productsetupconfiguration/index.js" asp-append-version="true"></script>

}