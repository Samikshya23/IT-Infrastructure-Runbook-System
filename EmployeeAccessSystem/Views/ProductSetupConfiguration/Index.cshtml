@model List<EmployeeAccessSystem.Models.ProductSetupConfiguration>

@{
    ViewData["Title"] = "Product Setup Configuration";
    int selectedProductId = ViewBag.SelectedProductId;
    string successMessage = ViewBag.SuccessMessage;
    var products = ViewBag.Products as IEnumerable<EmployeeAccessSystem.Models.ProductSetup>;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2 align-items-center">
            <div class="col-sm-6">
                <h4 class="m-0 font-weight-bold">Product Setup Configuration</h4>
            </div>

            <div class="col-sm-6 text-right">
                <button type="button"
                        class="btn btn-info btn-sm mr-2"
                        id="btnShowPanel">
                    <i class="fas fa-eye mr-1"></i>
                    Show Product Setup Configuration
                </button>

                <button type="button"
                        class="btn btn-primary btn-sm"
                        id="btnAddSetupConfiguration">
                    <i class="fas fa-plus mr-1"></i>
                    Add Product Setup Configuration
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show auto-hide-message">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @successMessage
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show auto-hide-message">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show auto-hide-message">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["Error"]
            </div>
        }

        <div class="card mb-2" id="showPanel" style="display:none;">
            <div class="card-body p-2">
                <div class="row align-items-end">
                    <div class="col-md-5">
                        <label class="font-weight-bold mb-1">Product</label>

                        <select id="showProductId" class="form-control form-control-sm">
                            <option value="">Select Product</option>

                            @if (products != null)
                            {
                                foreach (var product in products)
                                {
                                    if (selectedProductId == product.ProductId)
                                    {
                                        <option value="@product.ProductId" selected>
                                            @product.ProductName
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@product.ProductId">
                                            @product.ProductName
                                        </option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <button type="button"
                                class="btn btn-primary btn-sm"
                                id="btnLoadSetupTable">
                            Load
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div id="setupTableContainer">
            <div class="card">
                <div class="card-body text-center text-muted py-4">
                    Click <strong>Add Product Setup Configuration</strong> to create setup configuration.
                    Or click <strong>Show Product Setup Configuration</strong> to view saved setup.
                </div>
            </div>
        </div>

    </div>
</section>

<div class="modal fade"
     id="setupConfigurationModal"
     tabindex="-1"
     role="dialog"
     data-backdrop="static"
     data-keyboard="false">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content" id="setupConfigurationModalContent"></div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            setTimeout(function () {
                $(".auto-hide-message").fadeOut("slow");
            }, 3000);

            if (@selectedProductId > 0) {
                $("#showPanel").show();
                loadSetupTable(@selectedProductId);
            }

            $("#btnShowPanel").off("click").on("click", function () {
                $("#showPanel").slideToggle();
            });

            $("#btnLoadSetupTable").off("click").on("click", function () {
                var productId = $("#showProductId").val();

                if (productId === "") {
                    alert("Please select product.");
                    return;
                }

                loadSetupTable(productId);
            });

            $(document).on("click", "#btnAddSetupConfiguration", function () {
                var productId = $("#showProductId").val();

                $.get("/ProductSetupConfiguration/Add",
                    {
                        productId: productId
                    },
                    function (data) {
                        $("#setupConfigurationModalContent").html(data);
                        $("#setupConfigurationModal").modal("show");
                    });
            });

            function loadSetupTable(productId) {
                $("#setupTableContainer").html(
                    '<div class="card"><div class="card-body text-center text-muted py-4">Loading...</div></div>'
                );

                $("#setupTableContainer").load(
                    "/ProductSetupConfiguration/ShowTable?productId=" + productId
                );
            }
        });
    </script>
}