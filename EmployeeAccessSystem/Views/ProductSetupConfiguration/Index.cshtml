@model List<EmployeeAccessSystem.Models.ProductSetupConfiguration>

@{
    ViewData["Title"] = "Product Setup Configuration";
    int selectedProductId = ViewBag.SelectedProductId;
    string successMessage = ViewBag.SuccessMessage;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2 align-items-center">
            <div class="col-sm-6">
                <h4 class="m-0 font-weight-bold">Product Setup Configuration</h4>
            </div>

            <div class="col-sm-6 text-right">
                <button type="button"
                        class="btn btn-primary btn-sm"
                        id="btnAddSetupConfiguration">
                    <i class="fas fa-plus mr-1"></i>
                    Add Product Setup Configuration
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show auto-hide-message">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @successMessage
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show auto-hide-message">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show auto-hide-message">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["Error"]
            </div>
        }

        @if (Model != null && Model.Count > 0)
        {
            <div class="card card-outline card-secondary">
                <div class="card-header py-2">
                    <h3 class="card-title font-weight-bold">Setup Tree</h3>
                </div>

                <div class="card-body">
                    @foreach (var node in Model)
                    {
                        <partial name="_TreeNode" model="node" />
                    }
                </div>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body text-center text-muted py-4">
                    Click <strong>Add Product Setup Configuration</strong> to create setup configuration.
                </div>
            </div>
        }

    </div>
</section>

<div class="modal fade" id="setupConfigurationModal" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content" id="setupConfigurationModalContent"></div>
    </div>
</div>

<div class="modal fade" id="nodeModal" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" id="nodeModalContent"></div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            setTimeout(function () {
                $(".auto-hide-message").fadeOut("slow");
            }, 3000);

            $(document).on("click", "#btnAddSetupConfiguration", function () {
                $.get("/ProductSetupConfiguration/Add",
                    {
                        productId: @selectedProductId
                    },
                    function (data) {
                        $("#setupConfigurationModalContent").html(data);
                        $("#setupConfigurationModal").modal("show");
                    });
            });

            $(document).on("click", ".btnAddChild", function () {
                var nodeId = $(this).data("node-id");
                var productId = $(this).data("product-id");

                $.get("/ProductSetupConfiguration/AddChild",
                    {
                        parentNodeId: nodeId,
                        productId: productId
                    },
                    function (data) {
                        $("#nodeModalContent").html(data);
                        $("#nodeModal").modal("show");
                    });
            });

            $(document).on("click", ".btnEditNode", function () {
                var nodeId = $(this).data("node-id");

                $.get("/ProductSetupConfiguration/EditNode",
                    {
                        nodeId: nodeId
                    },
                    function (data) {
                        $("#nodeModalContent").html(data);
                        $("#nodeModal").modal("show");
                    });
            });

            $(document).on("click", ".btnDeleteNode", function () {
                var nodeId = $(this).data("node-id");

                $.get("/ProductSetupConfiguration/DeleteNode",
                    {
                        nodeId: nodeId
                    },
                    function (data) {
                        $("#nodeModalContent").html(data);
                        $("#nodeModal").modal("show");
                    });
            });

        });
    </script>
}