@using System.Text.Json

@{
    Layout = null;

    int selectedProductId = ViewBag.SelectedProductId;
    int rootIndex = ViewBag.RootIndex;

    var products = ViewBag.Products as IEnumerable<EmployeeAccessSystem.Models.ProductSetupConfiguration>;
    var valueTypes = ViewBag.ValueTypes as IEnumerable<EmployeeAccessSystem.Models.DropdownItemModel>;

    string valueTypeJson = JsonSerializer.Serialize(valueTypes);
}

<div class="modal-header bg-white border-bottom">
    <h5 class="modal-title font-weight-bold">
        @(rootIndex >= 0 ? "Edit Setup Configuration" : "Setup Configuration")
    </h5>
</div>

<div class="modal-body">

    <input type="hidden" id="RootIndex" value="@rootIndex" />
    <input type="hidden" id="SelectedProductId" value="@selectedProductId" />

    <!-- Main card -->
    <div class="card card-outline card-primary mb-0 shadow-none">

        <!-- Card header -->
        <div class="card-header bg-white border-bottom-0 py-1 px-2 ">
        <div class="card-body p-2">
            <div class="form-group mb-0">
                <label class="font-weight-bold mb-1">Select</label>

                <select id="ProductId" class="form-control form-control-sm" @(rootIndex >= 0 ? "disabled" : "")>
                    <option value="">Select</option>

                    @if (products != null)
                    {
                        foreach (var product in products)
                        {
                            if (selectedProductId == product.ProductId)
                            {
                                <option value="@product.ProductId" selected>@product.ProductName</option>
                            }
                            else
                            {
                                <option value="@product.ProductId">@product.ProductName</option>
                            }
                        }
                    }
                </select>
            </div>
        </div>
    </div>

    <div id="generatedSetupArea" style="display:none;">
        <div class="card shadow-none">
            <div class="card-body p-2">
                <div id="nodeContainer"></div>
            </div>
        </div>
    </div>

</div>

<div class="modal-footer">
    <button type="button" id="btnFooterClose" class="btn btn-secondary btn-sm">Close</button>
    <button type="button" id="btnSave" class="btn btn-primary btn-sm">Save</button>
</div>

<div class="modal fade" id="confirmCloseModal" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow">
            <div class="modal-body text-center py-4">
                <div class="mb-3">
                    <i class="fas fa-exclamation-circle text-warning" style="font-size:50px;"></i>
                </div>

                <h4 class="font-weight-bold mb-3">Are you sure?</h4>
                <p class="mb-0">Do you want to close this form?</p>
            </div>

            <div class="modal-footer justify-content-center bg-light border-top-0">
                <button type="button" id="btnContinueEditing" class="btn btn-secondary btn-sm px-4">No</button>
                <button type="button" id="btnConfirmClose" class="btn btn-danger btn-sm px-4">Yes</button>
            </div>
        </div>
    </div>
</div>

<script>
    window.productSetupValueTypes = @Html.Raw(valueTypeJson);
</script>

<script src="~/js/productsetupconfiguration/add.js" asp-append-version="true"></script>