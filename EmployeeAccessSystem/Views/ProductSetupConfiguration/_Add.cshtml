@{
    Layout = null;

    int selectedProductId = ViewBag.SelectedProductId;
    var products = ViewBag.Products as IEnumerable<EmployeeAccessSystem.Models.ProductSetup>;
}
<div class="modal-header bg-white border-bottom">
    <h5 class="modal-title font-weight-bold">Product Setup Configuration</h5>
</div>
<div class="modal-body">
    <div class="card card-outline card-secondary mb-2">
        <div class="card-body p-2">
            <div class="row align-items-end">
                <div class="col-md-12">
                    <label class="font-weight-bold mb-1">Product</label>

                    <select id="ProductId" class="form-control form-control-sm">
                        <option value="">Select Product</option>

                        @if (products != null)
                        {
                            foreach (var product in products)
                            {
                                if (selectedProductId == product.ProductId)
                                {
                                    <option value="@product.ProductId" selected>
                                        @product.ProductName
                                    </option>
                                }
                                else
                                {
                                    <option value="@product.ProductId">
                                        @product.ProductName
                                    </option>
                                }
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="card card-outline card-secondary">
        <div class="card-header py-2">
            <h3 class="card-title font-weight-bold">Generated Setup Form</h3>
        </div>

        <div class="card-body p-2">
            <div id="nodeContainer">
                <div class="text-muted text-center py-3" id="emptyMessage">
                    Select product to load setup form.
                </div>
            </div>
        </div>
    </div>

</div>

<div class="modal-footer">
    <button type="button" id="btnFooterClose" class="btn btn-secondary btn-sm">
        Close
    </button>

    <button type="button" id="btnSave" class="btn btn-primary btn-sm">
        Save
    </button>
</div>

<div class="modal fade"
     id="confirmCloseModal"
     tabindex="-1"
     role="dialog"
     data-backdrop="static"
     data-keyboard="false">

    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <div class="modal-header bg-white border-bottom">
                <h5 class="modal-title font-weight-bold">Unsaved Changes</h5>
            </div>

            <div class="modal-body text-center py-4">
                <div class="font-weight-bold">
                    Do you want to close this form?
                </div>
            </div>

            <div class="modal-footer justify-content-center bg-light">
                <button type="button" id="btnContinueEditing" class="btn btn-secondary btn-sm px-3">
                    Continue Editing
                </button>

                <button type="button" id="btnConfirmClose" class="btn btn-danger btn-sm px-3">
                    Yes, Close
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    $(document).ready(function () {

        var selectedProductId = @selectedProductId;

        // Load setup form when product is already selected.
        if (selectedProductId > 0) {
            $("#ProductId").val(selectedProductId);
            loadGeneratedForm(selectedProductId);
        }
        $("#ProductId").off("change").on("change", function () {
            var productId = $(this).val();

            $("#nodeContainer").html(
                '<div class="text-muted text-center py-3" id="emptyMessage">Select product to load setup form.</div>'
            );

            if (productId === "") {
                return;
            }

            loadGeneratedForm(productId);
        });
        // Load root levels from ProductConfiguration JSON.
        function loadGeneratedForm(productId) {
            $("#nodeContainer").html(
                '<div class="text-muted text-center py-3">Loading setup form...</div>'
            );
            $.get(
                "/ProductSetupConfiguration/GetRootLevels",
                { productId: productId },
                function (response) {
                    if (!response.success) {
                        showToastMessage("error", response.message);
                        return;
                    }

                    if (response.data == null || response.data.length === 0) {
                        $("#nodeContainer").html(
                            '<div class="text-muted text-center py-3">No Product Configuration found for this product.</div>'
                        );
                        return;
                    }
                    $("#nodeContainer").html("");

                    for (var i = 0; i < response.data.length; i++) {
                        addConfiguredRow($("#nodeContainer"), 0, response.data[i], true);
                    }
                    refreshActionButtons();
                }
            );
        }
        // Create setup row from configuration node.
        function addConfiguredRow(container, level, configNode, isRootLevel) {
            var margin = level * 30;
            var html = "";

            html += '<div class="node-row mb-2" ';
            html += 'data-level="' + level + '" ';
            html += 'data-config-id="' + configNode.id + '" ';
            html += 'data-heading="' + encodeHtml(configNode.heading) + '" ';
            html += 'data-label-name="' + encodeHtml(configNode.name) + '" ';
            html += 'data-input-type="' + configNode.inputType + '" ';
            html += 'data-root="' + isRootLevel + '" ';
            html += 'style="margin-left:' + margin + 'px;">';

            html += '<div class="row align-items-center">';

            html += '<div class="col-md-3">';
            html += '<label class="mb-0 font-weight-bold">';
            html += encodeHtml(configNode.name);
            html += '</label>';
            html += '</div>';

            html += '<div class="col-md-5">';
            html += '<input type="text" maxlength="100" ';
            html += 'class="form-control form-control-sm node-value" ';
            html += 'placeholder="Enter ' + encodeHtml(configNode.name) + '">';
            html += '</div>';

            if (isRootLevel === true) {
                html += '<div class="col-md-2">';
                html += '<select class="form-control form-control-sm field-type">';
                html += '<option value="">Select</option>';
                html += '<option value="Percentage">Percentage</option>';
                html += '<option value="Tick/Untick">Tick/Untick</option>';
                html += '<option value="Check/Unchecked">Check/Unchecked</option>';
                html += '<option value="Up/Down">Up/Down</option>';
                html += '<option value="Value">Value</option>';
                html += '<option value="Text">Text</option>';
                html += '<option value="Date">Date</option>';
                html += '</select>';
                html += '</div>';
            }
            else {
                html += '<div class="col-md-2"></div>';
            }

            html += '<div class="col-md-2 text-right">';

            html += '<button type="button" ';
            html += 'class="btn btn-outline-primary btn-sm btn-add-same mr-1" ';
            html += 'title="Add same level">';
            html += '<i class="fas fa-plus"></i>';
            html += '</button>';

            html += '<button type="button" ';
            html += 'class="btn btn-outline-danger btn-sm btn-remove-row" ';
            html += 'title="Remove">';
            html += '<i class="fas fa-minus"></i>';
            html += '</button>';

            html += '</div>';

            html += '</div>';
            html += '<div class="child-area mt-2"></div>';
            html += '</div>';

            container.append(html);

            var currentRow = container.children(".node-row").last();

            // Child levels are generated automatically from ProductConfiguration.
            loadDefaultChildren(currentRow);
        }

        // Load child levels for selected configuration node.
        function loadDefaultChildren(parentRow) {
            var productId = $("#ProductId").val();
            var configId = parentRow.attr("data-config-id");
            var childArea = parentRow.children(".child-area");
            var level = getLevel(parentRow);

            $.get(
                "/ProductSetupConfiguration/GetChildLevels",
                {
                    productId: productId,
                    parentConfigurationNodeId: configId
                },
                function (response) {
                    if (!response.success) {
                        showToastMessage("error", response.message);
                        return;
                    }

                    if (response.data == null || response.data.length === 0) {
                        refreshActionButtons();
                        return;
                    }

                    for (var i = 0; i < response.data.length; i++) {
                        addConfiguredRow(childArea, level + 1, response.data[i], false);
                    }

                    refreshActionButtons();
                }
            );
        }

        $(document).off("click", ".btn-add-same");
        $(document).on("click", ".btn-add-same", function () {
            var currentRow = $(this).closest(".node-row");
            var currentValue = currentRow.find("> .row .node-value").val();

            if ($.trim(currentValue) === "") {
                showToastMessage("error", "Please type value first.");
                return;
            }

            var parentContainer = currentRow.parent();
            var configNode = getConfigFromRow(currentRow);
            var level = getLevel(currentRow);
            var isRootLevel = currentRow.attr("data-root") === "true";

            addConfiguredRow(parentContainer, level, configNode, isRootLevel);
            refreshActionButtons();
        });

        $(document).off("click", ".btn-remove-row");
        $(document).on("click", ".btn-remove-row", function () {
            var currentRow = $(this).closest(".node-row");

            // In setup form, removing parent also removes its child setup values.
            currentRow.remove();
            if ($("#nodeContainer").children(".node-row").length === 0) {
                $("#nodeContainer").html(
                    '<div class="text-muted text-center py-3" id="emptyMessage">Select product to load setup form.</div>'
                );
            }
            refreshActionButtons();
        });

        function getConfigFromRow(row) {
            return {
                id: row.attr("data-config-id"),
                heading: row.attr("data-heading"),
                name: row.attr("data-label-name"),
                inputType: row.attr("data-input-type")
            };
        }
        function getLevel(row) {
            var level = row.attr("data-level");

            if (level === undefined || level === null || level === "") {
                return 0;
            }

            return parseInt(level);
        }
        // Controls plus/minus buttons for Root, Single, and Multiple.
        function refreshActionButtons() {
            $("#nodeContainer").find(".node-row").each(function () {
                var row = $(this);
                var inputType = row.attr("data-input-type");
                var isRootLevel = row.attr("data-root") === "true";

                row.find("> .row .btn-add-same").hide();
                row.find("> .row .btn-remove-row").hide();

                // Root/Product level: allow + and -.
                if (isRootLevel === true) {
                    row.find("> .row .btn-add-same").show();
                    row.find("> .row .btn-remove-row").show();
                    return;
                }

                // Single level: no -, but - is allowed.
                 // Single level is compulsory, so no + and no -.
    if (inputType === "Single") {
        return;
    }

                // Multiple level: only last sibling shows +, all rows show -.
                if (inputType === "Multiple") {
                    var siblingRows = row.parent().children(".node-row");
                    var isLastRow = row.is(siblingRows.last());
                    if (isLastRow) {
                        row.find("> .row .btn-add-same").show();
                    }

                    row.find("> .row .btn-remove-row").show();
                }
            });
        }

        $("#btnSave").off("click").on("click", function () {
            saveData();
        });

        function saveData() {
            var productId = $("#ProductId").val();

            if (productId === "") {
                showToastMessage("error", "Please select product.");
                return;
            }

            if ($("#nodeContainer").children(".node-row").length === 0) {
                showToastMessage("error", "Please add setup data.");
                return;
            }

            if (!validateRows($("#nodeContainer"))) {
                return;
            }

            var nodes = collectRows($("#nodeContainer"));

            $.ajax({
                url: "/ProductSetupConfiguration/SaveData",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({
                    productId: parseInt(productId),
                    nodes: nodes
                }),
                success: function (response) {
                    if (response.success) {
                        window.location.href =
                            "/ProductSetupConfiguration?selectedProductId=" +
                            productId +
                            "&successMessage=" +
                            encodeURIComponent(response.message);
                    }
                    else {
                        showToastMessage("error", response.message);
                    }
                },
                error: function () {
                    showToastMessage("error", "Error while saving setup configuration.");
                }
            });
        }

        // Validate setup values before sending to backend.
        function validateRows(container) {
            var valid = true;

            container.find(".node-row").each(function () {
                var row = $(this);
                var nodeValue = row.find("> .row .node-value").val();

                if ($.trim(nodeValue) === "") {
                    showToastMessage("error", "Please type value for all rows.");
                    valid = false;
                    return false;
                }

                if (row.find("> .row .field-type").length > 0) {
                    var fieldType = row.find("> .row .field-type").val();

                    if (fieldType === "") {
                        showToastMessage("error", "Please select field type.");
                        valid = false;
                        return false;
                    }
                }
            });

            return valid;
        }

        // Collect setup data in same hierarchy as ProductConfiguration.
        function collectRows(container) {
            var data = [];

            container.children(".node-row").each(function () {
                var row = $(this);
                var nodeValue = row.find("> .row .node-value").val();
                var configurationNodeId = row.attr("data-config-id");
                var fieldType = null;

                if (row.find("> .row .field-type").length > 0) {
                    fieldType = row.find("> .row .field-type").val();
                }

                data.push({
                    heading: row.attr("data-heading"),
                    label: row.attr("data-label-name"),
                    valueType: row.attr("data-input-type"),
                    value: $.trim(nodeValue),
                    fieldType: fieldType,
                    configurationNodeId: parseInt(configurationNodeId),
                    children: collectRows(row.children(".child-area"))
                });
            });

            return data;
        }

        $("#btnFooterClose").off("click").on("click", function () {
            $("#confirmCloseModal").modal("show");
        });

        $("#btnContinueEditing").off("click").on("click", function () {
            $("#confirmCloseModal").modal("hide");
        });

        $("#btnConfirmClose").off("click").on("click", function () {
            $("#confirmCloseModal").modal("hide");
            $("#setupConfigurationModal").modal("hide");
        });

        function encodeHtml(value) {
            if (value === null || value === undefined) {
                return "";
            }

            return $("<div/>").text(value).html();
        }

        // Common notification function.
        function showToastMessage(type, message) {
            if (typeof toastr === "undefined") {
                alert(message);
                return;
            }

            toastr.options = {
                closeButton: true,
                progressBar: true,
                newestOnTop: true,
                positionClass: "toast-top-right",
                preventDuplicates: true,
                timeOut: "3000"
            };

            if (type === "success") {
                toastr.success(message);
            }

            if (type === "error") {
                toastr.error(message);
            }

            if (type === "warning") {
                toastr.warning(message);
            }

            if (type === "info") {
                toastr.info(message);
            }
        }
    });
</script>