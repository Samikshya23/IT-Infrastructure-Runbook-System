@model EmployeeAccessSystem.Models.ProductSetupConfiguration

@{
    ViewData["Title"] = "Add Product Setup Configuration";
}

<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">Add Product Setup Configuration</h3>
    </div>

    <form asp-action="Add" method="post">

        <div class="card-body">

            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" asp-for="ParentNodeId" />
            <input type="hidden" asp-for="ConfigurationNodeId" />
            <input type="hidden" asp-for="ConfigurationNodeName" />
            <input type="hidden" asp-for="InputType" />

            <div class="form-group">
                <label>Configuration Level</label>
                <input type="text"
                       class="form-control"
                       value="@Model.ConfigurationNodeName"
                       readonly />
            </div>

            <div class="form-group">
                <label>@Model.ConfigurationNodeName</label>

                @if (Model.InputType == "Date")
                {
                    <input asp-for="NodeValue"
                           type="date"
                           class="form-control"
                           required />
                }
                else
                {
                    <input asp-for="NodeValue"
                           type="text"
                           class="form-control"
                           placeholder="Enter @Model.ConfigurationNodeName"
                           required />
                }
            </div>

        </div>

        <div class="card-footer text-right">
            <a asp-action="Index"
               asp-route-productId="@Model.ProductId"
               class="btn btn-secondary">
                Back
            </a>

            <button type="submit" class="btn btn-primary">
                Save
            </button>
        </div>

    </form>
</div>