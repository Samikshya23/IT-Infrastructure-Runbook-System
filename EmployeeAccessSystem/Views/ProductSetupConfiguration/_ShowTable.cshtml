@model List<EmployeeAccessSystem.Models.ProductSetupConfiguration>

@functions {

    private void BuildColumnNames(
        EmployeeAccessSystem.Models.ProductSetupConfiguration node,
        List<string> columns)
    {
        if (node == null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(node.ConfigurationNodeName))
        {
            columns.Add("Level " + (columns.Count + 1));
        }
        else
        {
            columns.Add(node.ConfigurationNodeName);
        }

        if (node.Children != null && node.Children.Count > 0)
        {
            BuildColumnNames(node.Children[0], columns);
        }
    }

    private void BuildRows(
        EmployeeAccessSystem.Models.ProductSetupConfiguration node,
        List<string> currentRow,
        List<List<string>> rows)
    {
        if (node == null)
        {
            return;
        }

        currentRow.Add(node.NodeValue);

        if (node.Children == null || node.Children.Count == 0)
        {
            rows.Add(new List<string>(currentRow));
        }
        else
        {
            for (int i = 0; i < node.Children.Count; i++)
            {
                BuildRows(node.Children[i], currentRow, rows);
            }
        }

        currentRow.RemoveAt(currentRow.Count - 1);
    }

    private int GetRowSpan(
        List<List<string>> rows,
        int startIndex,
        int columnIndex)
    {
        int count = 1;

        for (int i = startIndex + 1; i < rows.Count; i++)
        {
            bool sameGroup = true;

            for (int c = 0; c <= columnIndex; c++)
            {
                string currentValue = c < rows[startIndex].Count ? rows[startIndex][c] : "";
                string nextValue = c < rows[i].Count ? rows[i][c] : "";

                if (currentValue != nextValue)
                {
                    sameGroup = false;
                    break;
                }
            }

            if (sameGroup)
            {
                count++;
            }
            else
            {
                break;
            }
        }

        return count;
    }

    private bool ShouldShowCell(
        List<List<string>> rows,
        int rowIndex,
        int columnIndex)
    {
        if (rowIndex == 0)
        {
            return true;
        }

        for (int c = 0; c <= columnIndex; c++)
        {
            string currentValue = c < rows[rowIndex].Count ? rows[rowIndex][c] : "";
            string previousValue = c < rows[rowIndex - 1].Count ? rows[rowIndex - 1][c] : "";

            if (currentValue != previousValue)
            {
                return true;
            }
        }

        return false;
    }
}

@{
    List<string> columns = new List<string>();
    List<List<string>> rows = new List<List<string>>();
    List<int> rowRootIndexes = new List<int>();

    if (Model != null && Model.Count > 0)
    {
        BuildColumnNames(Model[0], columns);

        for (int r = 0; r < Model.Count; r++)
        {
            List<List<string>> rootRows = new List<List<string>>();

            BuildRows(Model[r], new List<string>(), rootRows);

            for (int i = 0; i < rootRows.Count; i++)
            {
                rows.Add(rootRows[i]);
                rowRootIndexes.Add(r);
            }
        }
    }
}

@if (Model != null && Model.Count > 0)
{
    <div class="card mb-0 shadow-none border-0">

        <div class="card-body p-0">

            <table id="setupDynamicTable"
                   class="table table-bordered table-hover table-sm mb-0 rounded-0">

                <thead class="bg-light border-bottom">

                    <tr>

                        <th class="text-center align-middle"
                            style="width:70px;">
                            SN
                        </th>

                        @for (int c = 0; c < columns.Count; c++)
                        {
                            <th class="text-center align-middle">
                                @columns[c]
                            </th>
                        }

                        <th class="text-center align-middle"
                            style="width:90px;">
                            Actions
                        </th>

                    </tr>

                </thead>

                <tbody>

                    @{
                        int sn = 1;
                        int previousRootIndex = -1;
                    }

                    @for (int i = 0; i < rows.Count; i++)
                    {
                        int currentRootIndex = rowRootIndexes[i];

                        <tr>

                            @if (currentRootIndex != previousRootIndex)
                            {
                                int rootRowSpan = 0;

                                for (int x = 0; x < rowRootIndexes.Count; x++)
                                {
                                    if (rowRootIndexes[x] == currentRootIndex)
                                    {
                                        rootRowSpan++;
                                    }
                                }

                                <td class="text-center align-middle"
                                    rowspan="@rootRowSpan">

                                    @sn

                                </td>
                            }

                            @for (int c = 0; c < columns.Count; c++)
                            {
                                if (ShouldShowCell(rows, i, c))
                                {
                                    int rowspan = GetRowSpan(rows, i, c);

                                    <td class="align-middle px-2"
                                        rowspan="@rowspan">

                                        @if (c < rows[i].Count)
                                        {
                                            @rows[i][c]
                                        }

                                    </td>
                                }
                            }

                            @if (currentRootIndex != previousRootIndex)
                            {
                                int rootRowSpan = 0;

                                for (int x = 0; x < rowRootIndexes.Count; x++)
                                {
                                    if (rowRootIndexes[x] == currentRootIndex)
                                    {
                                        rootRowSpan++;
                                    }
                                }

                                <td class="text-center align-middle"
                                    rowspan="@rootRowSpan">

                                    <button type="button"
                                            class="btn btn-xs btn-light border btnEditSetupConfiguration"
                                            data-product-id="@Model[currentRootIndex].ProductId"
                                            data-root-index="@currentRootIndex"
                                            title="Edit">

                                        <i class="fas fa-pen"></i>

                                    </button>

                                </td>

                                sn++;
                                previousRootIndex = currentRootIndex;
                            }

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
}
else
{
    <div class="card mb-0 shadow-none border-0">

        <div class="card-body text-center text-muted py-4">

            No data found.

        </div>

    </div>
}