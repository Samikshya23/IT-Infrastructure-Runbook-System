@model List<EmployeeAccessSystem.Models.ProductSetupConfiguration>

@{
    int sn = 1;

    string firstColumn = "Product";
    string secondColumn = "Item";

    if (Model != null && Model.Count > 0)
    {
        firstColumn = Model[0].ConfigurationNodeName;

        if (Model[0].Children != null && Model[0].Children.Count > 0)
        {
            secondColumn = Model[0].Children[0].ConfigurationNodeName;
        }
    }
}

@if (Model != null && Model.Count > 0)
{
    <div class="card mb-0 border-left border-right border-bottom shadow-none rounded-0">

        <div class="card-header bg-white border-bottom-0 py-1 px-2 rounded-0">
            <div class="d-flex justify-content-end">
                <div style="width:250px;">
                    <input type="text"
                           id="customSearch"
                           class="form-control form-control-sm"
                           placeholder="Search" />
                </div>
            </div>
        </div>

        <div class="card-body p-0">

            <table id="setupDynamicTable"
                   class="table table-bordered table-hover table-sm mb-0 rounded-0">

                <thead class="bg-light border-bottom">
                    <tr>
                        <th class="text-center align-middle" style="width:70px;">
                            SN
                        </th>

                        <th class="text-center align-middle">
                            @firstColumn
                        </th>

                        <th class="text-center align-middle">
                            @secondColumn
                        </th>

                        <th class="text-center align-middle" style="width:90px;">
                            Actions
                        </th>
                    </tr>
                </thead>

                <tbody>

                    @for (int r = 0; r < Model.Count; r++)
                    {
                        var root = Model[r];

                        int rowCount = 1;

                        if (root.Children != null && root.Children.Count > 0)
                        {
                            rowCount = root.Children.Count;
                        }

                        if (root.Children != null && root.Children.Count > 0)
                        {
                            for (int i = 0; i < root.Children.Count; i++)
                            {
                                <tr>

                                    @if (i == 0)
                                    {
                                        <td class="text-center align-middle"
                                            rowspan="@rowCount">
                                            @sn
                                        </td>

                                        <td class="align-middle px-2"
                                            rowspan="@rowCount">
                                            @root.NodeValue
                                        </td>
                                    }

                                    <td class="align-middle px-2">
                                        @root.Children[i].NodeValue
                                    </td>

                                    @if (i == 0)
                                    {
                                        <td class="text-center align-middle"
                                            rowspan="@rowCount">

                                            <button type="button"
                                                    class="btn btn-xs btn-light border btnEditSetupConfiguration"
                                                    data-product-id="@root.ProductId"
                                                    data-root-index="@r"
                                                    title="Edit">
                                                <i class="fas fa-pen"></i>
                                            </button>

                                        </td>

                                        sn++;
                                    }

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td class="text-center align-middle">
                                    @sn
                                </td>

                                <td class="align-middle px-2">
                                    @root.NodeValue
                                </td>

                                <td class="align-middle px-2"></td>

                                <td class="text-center align-middle">

                                    <button type="button"
                                            class="btn btn-xs btn-light border btnEditSetupConfiguration"
                                            data-product-id="@root.ProductId"
                                            data-root-index="@r"
                                            title="Edit">
                                        <i class="fas fa-pen"></i>
                                    </button>

                                </td>

                            </tr>

                            sn++;
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

    <script>

        $(function () {

            if ($.fn.DataTable.isDataTable("#setupDynamicTable")) {
                $("#setupDynamicTable").DataTable().destroy();
            }

            var table = $("#setupDynamicTable").DataTable({
                paging: true,
                searching: true,
                ordering: true,
                info: true,
                lengthChange: true,
                pageLength: 10,
                autoWidth: false,
                dom: "lrtip"
            });

            $("#customSearch").off("keyup").on("keyup", function () {
                table.search(this.value).draw();
            });

        });

        $(document).off("click", ".btnEditSetupConfiguration");

        $(document).on("click", ".btnEditSetupConfiguration", function () {

            var productId = $(this).data("product-id");
            var rootIndex = $(this).data("root-index");

            $.get("/ProductSetupConfiguration/Add",
                {
                    productId: productId,
                    rootIndex: rootIndex
                },
                function (data) {

                    $("#setupConfigurationModalContent").html(data);

                    $("#setupConfigurationModal").modal("show");
                });
        });

    </script>
}
else
{
    <div class="card mb-0 border-left border-right border-bottom shadow-none rounded-0">
        <div class="card-body text-center text-muted py-4">
            No setup data found for selected product.
        </div>
    </div>
}