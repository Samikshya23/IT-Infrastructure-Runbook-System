@model List<EmployeeAccessSystem.Models.ProductSetupConfiguration>

@{
    int sn = 1;
    string firstColumn = "Product";
    string secondColumn = "Item";

    if (Model != null && Model.Count > 0)
    {
        firstColumn = Model[0].ConfigurationNodeName;

        if (Model[0].Children != null && Model[0].Children.Count > 0)
        {
            secondColumn = Model[0].Children[0].ConfigurationNodeName;
        }
    }
}

@if (Model != null && Model.Count > 0)
{
    <div class="card mb-0 border-left border-right border-bottom shadow-none rounded-0">

        @* <div class="card-header bg-white border-bottom-0 py-1 px-2 rounded-0">
            <div class="d-flex justify-content-end">
                <div class="col-md-3 px-0">
                    <input type="text"
                           id="customSearch"
                           class="form-control form-control-sm"
                           placeholder="Search" />
                </div>
            </div>
        </div> *@

        <div class="card-body p-0">
            <table id="setupDynamicTable"
                   class="table table-bordered table-hover table-sm mb-0 rounded-0">

                <thead class="bg-light border-bottom">
                    <tr>
                        <th class="text-center align-middle" style="width:70px;">SN</th>
                        <th class="text-center align-middle">@firstColumn</th>
                        <th class="text-center align-middle">@secondColumn</th>
                        <th class="text-center align-middle" style="width:90px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @for (int r = 0; r < Model.Count; r++)
                    {
                        var root = Model[r];

                        <tr>
                            <td class="text-center align-middle">@sn</td>

                            <td class="align-middle px-2">
                                @root.NodeValue
                            </td>

                            <td class="align-middle px-2">
                                @if (root.Children != null && root.Children.Count > 0)
                                {
                                    for (int i = 0; i < root.Children.Count; i++)
                                    {
                                        <div class="py-1 @(i < root.Children.Count - 1 ? "border-bottom" : "")">
                                            @root.Children[i].NodeValue
                                        </div>
                                    }
                                }
                            </td>

                            <td class="text-center align-middle">
                                <button type="button"
                                        class="btn btn-xs btn-light border btnEditSetupConfiguration"
                                        data-product-id="@root.ProductId"
                                        data-root-index="@r"
                                        title="Edit">
                                    <i class="fas fa-pen"></i>
                                </button>
                            </td>
                        </tr>

                        sn++;
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card mb-0 border-left border-right border-bottom shadow-none rounded-0">
        <div class="card-body text-center text-muted py-4">
            No setup data found for selected product.
        </div>
    </div>
}