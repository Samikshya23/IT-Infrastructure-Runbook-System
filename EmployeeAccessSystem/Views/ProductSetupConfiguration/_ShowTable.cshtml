@model List<EmployeeAccessSystem.Models.ProductSetupConfiguration>

@functions {
    public class DisplayRow
    {
        public List<string> Values { get; set; }
        public bool IsFirstRow { get; set; }
        public int RowSpan { get; set; }

        public DisplayRow()
        {
            Values = new List<string>();
        }
    }

    public void AddColumns(EmployeeAccessSystem.Models.ProductSetupConfiguration node, List<string> columns)
    {
        if (node == null)
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(node.ConfigurationNodeName) &&
            !columns.Contains(node.ConfigurationNodeName))
        {
            columns.Add(node.ConfigurationNodeName);
        }

        if (node.Children != null && node.Children.Count > 0)
        {
            foreach (var child in node.Children)
            {
                AddColumns(child, columns);
            }
        }
    }

    public void BuildRows(
        EmployeeAccessSystem.Models.ProductSetupConfiguration node,
        List<string> columns,
        Dictionary<string, string> path,
        List<DisplayRow> rows)
    {
        if (node == null)
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(node.ConfigurationNodeName))
        {
            path[node.ConfigurationNodeName] = node.NodeValue;
        }

        if (node.Children == null || node.Children.Count == 0)
        {
            DisplayRow row = new DisplayRow();

            foreach (string column in columns)
            {
                if (path.ContainsKey(column))
                {
                    row.Values.Add(path[column]);
                }
                else
                {
                    row.Values.Add("");
                }
            }

            rows.Add(row);
            return;
        }

        foreach (var child in node.Children)
        {
            Dictionary<string, string> childPath =
                new Dictionary<string, string>(path);

            BuildRows(child, columns, childPath, rows);
        }
    }
}

@{
    List<string> columns = new List<string>();
    List<List<DisplayRow>> groupedRows = new List<List<DisplayRow>>();

    if (Model != null)
    {
        foreach (var root in Model)
        {
            AddColumns(root, columns);
        }

        foreach (var root in Model)
        {
            List<DisplayRow> rows = new List<DisplayRow>();
            Dictionary<string, string> path = new Dictionary<string, string>();

            BuildRows(root, columns, path, rows);

            for (int i = 0; i < rows.Count; i++)
            {
                rows[i].IsFirstRow = i == 0;
                rows[i].RowSpan = rows.Count;
            }

            groupedRows.Add(rows);
        }
    }

    int sn = 1;
}

@if (columns.Count > 0 && groupedRows.Count > 0)
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover table-sm mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="text-center align-middle" style="width:70px;">SN</th>

                        @foreach (string column in columns)
                        {
                            <th class="text-center align-middle">@column</th>
                        }

                        <th class="text-center align-middle" style="width:110px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (List<DisplayRow> group in groupedRows)
                    {
                        foreach (DisplayRow row in group)
                        {
                            <tr>
                                @if (row.IsFirstRow)
                                {
                                    <td class="text-center align-middle" rowspan="@row.RowSpan">
                                        @sn
                                    </td>
                                }

                                @for (int i = 0; i < row.Values.Count; i++)
                                {
                                    <td class="align-middle">@row.Values[i]</td>
                                }

                                @if (row.IsFirstRow)
                                {
                                    <td class="text-center align-middle" rowspan="@row.RowSpan">
                                        <button type="button"
                                                class="btn btn-xs btn-light border"
                                                title="Edit">
                                            <i class="fas fa-pen"></i>
                                        </button>

                                        <button type="button"
                                                class="btn btn-xs btn-outline-danger ml-1"
                                                title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </td>

                                    sn++;
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center text-muted py-4">
            No setup data found for selected product.
        </div>
    </div>
}