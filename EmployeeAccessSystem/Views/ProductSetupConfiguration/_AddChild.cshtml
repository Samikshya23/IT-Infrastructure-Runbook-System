@model EmployeeAccessSystem.Models.ProductSetupConfiguration

@{
    Layout = null;
}

<div class="modal-header bg-white border-bottom">
    <h5 class="modal-title font-weight-bold">
        Add @(Model.IsFieldValue ? "Field Value" : "Setup Node")
    </h5>
</div>

<form asp-action="AddChild" method="post">
    <div class="modal-body">

        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="ParentNodeId" />
        <input type="hidden" asp-for="IsFieldValue" />

        @if (!Model.IsFieldValue)
        {
            <div class="form-group">
                <label>Configuration Label</label>
                <select asp-for="ConfigurationNodeId" class="form-control form-control-sm" required>
                    <option value="">Select Label</option>

                    @if (Model.AvailableConfigurationNodes != null)
                    {
                        foreach (var item in Model.AvailableConfigurationNodes)
                        {
                            <option value="@item.NodeId">@item.NodeName</option>
                        }
                    }
                </select>
            </div>
        }
        else
        {
            <input type="hidden" asp-for="ConfigurationNodeId" />
            <input type="hidden" asp-for="ConfigurationNodeName" />
        }

        <div class="form-group">
            <label>
                @(Model.IsFieldValue ? "Field Value" : "Value")
            </label>

            <input asp-for="NodeValue"
                   type="text"
                   class="form-control form-control-sm"
                   required />
        </div>

        @if (Model.IsFieldValue)
        {
            <div class="form-group">
                <label>Field Type</label>
                <select asp-for="FieldType" class="form-control form-control-sm">
                    <option value="Text">Text</option>
                    <option value="Up/Down">Up/Down</option>
                    <option value="Tick/Untick">Tick/Untick</option>
                    <option value="Yes/No">Yes/No</option>
                    <option value="Percentage">Percentage</option>
                    <option value="Date">Date</option>
                </select>
            </div>
        }

    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">
            Close
        </button>

        <button type="submit" class="btn btn-primary btn-sm">
            Save
        </button>
    </div>
</form>