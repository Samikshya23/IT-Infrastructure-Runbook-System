@model EmployeeAccessSystem.Models.ProductSetupConfiguration
@{
    Layout = null;
}
<div class="modal-header bg-white border-bottom">
    <h5 class="modal-title font-weight-bold text-danger">
        Delete Setup Node
    </h5>
</div>
<form asp-action="DeleteConfirmed" method="post">
    <div class="modal-body">
        <input type="hidden" name="nodeId" value="@Model.NodeId" />
        <input type="hidden" name="productId" value="@Model.ProductId" />

        <div class="text-center py-3">
            <i class="fas fa-exclamation-triangle text-danger fa-2x mb-3"></i>

            <div class="font-weight-bold">
                Are you sure you want to delete this item?
            </div>

            <div class="text-muted mt-2">
                This will also delete all child nodes under this item.
            </div>

            <div class="mt-3">
                @if (Model.IsFieldValue)
                {
                    <span class="badge badge-secondary">Field Value</span>
                }
                else
                {
                    <span class="badge badge-info">@Model.ConfigurationNodeName</span>
                }

                <strong class="ml-2">@Model.NodeValue</strong>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">
            Cancel
        </button>
        <button type="submit" class="btn btn-danger btn-sm">
            Delete
        </button>
    </div>
</form>