@model EmployeeAccessSystem.Models.ProductSetupConfiguration

@{
    Layout = null;
}

<div class="modal-header bg-white border-bottom">

    <h5 class="modal-title font-weight-bold text-danger">
        Delete Setup Node
    </h5>

</div>

<form asp-action="DeleteConfirmed" method="post">

    <div class="modal-body">

        @* Hidden Fields *@
        <input type="hidden" name="nodeId" value="@Model.NodeId" />
        <input type="hidden" name="productId" value="@Model.ProductId" />

        <div class="text-center py-3">

            @* Warning Icon *@
            <div class="mb-3">
                <i class="fas fa-exclamation-triangle text-danger fa-2x"></i>
            </div>

            @* Confirmation Message *@
            <div class="font-weight-bold">
                Are you sure you want to delete this item?
            </div>

            @* Description *@
            <div class="text-muted mt-2">
                This will also delete all child nodes under this item.
            </div>

            @* Selected Item Info *@
            <div class="mt-3">

                @if (Model.IsFieldValue)
                {
                    <span class="badge badge-secondary">
                        Field Value
                    </span>
                }
                else
                {
                    <span class="badge badge-info">
                        @Model.ConfigurationNodeName
                    </span>
                }

                <strong class="ml-2">
                    @Model.NodeValue
                </strong>

            </div>

        </div>

    </div>

    <div class="modal-footer">

        @* Cancel Button *@
        <button type="button"
                class="btn btn-secondary btn-sm"
                data-dismiss="modal">
            Cancel
        </button>

        @* Delete Button *@
        <button type="submit"
                class="btn btn-danger btn-sm">
            Delete
        </button>

    </div>

</form>