@model EmployeeAccessSystem.Models.ProductSetupConfiguration
@{
    ViewData["Title"] = "Edit " + Model.ConfigurationNodeName;
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2 align-items-center">
            <div class="col-sm-6">
                <h4 class="m-0 font-weight-bold">
                    <i class="fas fa-edit text-warning mr-2"></i>
                    Edit @Model.ConfigurationNodeName
                </h4>
            </div>
        </div>
    </div>
</div>
<section class="content">
    <div class="container-fluid">
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title font-weight-bold">
                    @if (Model.IsFieldValue)
                    {
                        <span>Edit Field Value</span>
                    }
           m         else
                    {
                        <span>Edit @Model.ConfigurationNodeName</span>
                    }
                </h3>
            </div>
            <form asp-action="Edit" method="post">
                <div class="card-body">
                    <input type="hidden" asp-for="NodeId" />
                    <input type="hidden" asp-for="ProductId" />
                    <input type="hidden" asp-for="ConfigurationNodeId" />
                    <input type="hidden" asp-for="ParentNodeId" />
                    <input type="hidden" asp-for="ConfigurationNodeName" />
                    <input type="hidden" asp-for="InputType" />
                    <input type="hidden" asp-for="IsFieldValue" />
                    <div class="form-group">
                        <label>
                            @if (Model.IsFieldValue)
                            {
                                <span>Field Value</span>
                            }
                            else
                            {
                                <span>@Model.ConfigurationNodeName</span>
                            }
                        </label>
                        @if (Model.InputType == "Date")
                        {
                            <input asp-for="NodeValue"
                                   type="date"
                                   class="form-control"
                                   required />
                        }
                        else
                        {
                            <input asp-for="NodeValue"
                                   type="text"
                                   class="form-control"
                                   required />
                        }
                    </div>
                </div>
                <div class="card-footer text-right">
                    <a asp-action="Index"
                       asp-route-productId="@Model.ProductId"
                       class="btn btn-secondary">
                        <i class="fas fa-arrow-left mr-1"></i> Back
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save mr-1"></i> Update
                    </button>
                </div>
            </form>
        </div>

    </div>
</section>