@model EmployeeAccessSystem.Models.ProductSetupConfiguration

@{
    Layout = null;
}

<div class="modal-header bg-white border-bottom">
    <h5 class="modal-title font-weight-bold">
        Edit @(Model.IsFieldValue ? "Field Value" : Model.ConfigurationNodeName)
    </h5>
</div>

<form asp-action="EditNode" method="post">

    @* Hidden Fields *@
    <input type="hidden" asp-for="NodeId" />
    <input type="hidden" asp-for="ProductId" />

    <div class="modal-body">

        @* Value Input *@
        <div class="form-group mb-3">
            <label class="font-weight-bold mb-1">
                @(Model.IsFieldValue ? "Field Value" : Model.ConfigurationNodeName)
            </label>

            <input asp-for="NodeValue"
                   type="text"
                   class="form-control form-control-sm"
                   maxlength="100"
                   autocomplete="off"
                   required />
        </div>

        @* Field Type Dropdown *@
        @if (Model.IsFieldValue)
        {
            <div class="form-group mb-0">

                <label class="font-weight-bold mb-1">
                    Field Type
                </label>

                <select asp-for="FieldType"
                        class="form-control form-control-sm">

                    <option value="Text">Text</option>
                    <option value="Up/Down">Up/Down</option>
                    <option value="Tick/Untick">Tick/Untick</option>
                    <option value="Yes/No">Yes/No</option>
                    <option value="Percentage">Percentage</option>
                    <option value="Date">Date</option>

                </select>

            </div>
        }

    </div>

    <div class="modal-footer">

        @* Close Button *@
        <button type="button"
                class="btn btn-secondary btn-sm"
                data-dismiss="modal">
            Close
        </button>

        @* Update Button *@
        <button type="submit"
                class="btn btn-primary btn-sm">
            Update
        </button>

    </div>

</form>