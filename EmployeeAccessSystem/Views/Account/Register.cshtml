@model EmployeeAccessSystem.Models.RegisterModel

@{
    ViewData["Title"] = "Register";
    Layout = "_AuthLayout";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<div class="auth-bg">
    <div class="auth-container">
        <div class="auth-card">

            <div class="text-center mb-4">
                <h2 class="auth-title">Create Account</h2>
                <p class="auth-subtitle">Please fill in the details below.</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form asp-action="Register" method="post" autocomplete="off">

                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input asp-for="FullName"
                           class="form-control"
                           placeholder="Enter your full name" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email"
                           type="email"
                           class="form-control"
                           placeholder="Enter your email" />
                </div>

              @*   <div class="mb-3">
                    <select asp-for="DepartmentId"
                            class="form-control"
                            asp-items="ViewBag.Departments">
                        <option value="">-- Select Department --</option>
                    </select>
                </div> *@

                <div class="row">

                    <div class="col-md-6 mb-3 pw-wrapper">
                        <label class="form-label">Password</label>

                        <div class="pw-pop" id="pwPop">
                            <strong>Password must:</strong>
                            <ul>
                                <li>Be at least 6 characters long</li>
                                <li>Contain 1 uppercase letter</li>
                                <li>Contain 1 lowercase letter</li>
                            </ul>
                        </div>
                        <div class="password-group">
                            <input asp-for="Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="Enter password"
                                   id="Password"
                                   autocomplete="new-password" />

                            <span class="eye-icon" onclick="togglePassword('Password','toggleIconPwd')">
                                <i class="bi bi-eye-slash" id="toggleIconPwd"></i>
                            </span>
                        </div>

                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Confirm Password</label>

                        <div class="password-group">
                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Confirm password"
                                   id="ConfirmPassword"
                                   autocomplete="new-password" />

                            <span class="eye-icon" onclick="togglePassword('ConfirmPassword','toggleIconCpwd')">
                                <i class="bi bi-eye-slash" id="toggleIconCpwd"></i>
                            </span>
                        </div>

                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                </div>

                <button type="submit" class="btn auth-btn w-100">
                    Register
                </button>

                <div class="text-center mt-3">
                    <span class="text-muted">Already have an account?</span>
                    <a asp-action="Login" class="auth-link fw-semibold ms-1">Login</a>
                </div>

            </form>

        </div>
    </div>
</div>

<style>
    html, body {
        height: 100%;
        margin: 0;
        font-family: "Poppins", "Inter", system-ui, sans-serif;
        background: #f4f8fd;
    }

    .auth-bg {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .auth-container {
        width: 100%;
        max-width: 520px;
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e3eaf2;
        box-shadow: 0 20px 40px rgba(0, 40, 100, 0.08);
        padding: 36px 34px;
    }

    .auth-title {
        font-size: 28px;
        font-weight: 700;
        color: #1e293b;
    }

    .auth-subtitle {
        font-size: 14px;
        color: #64748b;
    }

    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #334155;
    }

    .form-control {
        height: 44px;
        border-radius: 8px;
        border: 1px solid #dbe5f1;
        padding: 0 12px;
        font-size: 14px;
    }

        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.2);
        }

    .auth-btn {
        height: 40px;
        border-radius: 6px;
        background-color: #2563eb;
        border: 1px solid #2563eb;
        color: #ffffff;
        font-size: 14px;
        font-weight: 600;
    }

        .auth-btn:hover {
            background-color: #1e4fd6;
        }

    .auth-link {
        color: #2563eb;
        text-decoration: none;
    }

        .auth-link:hover {
            text-decoration: underline;
        }

    /* popup */
    .pw-wrapper {
        position: relative;
    }

    .pw-pop {
        position: absolute;
        top: 35px;
        right: -320px;
        width: 300px;
        background: #eaf4ff;
        border: 1px solid #cfe6ff;
        border-radius: 10px;
        padding: 12px;
        font-size: 13px;
        color: #0f172a;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        display: none;
        z-index: 1000;
    }

        .pw-pop ul {
            margin: 8px 0 0 18px;
        }
    .password-group {
        position: relative;
    }

        .password-group input {
            padding-right: 42px;
        }

    .eye-icon {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        font-size: 18px;
        color: #475569;
        user-select: none;
    }

        .eye-icon:hover {
            color: #2563eb;
        }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const passwordInput = document.getElementById("Password");
        const popup = document.getElementById("pwPop");

        if (passwordInput && popup) {
            passwordInput.addEventListener("focus", function () {
                popup.style.display = "block";
            });

            document.addEventListener("click", function (event) {
                if (!popup.contains(event.target) && event.target !== passwordInput) {
                    popup.style.display = "none";
                }
            });
        }
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);

            if (!input || !icon) return;

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            }
        }
    </script>
}