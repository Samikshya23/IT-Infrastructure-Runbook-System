@{
    int? selectedCategoryId = ViewBag.SelectedCategoryId as int?;
    DateTime? fromDate = ViewBag.FromDate as DateTime?;
    DateTime? toDate = ViewBag.ToDate as DateTime?;
}

<div class="modal fade"
     id="emailReportModal"
     tabindex="-1"
     role="dialog"
     aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered"
         role="document">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-info text-white py-2">
                <h5 class="modal-title font-weight-bold" style="font-size: 16px;">
                    <i class="fas fa-envelope mr-1"></i> Email Report
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="emailReportForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="categoryId" value="@selectedCategoryId" />
                <input type="hidden" name="fromDate" value="@(fromDate.HasValue ? fromDate.Value.ToString("yyyy-MM-dd") : "")" />
                <input type="hidden" name="toDate" value="@(toDate.HasValue ? toDate.Value.ToString("yyyy-MM-dd") : "")" />
                
                <div class="modal-body p-3">
                    <div class="form-group mb-3">
                        <label for="senderEmail" class="font-weight-bold">Sender Email</label>
                        <input type="email" 
                               id="senderEmail" 
                               name="senderEmail" 
                               class="form-control" 
                               placeholder="Enter sender email address" 
                               required />
                    </div>

                    <div class="form-group mb-3">
                        <label for="senderPassword" class="font-weight-bold">Sender App Password</label>
                        <input type="password" 
                               id="senderPassword" 
                               name="senderPassword" 
                               class="form-control" 
                               placeholder="Enter sender app password" 
                               required />
                    </div>

                    <!-- Optional SMTP Server Settings (Advanced) -->
                    <div class="mb-3">
                        <button type="button" class="btn btn-link btn-xs p-0 text-info font-weight-bold" data-toggle="collapse" data-target="#smtpSettingsCollapse" aria-expanded="false" aria-controls="smtpSettingsCollapse" style="font-size: 12px; text-decoration: none;">
                            <i class="fas fa-cog mr-1"></i> Advanced SMTP Settings (Optional)
                        </button>
                        <div class="collapse mt-2" id="smtpSettingsCollapse">
                            <div class="card card-body bg-light p-3 border mb-0" style="border-radius: 8px;">
                                <div class="form-group mb-2">
                                    <label class="text-xs mb-1 font-weight-normal" style="font-size: 11px;">SMTP Host</label>
                                    <input type="text" id="smtpHost" name="smtpHost" class="form-control form-control-sm" placeholder="e.g. smtp.gmail.com" />
                                </div>
                                <div class="row">
                                    <div class="col-6">
                                        <div class="form-group mb-0">
                                            <label class="text-xs mb-1 font-weight-normal" style="font-size: 11px;">SMTP Port</label>
                                            <input type="number" id="smtpPort" name="smtpPort" class="form-control form-control-sm" placeholder="e.g. 587" />
                                        </div>
                                    </div>
                                    <div class="col-6 d-flex align-items-end">
                                        <div class="custom-control custom-checkbox mb-2">
                                            <input type="checkbox" class="custom-control-input" id="enableSsl" name="enableSsl" value="true" checked>
                                            <label class="custom-control-label text-xs font-weight-normal" for="enableSsl" style="font-size: 11px;">Enable SSL</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-group mb-3">
                        <label for="recipientEmail" class="font-weight-bold">Receiver Email</label>
                        <input type="text" 
                               id="recipientEmail" 
                               name="recipientEmail" 
                               class="form-control" 
                               placeholder="Enter receiver email address" 
                               required />
                    </div>
                    <div class="form-group mb-3">
                        <label for="subject" class="font-weight-bold">Subject</label>
                        <input type="text" 
                               id="subject" 
                               name="subject" 
                               class="form-control" 
                               placeholder="Enter email subject" 
                               required />
                    </div>
                    <div class="form-group mb-3">
                        <label for="message" class="font-weight-bold">Message</label>
                        <textarea id="message" 
                                  name="message" 
                                  class="form-control" 
                                  rows="3" 
                                  placeholder="Enter email message body" 
                                  required></textarea>
                    </div>
                    <div class="form-group mb-0">
                        <label class="font-weight-bold">Report Format</label>
                        <div class="d-flex mt-1">
                            <div class="custom-control custom-radio mr-4">
                                <input class="custom-control-input" type="radio" id="formatPdf" name="fileType" value="pdf" checked>
                                <label for="formatPdf" class="custom-control-label font-weight-normal">
                                    <i class="fas fa-file-pdf text-danger mr-1"></i> PDF
                                </label>
                            </div>
                            <div class="custom-control custom-radio">
                                <input class="custom-control-input" type="radio" id="formatExcel" name="fileType" value="excel">
                                <label for="formatExcel" class="custom-control-label font-weight-normal">
                                    <i class="fas fa-file-excel text-success mr-1"></i> Excel
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer p-2 d-flex justify-content-end bg-light">
                    <button type="button" class="btn btn-secondary btn-sm px-3 mr-2" data-dismiss="modal">Cancel</button>
                    <button type="submit" id="btnSendReportEmailSubmit" class="btn btn-info btn-sm px-4 text-white font-weight-bold">
                        <i class="fas fa-paper-plane mr-1"></i> Send
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
