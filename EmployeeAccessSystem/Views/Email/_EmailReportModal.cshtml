@{
    int? selectedCategoryId = ViewBag.SelectedCategoryId as int?;
    DateTime? fromDate = ViewBag.FromDate as DateTime?;
    DateTime? toDate = ViewBag.ToDate as DateTime?;
}

<div class="modal fade"
     id="emailReportModal"
     tabindex="-1"
     role="dialog"
     aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered"
         role="document">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-info text-white py-2">
                <h5 class="modal-title font-weight-bold" style="font-size: 16px;">
                    <i class="fas fa-envelope mr-1"></i> Email Report
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="emailReportForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="categoryId" value="@selectedCategoryId" />
                <input type="hidden" name="fromDate" value="@(fromDate.HasValue ? fromDate.Value.ToString("yyyy-MM-dd") : "")" />
                <input type="hidden" name="toDate" value="@(toDate.HasValue ? toDate.Value.ToString("yyyy-MM-dd") : "")" />
                
                <div class="modal-body p-3">
                    <div class="form-group mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="font-weight-bold mb-0">Sender Email</label>
                            <div>
                                <button type="button" id="btnChangeSender" class="btn btn-link btn-xs p-0 text-info font-weight-bold" style="font-size: 12px; text-decoration: none;">
                                    <i class="fas fa-edit mr-1"></i>Change Sender
                                </button>
                                <button type="button" id="btnResetSender" class="btn btn-link btn-xs p-0 text-danger font-weight-bold d-none" style="font-size: 12px; text-decoration: none;">
                                    <i class="fas fa-undo mr-1"></i>Reset to Default
                                </button>
                            </div>
                        </div>
                        <input type="email" 
                               id="senderEmailDisplay" 
                               class="form-control" 
                               value="@ViewBag.SenderEmail" 
                               readonly />
                        
                        <!-- Hidden inputs to submit sender credentials -->
                        <input type="hidden" id="senderEmail" name="senderEmail" value="@ViewBag.SenderEmail" data-default="@ViewBag.SenderEmail" />
                        <input type="hidden" id="senderPassword" name="senderPassword" value="" />
                    </div>

                    <!-- Collapsible Custom Sender credentials panel -->
                    <div id="divChangeSender" class="card card-body bg-light p-2 mb-3 d-none border">
                        <h6 class="font-weight-bold mb-2" style="font-size: 13px;">Change Sender Credentials</h6>
                        <div class="form-group mb-2">
                            <label class="text-xs mb-1" style="font-size: 11px;">New Sender Email</label>
                            <input type="email" id="txtNewSenderEmail" class="form-control form-control-sm" placeholder="Enter new sender email" />
                        </div>
                        <div class="form-group mb-2">
                            <label class="text-xs mb-1" style="font-size: 11px;">New Sender Password</label>
                            <input type="password" id="txtNewSenderPassword" class="form-control form-control-sm" placeholder="Enter password for new sender" />
                        </div>
                        <div class="text-right">
                            <button type="button" id="btnApplySender" class="btn btn-xs btn-success px-2 mr-1">OK</button>
                            <button type="button" id="btnCancelSender" class="btn btn-xs btn-secondary px-2">Cancel</button>
                        </div>
                    </div>
                    <div class="form-group mb-3">
                        <label for="recipientEmail" class="font-weight-bold">Receiver Email</label>
                        <input type="text" 
                               id="recipientEmail" 
                               name="recipientEmail" 
                               class="form-control" 
                               placeholder="Enter receiver email address" 
                               required />
                    </div>
                    <div class="form-group mb-3">
                        <label for="subject" class="font-weight-bold">Subject</label>
                        <input type="text" 
                               id="subject" 
                               name="subject" 
                               class="form-control" 
                               placeholder="Enter email subject" 
                               required />
                    </div>
                    <div class="form-group mb-3">
                        <label for="message" class="font-weight-bold">Message</label>
                        <textarea id="message" 
                                  name="message" 
                                  class="form-control" 
                                  rows="3" 
                                  placeholder="Enter email message body" 
                                  required></textarea>
                    </div>
                    <div class="form-group mb-0">
                        <label class="font-weight-bold">Report Format</label>
                        <div class="d-flex mt-1">
                            <div class="custom-control custom-radio mr-4">
                                <input class="custom-control-input" type="radio" id="formatPdf" name="fileType" value="pdf" checked>
                                <label for="formatPdf" class="custom-control-label font-weight-normal">
                                    <i class="fas fa-file-pdf text-danger mr-1"></i> PDF
                                </label>
                            </div>
                            <div class="custom-control custom-radio">
                                <input class="custom-control-input" type="radio" id="formatExcel" name="fileType" value="excel">
                                <label for="formatExcel" class="custom-control-label font-weight-normal">
                                    <i class="fas fa-file-excel text-success mr-1"></i> Excel
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer p-2 d-flex justify-content-end bg-light">
                    <button type="button" class="btn btn-secondary btn-sm px-3 mr-2" data-dismiss="modal">Cancel</button>
                    <button type="submit" id="btnSendReportEmailSubmit" class="btn btn-info btn-sm px-4 text-white font-weight-bold">
                        <i class="fas fa-paper-plane mr-1"></i> Send
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
