@model EmployeeAccessSystem.Models.Category

@{
    Layout = null;
}

@await Component.InvokeAsync("DeleteConfirmation", new
{
    formId = "deleteCategoryForm",
    actionName = "Delete",
    controllerName = "Category",
    hiddenInputName = "categoryId",
    hiddenInputValue = Model.CategoryId,
    message = "Do you want to delete this record?",
    itemName = Model.Name
})