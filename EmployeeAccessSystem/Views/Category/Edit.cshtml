@model EmployeeAccessSystem.Models.Category

@{
    Layout = null;
}

<form asp-action="Edit" asp-controller="Category" method="post" id="editCategoryForm">

    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="CategoryId" />

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    <div class="form-group">

        <label asp-for="Name" class="font-weight-bold">
            Name
        </label>

        <input asp-for="Name"
               class="form-control"
               placeholder="Enter name"
               maxlength="100" />

        <span asp-validation-for="Name"
              class="text-danger small">
        </span>

    </div>

    <div class="form-group mb-4">

        <div class="custom-control custom-switch">

            <input asp-for="IsActive"
                   class="custom-control-input"
                   id="EditIsActive" />

            <label class="custom-control-label font-weight-bold"
                   for="EditIsActive"
                   id="editStatusLabel">
                Active
            </label>

        </div>

        <span asp-validation-for="IsActive"
              class="text-danger small">
        </span>

    </div>

    <div class="modal-footer px-0 pb-0">

        <button type="button"
                class="btn btn-secondary btn-sm"
                data-dismiss="modal">
            Back
        </button>

        <button type="submit"
                class="btn btn-primary btn-sm">
            Update
        </button>

    </div>

</form>

<partial name="_ValidationScriptsPartial" />

<script src="~/js/category/edit.js"></script>