@{
    Layout = null;

    int selectedCategoryId = ViewBag.SelectedCategoryId;
    string existingJson = ViewBag.ExistingJson;
}

<div class="modal-header bg-white border-bottom">
    <h5 class="modal-title font-weight-bold">
        Form Configuration
    </h5>
</div>

<div class="modal-body">

    @Html.AntiForgeryToken()

    <div class="card card-outline card-primary mb-0 shadow-none">

        <div class="card-header bg-white border-bottom-0 py-1 px-2">

            <div class="card-body p-2">

                <div class="row align-items-end">

                    <div class="col-md-11">

                        <label class="font-weight-bold mb-1">
                            Category
                        </label>

                        <select id="CategoryId"
                                class="form-control form-control-sm"
                                asp-items="ViewBag.CategoryList">

                            <option value="">
                                Select Category
                            </option>

                        </select>

                    </div>

                    <div class="col-md-1 text-right">

                        <button type="button"
                                id="btnAddRoot"
                                class="btn btn-outline-primary btn-sm px-2 py-0"
                                title="Add Structure"
                                style="display:none;">

                            <i class="fas fa-plus"></i>

                        </button>

                    </div>

                </div>

            </div>

        </div>

        <div id="nodeContainer"
             class="p-3">
        </div>

    </div>

</div>

<div class="modal-footer">

    <button type="button"
            id="btnFooterClose"
            class="btn btn-secondary btn-sm">

        Close

    </button>

    <button type="button"
            id="btnSave"
            class="btn btn-primary btn-sm">

        Save

    </button>

</div>

<div class="modal fade"
     id="confirmCloseModal"
     tabindex="-1"
     role="dialog"
     data-backdrop="static"
     data-keyboard="false">

    <div class="modal-dialog modal-sm modal-dialog-centered">

        <div class="modal-content border-0 shadow">

            <div class="modal-body text-center py-4">

                <div class="mb-3 text-center">

                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-warning text-white"
                          style="width:70px;height:70px;font-size:42px;font-weight:bold;line-height:70px;">

                        !

                    </span>

                </div>

                <h4 class="font-weight-bold mb-3">
                    Are you sure?
                </h4>

                <p class="mb-0">
                    Do you want to close this form?
                </p>

            </div>

            <div class="modal-footer justify-content-center bg-light">

                <button type="button"
                        id="btnContinueEditing"
                        class="btn btn-secondary btn-sm px-4">

                    No

                </button>

                <button type="button"
                        id="btnConfirmClose"
                        class="btn btn-danger btn-sm px-4">

                    Yes

                </button>

            </div>

        </div>

    </div>

</div>

<script>
    var selectedCategoryId = @selectedCategoryId;

    var existingData =
        @Html.Raw(string.IsNullOrWhiteSpace(existingJson) ? "[]" : existingJson);
</script>

<script src="~/js/formconfiguration/add.js" asp-append-version="true"></script>