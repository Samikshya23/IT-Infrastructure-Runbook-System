@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Home";
}
<div class="home-section d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="main-title mb-3">
                    IT Infrastructure and Runbook System
                </h1>
                <p class="main-text mb-4">
                    A simple and secure system to manage employees,
                    categories, subcategories, and access permissions.
                </p>
                @* <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a asp-controller="Account"
                       asp-action="Login"
                       class="btn btn-dark btn-lg px-4">
                        Login
                    </a>
                    <a asp-controller="Account"
                       asp-action="Register"
                       class="btn btn-outline-dark btn-lg px-4">
                        Register
                    </a>
                </div> *@
            </div>
        </div>
    </div>
</div>
@section Styles {
    <style>
        .home-section {
            min-height: calc(100vh - 70px);
            background-image: url('/images/dashboard.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }
        .main-title {
            font-size: 60px;
            font-weight: 700;
        }
        .main-text {
            font-size: 22px;
            color: #555;
        }
        .btn-lg {
            border-radius: 10px;
            min-width: 140px;
        }
    </style>
}