@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid pt-3">
    <div class="row">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card card-outline card-primary shadow-sm" style="border-radius: 12px;">
                <div class="card-body p-4">
                    <h2 class="text-primary font-weight-bold mb-3">
                        <i class="fas fa-hand-holding-heart mr-2"></i>Hello, @User.Identity?.Name!
                    </h2>
                    <p class="lead text-muted">Welcome to the IT Infrastructure Runbook System.</p>
                    <hr class="my-4" />
                    <p class="text-secondary">
                        Please use the sidebar menu on the left to navigate and manage the modules assigned to you.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
