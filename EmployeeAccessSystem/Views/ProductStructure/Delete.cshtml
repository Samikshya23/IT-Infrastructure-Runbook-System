@model EmployeeAccessSystem.Models.ProductConfiguration

@{
    Layout = null;
}

<form asp-action="DeleteConfirmed"
      asp-controller="ProductStructure"
      method="post"
      id="deleteProductStructureForm">

    @Html.AntiForgeryToken()

    <input type="hidden" name="nodeId" value="@Model.NodeId" />
    <input type="hidden" name="productId" value="@Model.ProductId" />

    <div class="text-center py-3">
        <h4 class="font-weight-bold mb-3">Are you sure?</h4>

        <p class="mb-4">
            You want to delete this Product Structure item
            "<strong>@Model.NodeName</strong>"
        </p>

        <button type="button" class="btn btn-secondary mr-2" data-dismiss="modal">
            Cancel
        </button>

        <button type="submit" class="btn btn-danger">
            Confirm
        </button>
    </div>
</form>