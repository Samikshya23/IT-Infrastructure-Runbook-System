@using System
@using System.Collections.Generic
@using System.Text.Json
@using EmployeeAccessSystem.Models
@model IEnumerable<EmployeeAccessSystem.Models.Report>

@{
    ViewData["Title"] = "Reports";

    List<Report> reportData = new List<Report>();

    if (Model != null)
    {
        foreach (Report item in Model)
        {
            reportData.Add(item);
        }
    }

    IEnumerable<ReportProduct> products =
        ViewBag.Products as IEnumerable<ReportProduct>;

    int? selectedProductId = ViewBag.SelectedProductId as int?;
    DateTime? fromDate = ViewBag.FromDate as DateTime?;
    DateTime? toDate = ViewBag.ToDate as DateTime?;
    string headingJson = ViewBag.Headings as string;

    List<string> headings = BuildHeadings(headingJson);
    List<DateTime> dates = BuildDates(fromDate, toDate);
    List<DynamicReportRow> rows = BuildRows(reportData, headings.Count);

    string selectedRangeText = "";

    if (fromDate.HasValue && toDate.HasValue)
    {
        selectedRangeText =
            fromDate.Value.ToString("dd MMM yyyy") +
            " - " +
            toDate.Value.ToString("dd MMM yyyy");
    }
}

<div class="card shadow-sm mb-0 h-100">
    <div class="card-header bg-white py-2">
        <h3 class="mb-0">Reports</h3>
    </div>

    <div class="card-body p-2">
        <div class="card card-primary card-outline mb-3">
            <div class="card-body">
                <form asp-controller="Report"
                      asp-action="Index"
                      method="get"
                      id="reportForm">

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group mb-2">
                                <label for="productId">Product</label>

                                <select id="productId"
                                        name="productId"
                                        class="form-control select2bs4">
                                    <option value="">Select Product</option>

                                    @if (products != null)
                                    {
                                        foreach (ReportProduct product in products)
                                        {
                                            if (selectedProductId.HasValue &&
                                            selectedProductId.Value == product.ProductId)
                                            {
                                                <option value="@product.ProductId" selected="selected">
                                                    @product.ProductName
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@product.ProductId">
                                                    @product.ProductName
                                                </option>
                                            }
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-2">
                                <label for="dateRange">Date Range</label>

                                <div class="input-group">
                                    <input type="text"
                                           id="dateRange"
                                           class="form-control"
                                           readonly
                                           placeholder="Pick date range" />

                                    <div class="input-group-append">
                                        <span class="input-group-text"
                                              id="dateRangeIcon"
                                              style="cursor:pointer;">
                                            <i class="far fa-calendar-alt"></i>
                                        </span>
                                    </div>
                                </div>

                                <input type="hidden"
                                       id="fromDate"
                                       name="fromDate"
                                       value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-dd") : "")" />

                                <input type="hidden"
                                       id="toDate"
                                       name="toDate"
                                       value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-dd") : "")" />
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label>&nbsp;</label>

                                <button type="submit" class="btn btn-primary btn-block">
                                    <i class="fas fa-chart-bar mr-1"></i> Generate
                                </button>
                            </div>
                        </div>
                    </div>

                </form>
            </div>
        </div>

        <div id="reportMessageArea"></div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mb-3">
                @TempData["Error"]
            </div>
        }

        @if (selectedProductId.HasValue &&
                fromDate.HasValue &&
                toDate.HasValue &&
                rows.Count == 0)
        {
            <div class="alert alert-warning mb-0">
                No report data found for the selected criteria.
            </div>
        }

        @if (selectedProductId.HasValue &&
                fromDate.HasValue &&
                toDate.HasValue &&
                rows.Count > 0)
        {
            <div class="card card-primary card-outline mb-0">
                <div class="card-body p-2">

                    <div class="d-flex justify-content-between align-items-center mb-2 px-1">
                        <div>
                            <span class="text-dark font-weight-medium">
                                @selectedRangeText
                            </span>
                        </div>

                        <div class="btn-group">
    <button type="button"
            class="btn btn-danger dropdown-toggle"
            data-toggle="dropdown">
        <i class="fas fa-download mr-1"></i> Download
    </button>

    <div class="dropdown-menu dropdown-menu-right">

        <!-- PDF download -->
        <a class="dropdown-item report-download-link"
           href="@Url.Action("DownloadPdf", "Report", new {
               productId = selectedProductId,
               fromDate = fromDate.HasValue ? fromDate.Value.ToString("yyyy-MM-dd") : "",
               toDate = toDate.HasValue ? toDate.Value.ToString("yyyy-MM-dd") : ""
           })"
           data-file-type="pdf">

            <i class="fas fa-file-pdf text-danger mr-2"></i>
            PDF

        </a>

        <!-- Excel download -->
        <a class="dropdown-item report-download-link"
           href="@Url.Action("DownloadExcel", "Report", new {
               productId = selectedProductId,
               fromDate = fromDate.HasValue ? fromDate.Value.ToString("yyyy-MM-dd") : "",
               toDate = toDate.HasValue ? toDate.Value.ToString("yyyy-MM-dd") : ""
           })"
           data-file-type="excel">

            <i class="fas fa-file-excel text-success mr-2"></i>
            Excel

        </a>

    </div>
</div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2 report-pagination-bar">
                        <div class="form-inline">
                            <label class="mr-2 mb-0 font-weight-bold">Show</label>

                            <select id="reportPageSize"
                                    class="form-control form-control-sm mr-2"
                                    style="width:90px;">
                                <option value="10" selected>10</option>
                                <option value="15">15</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                            </select>

                            <span>entries</span>
                        </div>

                        <div class="report-pagination-info text-muted small">
                            Showing
                            <span id="reportStartEntry">0</span>
                            to
                            <span id="reportEndEntry">0</span>
                            of
                            <span id="reportTotalEntry">0</span>
                            entries
                        </div>
                    </div>

                    <div class="table-responsive p-0"
                         style="max-height:70vh; overflow:auto; border:1px solid #bfc5cc;">

                        <table class="table table-sm mb-0 text-center bg-white"
                               id="dynamicReportTable"
                               style="border-collapse:collapse; width:100%; border:1px solid #cfd4da;">

                            <thead>
                                <tr>
                                    @{
                                        int leftPosition = 0;
                                    }

                                    @for (int h = 0; h < headings.Count; h++)
                                    {
                                        int width = h == 0 ? 180 : 170;

                                        <th rowspan="2"
                                            class="align-middle bg-light"
                                            style="position:sticky; top:0; left:@(leftPosition)px; z-index:6; min-width:@(width)px; border:1px solid #d6d9dd;">
                                            @headings[h]
                                        </th>

                                        leftPosition = leftPosition + width;
                                    }

                                    @for (int d = 0; d < dates.Count; d++)
                                    {
                                        <th class="text-center bg-light"
                                            style="position:sticky; top:0; z-index:5; min-width:55px; border:1px solid #d6d9dd;">
                                            <div class="font-weight-bold">
                                                @dates[d].ToString("dd")
                                            </div>
                                        </th>
                                    }
                                </tr>

                                <tr>
                                    @for (int d = 0; d < dates.Count; d++)
                                    {
                                        <th class="text-center bg-light"
                                            style=" position:sticky;  top:39px;
                z-index:5;
                min-width:55px;
                border-left:1px solid #d6d9dd;
                border-right:1px solid #d6d9dd;
                border-top:1px solid #d6d9dd;
                border-bottom:2px solid #adb5bd;
                box-shadow: inset 0 -1px 0 #adb5bd;
            ">
                                            
                                            <small class="font-weight-bold">
                                                @dates[d].ToString("ddd")
                                            </small>
                                        </th>
                                    }
                                </tr>
                            </thead>

                            <tbody>
                                @for (int r = 0; r < rows.Count; r++)
                                {
                                    bool groupStart = ShouldShowCell(rows, r, 0);

                                    <tr class="report-entry-row"
                                        data-group-start="@(groupStart ? "true" : "false")">
                                        @{
                                            int bodyLeftPosition = 0;
                                        }

                                        @for (int c = 0; c < headings.Count; c++)
                                        {
                                            int width = c == 0 ? 180 : 170;
                                            bool showCell = ShouldShowCell(rows, r, c);
                                            int rowSpan = GetRowSpan(rows, r, c);

                                            if (showCell)
                                            {
                                                <td rowspan="@rowSpan"
                                                    class="align-middle text-left bg-white"
                                                    style="position:sticky; left:@(bodyLeftPosition)px; z-index:4; min-width:@(width)px; border:1px solid #d6d9dd;">
                                                    @rows[r].LeftValues[c]
                                                </td>
                                            }

                                            bodyLeftPosition = bodyLeftPosition + width;
                                        }

                                        @for (int d = 0; d < dates.Count; d++)
                                        {
                                            string key = dates[d].ToString("yyyy-MM-dd");
                                            string value = "";

                                            if (rows[r].DateValues.ContainsKey(key))
                                            {
                                                value = rows[r].DateValues[key];
                                            }

                                            <td class="text-center align-middle"
                                                style="
                    min-width:55px;
                    border-left:1px solid #d6d9dd;
                    border-right:1px solid #d6d9dd;
                    border-bottom:1px solid #d6d9dd;
                    border-top:none;
                ">
                                                @if (string.IsNullOrWhiteSpace(value))
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                                else if (value == "CHECK_ICON")
                                                {
                                                    <i class="fas fa-check text-success"></i>
                                                }
                                                else if (value == "CROSS_ICON")
                                                {
                                                    <i class="fas fa-times text-danger"></i>
                                                }
                                                else if (value == "Up")
                                                {
                                                    <span class="text-success font-weight-bold">Up</span>
                                                }
                                                else if (value == "Down")
                                                {
                                                    <span class="text-danger font-weight-bold">Down</span>
                                                }
                                                else
                                                {
                                                    <span>@value</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-2 report-pagination-footer">
                        <div class="text-muted small">
                            Showing
                            <span id="reportStartEntryBottom">0</span>
                            to
                            <span id="reportEndEntryBottom">0</span>
                            of
                            <span id="reportTotalEntryBottom">0</span>
                            entries
                        </div>

                        <ul class="pagination pagination-sm mb-0"
                            id="reportPagination">
                        </ul>
                    </div>

                </div>
            </div>
        }
    </div>
</div>

@functions {
    public class DynamicReportRow
    {
        public List<string> LeftValues { get; set; }

        public Dictionary<string, string> DateValues { get; set; }

        public DynamicReportRow()
        {
            LeftValues = new List<string>();
            DateValues = new Dictionary<string, string>();
        }
    }

    public List<DateTime> BuildDates(DateTime? fromDate, DateTime? toDate)
    {
        List<DateTime> dates = new List<DateTime>();

        if (fromDate.HasValue && toDate.HasValue)
        {
            DateTime currentDate = fromDate.Value.Date;

            while (currentDate <= toDate.Value.Date)
            {
                dates.Add(currentDate);
                currentDate = currentDate.AddDays(1);
            }
        }

        return dates;
    }

    public List<string> BuildHeadings(string json)
    {
        List<string> headings = new List<string>();

        if (string.IsNullOrWhiteSpace(json))
        {
            return headings;
        }

        try
        {
            JsonDocument document = JsonDocument.Parse(json);
            JsonElement root = document.RootElement;

            if (root.TryGetProperty("structure", out JsonElement structureElement))
            {
                AddLabels(structureElement, headings);
            }
            else if (root.TryGetProperty("Structure", out JsonElement capitalStructureElement))
            {
                AddLabels(capitalStructureElement, headings);
            }
            else
            {
                AddLabels(root, headings);
            }
        }
        catch
        {
            headings.Clear();
        }

        return headings;
    }

    public void AddLabels(JsonElement element, List<string> headings)
    {
        if (element.ValueKind == JsonValueKind.Array)
        {
            foreach (JsonElement child in element.EnumerateArray())
            {
                AddLabels(child, headings);
            }

            return;
        }

        if (element.ValueKind != JsonValueKind.Object)
        {
            return;
        }

        string label = "";

        if (element.TryGetProperty("label", out JsonElement labelElement))
        {
            label = labelElement.GetString();
        }
        else if (element.TryGetProperty("Label", out JsonElement capitalLabelElement))
        {
            label = capitalLabelElement.GetString();
        }

        if (!string.IsNullOrWhiteSpace(label))
        {
            bool exists = false;

            for (int i = 0; i < headings.Count; i++)
            {
                if (headings[i] == label.Trim())
                {
                    exists = true;
                    break;
                }
            }

            if (!exists)
            {
                headings.Add(label.Trim());
            }
        }

        if (element.TryGetProperty("children", out JsonElement childrenElement))
        {
            AddLabels(childrenElement, headings);
        }
        else if (element.TryGetProperty("Children", out JsonElement capitalChildrenElement))
        {
            AddLabels(capitalChildrenElement, headings);
        }
    }

    public List<DynamicReportRow> BuildRows(List<Report> reportData, int headingCount)
    {
        List<DynamicReportRow> rows = new List<DynamicReportRow>();

        if (headingCount == 0)
        {
            return rows;
        }

        for (int i = 0; i < reportData.Count; i++)
        {
            List<string> leftValues = BuildLeftValues(reportData[i], headingCount);
            string rowKey = BuildRowKey(leftValues);

            DynamicReportRow row = null;

            for (int r = 0; r < rows.Count; r++)
            {
                string existingKey = BuildRowKey(rows[r].LeftValues);

                if (existingKey == rowKey)
                {
                    row = rows[r];
                    break;
                }
            }

            if (row == null)
            {
                row = new DynamicReportRow();

                for (int v = 0; v < leftValues.Count; v++)
                {
                    row.LeftValues.Add(leftValues[v]);
                }

                rows.Add(row);
            }

            string dateKey = reportData[i].EntryDate.ToString("yyyy-MM-dd");

            string displayValue =
                FormatResultValue(
                    reportData[i].ValueType,
                    reportData[i].ValueTypeId,
                    reportData[i].ResultValue);

            if (!row.DateValues.ContainsKey(dateKey))
            {
                row.DateValues.Add(dateKey, displayValue);
            }
            else
            {
                row.DateValues[dateKey] = displayValue;
            }
        }

        return rows;
    }

    public List<string> BuildLeftValues(Report report, int headingCount)
    {
        List<string> values = new List<string>();

        if (report != null &&
            !string.IsNullOrWhiteSpace(report.ParentPath))
        {
            string path = report.ParentPath;
            string[] parts;

            if (path.Contains(">"))
            {
                parts = path.Split('>');
            }
            else
            {
                parts = path.Split('/');
            }

            for (int i = 0; i < parts.Length; i++)
            {
                if (!string.IsNullOrWhiteSpace(parts[i]))
                {
                    values.Add(parts[i].Trim());
                }
            }
        }

        if (report != null &&
            !string.IsNullOrWhiteSpace(report.DisplayName))
        {
            values.Add(report.DisplayName.Trim());
        }

        while (values.Count < headingCount)
        {
            values.Add("");
        }

        while (values.Count > headingCount)
        {
            values.RemoveAt(values.Count - 1);
        }

        return values;
    }

    public string BuildRowKey(List<string> values)
    {
        string key = "";

        for (int i = 0; i < values.Count; i++)
        {
            key = key + values[i] + "|";
        }

        return key;
    }

    public string FormatResultValue(
        string valueType,
        int valueTypeId,
        string resultValue)
    {
        if (string.IsNullOrWhiteSpace(resultValue))
        {
            return "";
        }

        string value = resultValue.Trim();

        if (valueTypeId == 3)
        {
            if (value.EndsWith("%"))
            {
                return value;
            }

            return value + "%";
        }

        if (valueTypeId == 4)
        {
            if (value == "1" ||
                value == "true" ||
                value == "True" ||
                value == "yes" ||
                value == "Yes" ||
                value == "8" ||
                value == "Tick")
            {
                return "CHECK_ICON";
            }

            return "CROSS_ICON";
        }

        if (valueTypeId == 5)
        {
            if (value == "1" ||
                value == "up" ||
                value == "Up" ||
                value == "yes" ||
                value == "Yes" ||
                value == "10")
            {
                return "Up";
            }

            return "Down";
        }

        string type = "";

        if (!string.IsNullOrWhiteSpace(valueType))
        {
            type = valueType.Trim().ToLower();
        }

        if (type == "percentage")
        {
            if (value.EndsWith("%"))
            {
                return value;
            }

            return value + "%";
        }

        if (type == "tick/untick" ||
            type == "tick/cross" ||
            type == "check/unchecked")
        {
            if (value == "8" || value == "Tick")
            {
                return "CHECK_ICON";
            }

            return "CROSS_ICON";
        }

        if (type == "up/down")
        {
            if (value == "10" || value == "Up")
            {
                return "Up";
            }

            return "Down";
        }

        return value;
    }

    public bool ShouldShowCell(
        List<DynamicReportRow> rows,
        int rowIndex,
        int columnIndex)
    {
        if (rowIndex == 0)
        {
            return true;
        }

        bool sameGroup = true;

        for (int i = 0; i <= columnIndex; i++)
        {
            if (rows[rowIndex].LeftValues[i] !=
                rows[rowIndex - 1].LeftValues[i])
            {
                sameGroup = false;
                break;
            }
        }

        if (sameGroup)
        {
            return false;
        }

        return true;
    }

    public int GetRowSpan(
        List<DynamicReportRow> rows,
        int rowIndex,
        int columnIndex)
    {
        int count = 1;

        for (int i = rowIndex + 1; i < rows.Count; i++)
        {
            bool sameGroup = true;

            for (int j = 0; j <= columnIndex; j++)
            {
                if (rows[i].LeftValues[j] !=
                    rows[rowIndex].LeftValues[j])
                {
                    sameGroup = false;
                    break;
                }
            }

            if (sameGroup)
            {
                count++;
            }
            else
            {
                break;
            }
        }

        return count;
    }
}

@section Scripts {
    <script>
        $(function () {

            if ($('#productId').hasClass('select2-hidden-accessible')) {
                $('#productId').select2('destroy');
            }

            $('#productId').select2({
                theme: 'bootstrap4',
                placeholder: 'Select Product',
                allowClear: true,
                minimumResultsForSearch: 0,
                width: '100%'
            });

            function showReportMessage(message, type) {

                var cssClass = 'alert-danger';

                if (type === 'warning') {
                    cssClass = 'alert-warning';
                }

                $('#reportMessageArea').html(
                    '<div class="alert ' + cssClass + ' mb-3">' +
                    message +
                    '</div>'
                );
            }

            function showDownloadMessage(message) {

                if (typeof toastr !== 'undefined') {

                    toastr.options = {
                        closeButton: true,
                        progressBar: true,
                        newestOnTop: true,
                        positionClass: 'toast-top-right',
                        preventDuplicates: true,
                        timeOut: '3000'
                    };

                    toastr.error(message, 'Message');

                    return;
                }

                showReportMessage(message, 'warning');
            }

            function setRangeValues(start, end) {

                $('#fromDate').val(start.format('YYYY-MM-DD'));

                $('#toDate').val(end.format('YYYY-MM-DD'));

                $('#dateRange').val(
                    start.format('DD MMM YYYY') +
                    ' - ' +
                    end.format('DD MMM YYYY')
                );
            }

            var today = moment();
            var startDate;
            var endDate;

            if ($('#fromDate').val() !== '' &&
                $('#toDate').val() !== '') {

                startDate = moment($('#fromDate').val(), 'YYYY-MM-DD');
                endDate = moment($('#toDate').val(), 'YYYY-MM-DD');

            }
            else {

                startDate = today.clone();
                endDate = today.clone();

            }

            $('#dateRange').daterangepicker({
                autoUpdateInput: false,
                opens: 'center',
                drops: 'down',
                linkedCalendars: false,
                alwaysShowCalendars: true,
                showDropdowns: true,
                autoApply: false,
                maxDate: today,
                startDate: startDate,
                endDate: endDate,
                maxSpan: {
                    days: 31
                },
                locale: {
                    format: 'DD MMM YYYY',
                    cancelLabel: 'Clear',
                    applyLabel: 'Apply'
                }
            });

            if ($('#fromDate').val() !== '' &&
                $('#toDate').val() !== '') {

                setRangeValues(startDate, endDate);
            }

            $('#dateRange').on('apply.daterangepicker', function (ev, picker) {

                setRangeValues(picker.startDate, picker.endDate);

            });

            $('#dateRange').on('cancel.daterangepicker', function () {

                $('#dateRange').val('');
                $('#fromDate').val('');
                $('#toDate').val('');

            });

            $('#dateRangeIcon').on('click', function () {

                $('#dateRange').trigger('click');

            });

            $('#reportForm').on('submit', function (e) {

                var productId = $('#productId').val();
                var fromDate = $('#fromDate').val();
                var toDate = $('#toDate').val();

                $('#reportMessageArea').html('');

                if (productId === '' || productId === null) {

                    showReportMessage('Please select product.', 'warning');

                    e.preventDefault();

                    return false;
                }

                if (fromDate === '' || toDate === '') {

                    showReportMessage('Please select date range.', 'warning');

                    e.preventDefault();

                    return false;
                }

                var from = moment(fromDate, 'YYYY-MM-DD');
                var to = moment(toDate, 'YYYY-MM-DD');

                if (to.isBefore(from)) {

                    showReportMessage(
                        'Start date cannot be greater than end date.',
                        'warning'
                    );

                    e.preventDefault();

                    return false;
                }

                var dayDifference = to.diff(from, 'days');

                if (dayDifference > 31) {

                    showReportMessage(
                        'Maximum report range is 31 days only.',
                        'warning'
                    );

                    e.preventDefault();

                    return false;
                }
            });

            function downloadReportFile(url, fileType) {

                $.ajax({

                    url: url,
                    type: 'GET',

                    xhrFields: {
                        responseType: 'blob'
                    },

                    success: function (data, status, xhr) {

                        var fileName = 'Report';

                        if (fileType === 'pdf') {
                            fileName = 'Report.pdf';
                        }

                        if (fileType === 'excel') {
                            fileName = 'Report.xlsx';
                        }

                        var disposition = xhr.getResponseHeader('Content-Disposition');

                        if (disposition != null && disposition !== '') {

                            var fileNameMatch = disposition.match(/filename="?([^"]+)"?/);

                            if (fileNameMatch != null && fileNameMatch.length > 1) {
                                fileName = fileNameMatch[1];
                            }
                        }

                        var blobUrl = window.URL.createObjectURL(data);

                        var link = document.createElement('a');

                        link.href = blobUrl;
                        link.download = fileName;

                        document.body.appendChild(link);

                        link.click();

                        document.body.removeChild(link);

                        window.URL.revokeObjectURL(blobUrl);
                    },

                    error: function (xhr) {

                        if (xhr.status === 401) {

                            showDownloadMessage('Please login first.');

                            return;
                        }

                        if (xhr.status === 403) {

                            showDownloadMessage('Access denied. You do not have permission.');

                            return;
                        }

                        showDownloadMessage('Unable to download report.');
                    }

                });
            }

            $('.report-download-link')
                .off('click')
                .on('click', function (e) {

                    e.preventDefault();

                    var url = $(this).attr('href');

                    var fileType = $(this).attr('data-file-type');

                    downloadReportFile(url, fileType);

                });

            function buildPagination() {

                var pageSize = parseInt($('#reportPageSize').val());

                function getReportGroups() {

                    var rows = $('#dynamicReportTable tbody tr');
                    var groups = [];
                    var currentGroup = [];

                    rows.each(function () {

                        var row = $(this);
                        var isGroupStart = row.attr('data-group-start') === 'true';

                        if (isGroupStart) {

                            if (currentGroup.length > 0) {
                                groups.push(currentGroup);
                            }

                            currentGroup = [];
                            currentGroup.push(row);

                        }
                        else {

                            currentGroup.push(row);

                        }
                    });

                    if (currentGroup.length > 0) {
                        groups.push(currentGroup);
                    }

                    return groups;
                }

                function renderPage(pageNumber) {

                    var groups = getReportGroups();
                    var totalEntries = groups.length;
                    var totalPages = Math.ceil(totalEntries / pageSize);

                    if (totalPages === 0) {
                        totalPages = 1;
                    }

                    if (pageNumber < 1) {
                        pageNumber = 1;
                    }

                    if (pageNumber > totalPages) {
                        pageNumber = totalPages;
                    }

                    $('#dynamicReportTable tbody tr').hide();

                    var startIndex = (pageNumber - 1) * pageSize;
                    var endIndex = startIndex + pageSize;

                    if (endIndex > totalEntries) {
                        endIndex = totalEntries;
                    }

                    for (var i = startIndex; i < endIndex; i++) {

                        for (var j = 0; j < groups[i].length; j++) {

                            groups[i][j].show();

                        }
                    }

                    var startEntry = totalEntries === 0 ? 0 : startIndex + 1;
                    var endEntry = endIndex;

                    $('#reportStartEntry').text(startEntry);
                    $('#reportEndEntry').text(endEntry);
                    $('#reportTotalEntry').text(totalEntries);

                    $('#reportStartEntryBottom').text(startEntry);
                    $('#reportEndEntryBottom').text(endEntry);
                    $('#reportTotalEntryBottom').text(totalEntries);

                    buildPaginationButtons(pageNumber, totalPages);
                }

                function buildPaginationButtons(currentPage, totalPages) {

                    var pagination = $('#reportPagination');

                    pagination.empty();

                    var prevDisabled = currentPage === 1 ? 'disabled' : '';

                    pagination.append(
                        '<li class="page-item ' + prevDisabled + '">' +
                        '<a class="page-link report-page-link" href="#" data-page="' +
                        (currentPage - 1) +
                        '">Previous</a></li>'
                    );

                    for (var i = 1; i <= totalPages; i++) {

                        var activeClass = currentPage === i ? 'active' : '';

                        pagination.append(
                            '<li class="page-item ' + activeClass + '">' +
                            '<a class="page-link report-page-link" href="#" data-page="' +
                            i +
                            '">' +
                            i +
                            '</a></li>'
                        );
                    }

                    var nextDisabled = currentPage === totalPages ? 'disabled' : '';

                    pagination.append(
                        '<li class="page-item ' + nextDisabled + '">' +
                        '<a class="page-link report-page-link" href="#" data-page="' +
                        (currentPage + 1) +
                        '">Next</a></li>'
                    );
                }

                $('#reportPagination')
                    .off('click', '.report-page-link')
                    .on('click', '.report-page-link', function (e) {

                        e.preventDefault();

                        var page = parseInt($(this).attr('data-page'));

                        if (!isNaN(page)) {
                            renderPage(page);
                        }

                    });

                $('#reportPageSize')
                    .off('change')
                    .on('change', function () {

                        pageSize = parseInt($(this).val());

                        renderPage(1);

                    });

                renderPage(1);
            }

            if ($('#dynamicReportTable').length > 0) {
                buildPagination();
            }

        });
    </script>
}