<div class="modal fade" id="productEntryModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
        <div class="modal-content rounded-0">

            <form asp-action="Save" asp-controller="ProductEntry" method="post" id="productEntryForm">
                @Html.AntiForgeryToken()

                <input type="hidden" name="EntryGroupId" id="EntryGroupId" />

                <div class="modal-header py-2">
                    <h5 class="modal-title font-weight-bold">Entry</h5>
                </div>

                <div class="modal-body py-2" style="max-height:70vh; overflow-y:auto;">

                    <div class="card card-primary card-outline shadow-none rounded-0 mb-0">
                        <div class="card-body p-2">

                            <div class="form-group mb-2">
                                <label class="font-weight-bold mb-1">Select</label>

                                <select id="ProductId"
                                        name="ProductId"
                                        class="form-control form-control-sm"
                                        asp-items="ViewBag.Products"
                                        onchange="loadTodayEntryValues()">
                                </select>
                            </div>

                            <div id="dynamicEntryArea"></div>

                        </div>
                    </div>

                </div>

                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" onclick="confirmCloseProductEntry()">Close</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </form>

        </div>
    </div>
</div>

<div class="modal fade" id="closeConfirmModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
        <div class="modal-content rounded-0">
            <div class="modal-body text-center">
                <div class="mb-3">
                    <span class="bg-warning rounded-circle d-inline-flex align-items-center justify-content-center"
                          style="width:60px;height:60px;">
                        <i class="fas fa-exclamation text-white fa-2x"></i>
                    </span>
                </div>

                <h5 class="font-weight-bold">Are you sure?</h5>

                <p class="text-muted mb-3">
                    Do you want to close this form?
                </p>

                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">No</button>
                <button type="button" class="btn btn-danger btn-sm" onclick="closeProductEntryModalNow()">Yes</button>
            </div>
        </div>
    </div>
</div>

<div aria-live="polite" aria-atomic="true" style="position:fixed; top:20px; right:20px; z-index:9999;">
    <div id="productEntryToast" class="toast bg-danger text-white" data-delay="3000" role="alert">
        <div class="toast-body" id="productEntryToastMessage"></div>
    </div>
</div>

<script>
    var currentSetupItems = [];

    function getAntiForgeryToken() {
        return $('input[name="__RequestVerificationToken"]').val();
    }

    function showEntryToast(message) {
        $('#productEntryToastMessage').text(message);

        if ($.fn.toast) {
            $('#productEntryToast').toast('show');
        }
        else {
            $('#productEntryToast').show();

            setTimeout(function () {
                $('#productEntryToast').hide();
            }, 3000);
        }
    }

    function cleanProductEntryModal() {

        $('#productEntryModal').modal('hide');
        $('#closeConfirmModal').modal('hide');

        $('#EntryGroupId').val('');
        $('#dynamicEntryArea').html('');

        $('.modal-backdrop').remove();
        $('body').removeClass('modal-open');
        $('body').css('padding-right', '');
    }

    function showEntryAccessError(message) {
        if (message == null || message === '') {
            message = 'Access denied. You do not have permission.';
        }

        showEntryToast(message);
    }

    function getAjaxErrorMessage(xhr) {
        if (xhr != null && xhr.responseJSON != null && xhr.responseJSON.message != null) {
            return xhr.responseJSON.message;
        }

        return 'Access denied. You do not have permission.';
    }

    function openAddEntryModal() {

        $('#EntryGroupId').val('');
        $('#dynamicEntryArea').html('');

        $.ajax({
            url: '/ProductEntry/Add',
            type: 'GET',
            headers: {
                'RequestVerificationToken': getAntiForgeryToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function () {

                $('#productEntryModal').modal('show');

                loadTodayEntryValues();
            },
            error: function (xhr) {

                if (xhr.status === 401) {
                    showEntryToast('Please login first.');
                    cleanProductEntryModal();
                    return;
                }

                if (xhr.status === 403) {
                    showEntryToast('Access denied. You do not have permission.');
                    cleanProductEntryModal();
                    return;
                }

                showEntryToast('An error occurred while loading the form.');
                cleanProductEntryModal();
            }
        });
    }

    function loadTodayEntryValues() {
        var productId = $('#ProductId').val();

        if (productId === '' || productId == null) {
            $('#dynamicEntryArea').html('');
            return;
        }

        $.ajax({
            url: '/ProductEntry/GetTodayByProduct',
            type: 'GET',
            headers: {
                'RequestVerificationToken': getAntiForgeryToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: {
                productId: productId
            },
            success: function (entries) {
                if (entries != null && entries.success === false) {
                    showEntryAccessError(entries.message);
                    return;
                }

                loadProductEntryForm(entries);
            },
            error: function (xhr) {
                if (xhr.status === 401 || xhr.status === 403) {
                    showEntryAccessError(getAjaxErrorMessage(xhr));
                    return;
                }

                loadProductEntryForm(null);
            }
        });
    }

    function openEditEntryModal(entryGroupId) {

        $('#EntryGroupId').val(entryGroupId);
        $('#dynamicEntryArea').html('');

        $.ajax({
            url: '/ProductEntry/Edit',
            type: 'GET',
            headers: {
                'RequestVerificationToken': getAntiForgeryToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: {
                entryGroupId: entryGroupId
            },
            success: function () {

                loadEditEntryDetails(entryGroupId);
            },
            error: function (xhr) {

                if (xhr.status === 401) {
                    showEntryToast('Please login first.');
                    cleanProductEntryModal();
                    return;
                }

                if (xhr.status === 403) {
                    showEntryToast('Access denied. You do not have permission.');
                    cleanProductEntryModal();
                    return;
                }

                showEntryToast('Failed to load entry.');
                cleanProductEntryModal();
            }
        });
    }

    function loadEditEntryDetails(entryGroupId) {

        $.ajax({
            url: '/ProductEntry/GetDetails',
            type: 'GET',
            headers: {
                'RequestVerificationToken': getAntiForgeryToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: {
                entryGroupId: entryGroupId
            },
            success: function (entries) {
                if (entries != null && entries.success === false) {
                    showEntryToast(entries.message);
                    cleanProductEntryModal();
                    return;
                }

                if (entries == null || entries.length === 0) {
                    showEntryToast('Entry not found.');
                    cleanProductEntryModal();
                    return;
                }

                var firstEntry = entries[0];
                var productId = firstEntry.productId;

                if (productId == null) {
                    productId = firstEntry.ProductId;
                }

                $('#ProductId').val(productId);
                $('#productEntryModal').modal('show');

                loadProductEntryForm(entries);
            },
            error: function (xhr) {
                if (xhr.status === 401 || xhr.status === 403) {
                    showEntryToast('Access denied. You do not have permission.');
                    cleanProductEntryModal();
                    return;
                }

                showEntryToast('Failed to load entry.');
                cleanProductEntryModal();
            }
        });
    }

    function loadProductEntryForm(existingEntries) {
        var productId = $('#ProductId').val();

        if (productId === '' || productId == null) {
            $('#dynamicEntryArea').html('');
            return;
        }

        $.ajax({
            url: '/ProductEntry/GetSetup',
            type: 'GET',
            headers: {
                'RequestVerificationToken': getAntiForgeryToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: {
                productId: productId
            },
            success: function (setupJson) {
                if (setupJson != null && setupJson.success === false) {
                    showEntryAccessError(setupJson.message);
                    return;
                }

                if (setupJson == null || setupJson === '') {
                    $('#dynamicEntryArea').html('<div class="alert alert-warning m-2">No setup configuration found.</div>');
                    return;
                }

                var setupObject = null;

                try {
                    if (typeof setupJson === 'string') {
                        setupObject = JSON.parse(setupJson);
                    }
                    else {
                        setupObject = setupJson;
                    }
                }
                catch (e) {
                    $('#dynamicEntryArea').html('<div class="alert alert-danger m-2">Unable to load setup configuration. Please contact administrator.</div>');
                    return;
                }

                currentSetupItems = [];

                if (Array.isArray(setupObject)) {
                    collectSetupItems(setupObject);
                }
                else if (setupObject.structure != null) {
                    collectSetupItems(setupObject.structure);
                }
                else if (setupObject.Structure != null) {
                    collectSetupItems(setupObject.Structure);
                }

                if (existingEntries == null) {
                    existingEntries = [];
                }

                renderEntryForm(existingEntries);
            },
            error: function (xhr) {
                if (xhr.status === 401 || xhr.status === 403) {
                    showEntryAccessError(getAjaxErrorMessage(xhr));
                    return;
                }

                $('#dynamicEntryArea').html('<div class="alert alert-danger m-2">Failed to load setup.</div>');
            }
        });
    }

    function collectSetupItems(nodes) {
        if (nodes == null) {
            return;
        }

        for (var i = 0; i < nodes.length; i++) {
            var parent = nodes[i];

            var parentName = getNodeValue(parent);
            var parentNodeId = getNodeId(parent);
            var parentFieldType = getNodeFieldType(parent);
            var parentFieldTypeId = getNodeFieldTypeId(parent);
            var children = getNodeChildren(parent);

            if (children == null || children.length === 0) {
                currentSetupItems.push({
                    setupNodeId: parentNodeId,
                    oldSetupNodeId: parentName,
                    parentPath: parentName,
                    displayName: parentName,
                    valueType: parentFieldType,
                    valueTypeId: parentFieldTypeId
                });
            }
            else {
                for (var j = 0; j < children.length; j++) {
                    var child = children[j];
                    var childName = getNodeValue(child);
                    var childNodeId = getNodeId(child);

                    currentSetupItems.push({
                        setupNodeId: childNodeId,
                        oldSetupNodeId: parentName + '/' + childName,
                        parentPath: parentName,
                        displayName: childName,
                        valueType: parentFieldType,
                        valueTypeId: parentFieldTypeId
                    });
                }
            }
        }
    }

    function renderEntryForm(existingEntries) {
        if (currentSetupItems.length === 0) {
            $('#dynamicEntryArea').html('');
            return;
        }

        var grouped = {};

        for (var i = 0; i < currentSetupItems.length; i++) {
            var item = currentSetupItems[i];

            if (!grouped[item.parentPath]) {
                grouped[item.parentPath] = [];
            }

            grouped[item.parentPath].push(item);
        }

        var html = '';

        html += '<div class="table-responsive">';
        html += '<table class="table table-bordered table-sm mb-0 w-100" style="table-layout:fixed;">';
        html += '<tbody>';

        var index = 0;

        for (var groupName in grouped) {
            if (grouped.hasOwnProperty(groupName)) {
                var items = grouped[groupName];

                for (var x = 0; x < items.length; x++) {
                    var item = items[x];

                    var oldValue = getExistingValue(
                        existingEntries,
                        item.setupNodeId,
                        item.displayName,
                        item.parentPath,
                        item.oldSetupNodeId,
                        item.valueTypeId
                    );

                    html += '<tr>';

                    if (x === 0) {
                        html += '<td rowspan="' + items.length + '" class="align-middle font-weight-bold text-left p-0" style="width:30%;">';
                        html += '<div class="px-2 d-flex align-items-center justify-content-start" style="height:36px;">';
                        html += escapeHtml(groupName);
                        html += '</div>';
                        html += '</td>';
                    }

                    html += '<td class="align-middle text-left p-0" style="width:40%;">';
                    html += '<div class="px-2 d-flex align-items-center justify-content-start" style="height:36px;">';
                    html += escapeHtml(item.displayName);
                    html += '</div>';

                    html += '<input type="hidden" name="Items[' + index + '].SetupNodeId" value="' + escapeAttribute(item.setupNodeId) + '" />';
                    html += '<input type="hidden" name="Items[' + index + '].ParentPath" value="' + escapeAttribute(item.parentPath) + '" />';
                    html += '<input type="hidden" name="Items[' + index + '].DisplayName" value="' + escapeAttribute(item.displayName) + '" />';
                    html += '<input type="hidden" name="Items[' + index + '].ValueType" value="' + escapeAttribute(item.valueType) + '" />';
                    html += '<input type="hidden" name="Items[' + index + '].ValueTypeId" value="' + escapeAttribute(item.valueTypeId) + '" />';

                    html += '</td>';

                    html += '<td class="align-middle text-left p-0" style="width:30%;">';
                    html += '<div class="px-2 d-flex align-items-center justify-content-start" style="height:36px;">';

                    html += createValueInput(
                        index,
                        oldValue,
                        item.valueTypeId
                    );

                    html += '</div>';
                    html += '</td>';
                    html += '</tr>';

                    index++;
                }
            }
        }

        html += '</tbody>';
        html += '</table>';
        html += '</div>';

        $('#dynamicEntryArea').html(html);
    }

    function createValueInput(index, oldValue, valueTypeId) {
        if (oldValue == null) {
            oldValue = '';
        }

        oldValue = oldValue.toString().replace('%', '');

        var typeId = parseInt(valueTypeId);

        if (typeId === 4) {
            return createTickCrossDropdown(index, oldValue);
        }

        if (typeId === 5) {
            return createUpDownDropdown(index, oldValue);
        }

        if (typeId === 3) {
            return '' +
                '<div class="input-group input-group-sm" style="width:100px;">' +
                '<input type="text" autocomplete="off" class="form-control form-control-sm percentage-input required-entry-value" name="Items[' + index + '].ResultValue" value="' + escapeAttribute(oldValue) + '" oninput="limitPercentageInput(this)" />' +
                '<div class="input-group-append">' +
                '<span class="input-group-text">%</span>' +
                '</div>' +
                '</div>';
        }

        if (typeId === 2) {
            return '' +
                '<input type="date" class="form-control form-control-sm required-entry-value" name="Items[' + index + '].ResultValue" value="' + escapeAttribute(oldValue) + '" style="width:140px;" />';
        }

        var textValue = oldValue;

        if (
            oldValue === '8' ||
            oldValue === '9' ||
            oldValue === '10' ||
            oldValue === '11' ||
            oldValue === 'Tick' ||
            oldValue === 'Cross' ||
            oldValue === 'Up' ||
            oldValue === 'Down'
        ) {
            textValue = '';
        }

        return '' +
            '<input type="text" autocomplete="off" class="form-control form-control-sm required-entry-value" name="Items[' + index + '].ResultValue" value="' + escapeAttribute(textValue) + '" style="width:120px;" />';
    }

    function createTickCrossDropdown(index, oldValue) {
        var selectedText = 'Select';
        var selectedValue = oldValue;

        if (oldValue === 'Tick') {
            selectedValue = '8';
        }

        if (oldValue === 'Cross') {
            selectedValue = '9';
        }

        if (selectedValue === '8') {
            selectedText = '<i class="fas fa-check text-success"></i>';
        }

        if (selectedValue === '9') {
            selectedText = '<i class="fas fa-times text-danger"></i>';
        }

        return '' +
            '<input type="hidden" class="required-entry-value" id="tickCross_' + index + '" name="Items[' + index + '].ResultValue" value="' + escapeAttribute(selectedValue) + '" />' +
            '<div class="dropdown" style="width:100px;">' +
            '<button type="button" class="btn btn-light border btn-sm dropdown-toggle" data-toggle="dropdown" id="tickCrossButton_' + index + '" style="width:100px;">' +
            selectedText +
            '</button>' +
            '<div class="dropdown-menu p-0 text-center" style="min-width:100px;">' +
            '<button type="button" class="dropdown-item" onclick="selectTickCross(' + index + ', \'8\')">' +
            '<i class="fas fa-check text-success"></i>' +
            '</button>' +
            '<button type="button" class="dropdown-item" onclick="selectTickCross(' + index + ', \'9\')">' +
            '<i class="fas fa-times text-danger"></i>' +
            '</button>' +
            '</div>' +
            '</div>';
    }

    function selectTickCross(index, value) {
        $('#tickCross_' + index).val(value);

        if (value === '8') {
            $('#tickCrossButton_' + index).html('<i class="fas fa-check text-success"></i>');
        }

        if (value === '9') {
            $('#tickCrossButton_' + index).html('<i class="fas fa-times text-danger"></i>');
        }
    }

    function createUpDownDropdown(index, oldValue) {
        var selectedText = 'Select';
        var selectedValue = oldValue;

        if (oldValue === 'Up') {
            selectedValue = '10';
        }

        if (oldValue === 'Down') {
            selectedValue = '11';
        }

        if (selectedValue === '10') {
            selectedText = '<span class="text-success font-weight-bold">Up</span>';
        }

        if (selectedValue === '11') {
            selectedText = '<span class="text-danger font-weight-bold">Down</span>';
        }

        return '' +
            '<input type="hidden" class="required-entry-value" id="upDown_' + index + '" name="Items[' + index + '].ResultValue" value="' + escapeAttribute(selectedValue) + '" />' +
            '<div class="dropdown" style="width:100px;">' +
            '<button type="button" class="btn btn-light border btn-sm dropdown-toggle" data-toggle="dropdown" id="upDownButton_' + index + '" style="width:100px;">' +
            selectedText +
            '</button>' +
            '<div class="dropdown-menu p-0 text-center" style="min-width:100px;">' +
            '<button type="button" class="dropdown-item" onclick="selectUpDown(' + index + ', \'10\')">' +
            '<span class="text-success font-weight-bold">Up</span>' +
            '</button>' +
            '<button type="button" class="dropdown-item" onclick="selectUpDown(' + index + ', \'11\')">' +
            '<span class="text-danger font-weight-bold">Down</span>' +
            '</button>' +
            '</div>' +
            '</div>';
    }

    function selectUpDown(index, value) {
        $('#upDown_' + index).val(value);

        if (value === '10') {
            $('#upDownButton_' + index).html('<span class="text-success font-weight-bold">Up</span>');
        }

        if (value === '11') {
            $('#upDownButton_' + index).html('<span class="text-danger font-weight-bold">Down</span>');
        }
    }

    function limitPercentageInput(input) {
        if (input == null) {
            return;
        }

        var value = input.value.replace(/[^0-9]/g, '');

        if (value === '') {
            input.value = '';
            return;
        }

        var numberValue = parseInt(value);

        if (numberValue > 100) {
            input.value = '';
            showEntryToast('Percentage value cannot be greater than 100.');
            return;
        }

        input.value = numberValue.toString();
    }

    function getExistingValue(existingEntries, setupNodeId, displayName, parentPath, oldSetupNodeId, valueTypeId) {
        if (existingEntries == null) {
            return '';
        }

        var foundValue = '';

        for (var i = 0; i < existingEntries.length; i++) {
            var entry = existingEntries[i];

            var entrySetupNodeId = entry.setupNodeId || entry.SetupNodeId;
            var entryResultValue = entry.resultValue;

            if (entryResultValue == null) {
                entryResultValue = entry.ResultValue;
            }

            if (entrySetupNodeId === setupNodeId || entrySetupNodeId === oldSetupNodeId) {
                foundValue = entryResultValue;
                break;
            }
        }

        if (foundValue === '') {
            for (var j = 0; j < existingEntries.length; j++) {
                var entry2 = existingEntries[j];

                var entryDisplayName = entry2.displayName || entry2.DisplayName;
                var entryParentPath = entry2.parentPath || entry2.ParentPath;
                var entryResultValue2 = entry2.resultValue;

                if (entryResultValue2 == null) {
                    entryResultValue2 = entry2.ResultValue;
                }

                if (entryDisplayName === displayName && entryParentPath === parentPath) {
                    foundValue = entryResultValue2;
                    break;
                }
            }
        }

        if (foundValue === '') {
            return '';
        }

        if (parseInt(valueTypeId) === 3) {
            if (isNaN(foundValue.replace('%', ''))) {
                return '';
            }
        }

        if (parseInt(valueTypeId) === 4) {
            if (foundValue !== 'Tick' && foundValue !== 'Cross' && foundValue !== '8' && foundValue !== '9') {
                return '';
            }
        }

        if (parseInt(valueTypeId) === 5) {
            if (foundValue !== 'Up' && foundValue !== 'Down' && foundValue !== '10' && foundValue !== '11') {
                return '';
            }
        }

        return foundValue;
    }

    $('#productEntryForm').off('submit').on('submit', function (e) {
        var productId = $('#ProductId').val();

        if (productId === '' || productId == null) {
            e.preventDefault();
            showEntryToast('Please select a main item.');
            return false;
        }

        var isValid = true;

        $('.required-entry-value').each(function () {
            var value = $(this).val();

            if (value == null || value.trim() === '') {
                isValid = false;
                return false;
            }
        });

        if (!isValid) {
            e.preventDefault();
            showEntryToast('Please fill all required values.');
            return false;
        }

        return true;
    });

    function confirmCloseProductEntry() {
        $('#closeConfirmModal').modal('show');
    }

    function closeProductEntryModalNow() {
        $('#closeConfirmModal').modal('hide');
        $('#productEntryModal').modal('hide');
    }

    function getNodeId(node) {
        var id = node.id;

        if (id == null) {
            id = node.Id;
        }

        if (id == null) {
            id = node.nodeId;
        }

        if (id == null) {
            id = node.NodeId;
        }

        if (id == null || id === '') {
            id = getNodeValue(node);
        }

        return id;
    }

    function getNodeValue(node) {
        var value = node.value;

        if (value == null) {
            value = node.Value;
        }

        if (value == null) {
            value = node.label;
        }

        if (value == null) {
            value = node.Label;
        }

        if (value == null) {
            value = '';
        }

        return value;
    }

    function getNodeFieldType(node) {
        var fieldType = node.fieldType;

        if (fieldType == null) {
            fieldType = node.FieldType;
        }

        if (fieldType == null) {
            fieldType = node.valueType;
        }

        if (fieldType == null) {
            fieldType = node.ValueType;
        }

        if (fieldType == null) {
            fieldType = '';
        }

        return fieldType.trim();
    }

    function getNodeFieldTypeId(node) {
        var fieldTypeId = node.fieldTypeId;

        if (fieldTypeId == null) {
            fieldTypeId = node.FieldTypeId;
        }

        if (fieldTypeId == null) {
            fieldTypeId = node.valueTypeId;
        }

        if (fieldTypeId == null) {
            fieldTypeId = node.ValueTypeId;
        }

        if (fieldTypeId == null || fieldTypeId === '') {
            return '';
        }

        return fieldTypeId;
    }

    function getNodeChildren(node) {
        var children = node.children;

        if (children == null) {
            children = node.Children;
        }

        return children;
    }

    function escapeHtml(value) {
        if (value == null) {
            return '';
        }

        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function escapeAttribute(value) {
        return escapeHtml(value);
    }
</script>