<div class="modal fade" id="categoryChecklistModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
        <div class="modal-content rounded-0">

            <form asp-action="Save" asp-controller="CategoryChecklist" method="post" id="categoryChecklistForm">
                @Html.AntiForgeryToken()

                <input type="hidden" name="EntryGroupId" id="EntryGroupId" />

                <div class="modal-header py-2">
                    <h5 class="modal-title font-weight-bold">Checklist</h5>
                </div>

                <div class="modal-body py-2" style="max-height:70vh; overflow-y:auto;">
                    <div class="card card-primary card-outline shadow-none rounded-0 mb-0">
                        <div class="card-body p-2">

                            <div class="form-group mb-2">
                                <label class="font-weight-bold mb-1">Select</label>

                                <select id="CategoryId"
                                        name="CategoryId"
                                        class="form-control form-control-sm"
                                        asp-items="ViewBag.Categories"
                                        onchange="loadTodayChecklistValues()">
                                </select>
                            </div>

                            <div id="dynamicChecklistArea"></div>

                        </div>
                    </div>
                </div>

                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" onclick="confirmCloseCategoryChecklist()">Close</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </form>

        </div>
    </div>
</div>

<div class="modal fade" id="closeConfirmModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
        <div class="modal-content rounded-0">
            <div class="modal-body text-center">
                <div class="mb-3">
                    <span class="bg-warning rounded-circle d-inline-flex align-items-center justify-content-center"
                          style="width:60px;height:60px;">
                        <i class="fas fa-exclamation text-white fa-2x"></i>
                    </span>
                </div>

                <h5 class="font-weight-bold">Are you sure?</h5>

                <p class="text-muted mb-3">
                    Do you want to close this form?
                </p>

                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">No</button>
                <button type="button" class="btn btn-danger btn-sm" onclick="closeCategoryChecklistModalNow()">Yes</button>
            </div>
        </div>
    </div>
</div>

<div aria-live="polite" aria-atomic="true" style="position:fixed; top:20px; right:20px; z-index:9999;">
    <div id="categoryChecklistToast" class="toast bg-danger text-white" data-delay="3000" role="alert">
        <div class="toast-body" id="categoryChecklistToastMessage"></div>
    </div>
</div>

<script>
    var currentSetupItems = [];

    function getAntiForgeryToken() {
        return $('input[name="__RequestVerificationToken"]').val();
    }

    function showChecklistToast(message) {
        $('#categoryChecklistToastMessage').text(message);

        if ($.fn.toast) {
            $('#categoryChecklistToast').toast('show');
        }
        else {
            $('#categoryChecklistToast').show();

            setTimeout(function () {
                $('#categoryChecklistToast').hide();
            }, 3000);
        }
    }

    function cleanCategoryChecklistModal() {
        $('#categoryChecklistModal').modal('hide');
        $('#closeConfirmModal').modal('hide');

        $('#EntryGroupId').val('');
        $('#dynamicChecklistArea').html('');

        $('.modal-backdrop').remove();
        $('body').removeClass('modal-open');
        $('body').css('padding-right', '');
    }

    function showChecklistAccessError(message) {
        if (message == null || message === '') {
            message = 'Access denied. You do not have permission.';
        }

        showChecklistToast(message);
    }

    function getAjaxErrorMessage(xhr) {
        if (xhr != null && xhr.responseJSON != null && xhr.responseJSON.message != null) {
            return xhr.responseJSON.message;
        }

        return 'Access denied. You do not have permission.';
    }

    function openAddChecklistModal() {
        $('#EntryGroupId').val('');
        $('#dynamicChecklistArea').html('');

        $.ajax({
            url: '/CategoryChecklist/Add',
            type: 'GET',
            headers: {
                'RequestVerificationToken': getAntiForgeryToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function () {
                $('#categoryChecklistModal').modal('show');
                loadTodayChecklistValues();
            },
            error: function (xhr) {
                if (xhr.status === 401) {
                    showChecklistToast('Please login first.');
                    cleanCategoryChecklistModal();
                    return;
                }

                if (xhr.status === 403) {
                    showChecklistToast('Access denied. You do not have permission.');
                    cleanCategoryChecklistModal();
                    return;
                }

                showChecklistToast('An error occurred while loading the form.');
                cleanCategoryChecklistModal();
            }
        });
    }

    function loadTodayChecklistValues() {
        var categoryId = $('#CategoryId').val();

        if (categoryId === '' || categoryId == null) {
            $('#dynamicChecklistArea').html('');
            return;
        }

        $.ajax({
            url: '/CategoryChecklist/GetTodayByCategory',
            type: 'GET',
            headers: {
                'RequestVerificationToken': getAntiForgeryToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: {
                categoryId: categoryId
            },
            success: function (entries) {
                if (entries != null && entries.success === false) {
                    showChecklistAccessError(entries.message);
                    return;
                }

                loadCategoryChecklistForm(entries);
            },
            error: function (xhr) {
                if (xhr.status === 401 || xhr.status === 403) {
                    showChecklistAccessError(getAjaxErrorMessage(xhr));
                    return;
                }

                loadCategoryChecklistForm(null);
            }
        });
    }

    function openEditChecklistModal(entryGroupId) {
        $('#EntryGroupId').val(entryGroupId);
        $('#dynamicChecklistArea').html('');

        $.ajax({
            url: '/CategoryChecklist/Edit',
            type: 'GET',
            headers: {
                'RequestVerificationToken': getAntiForgeryToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: {
                entryGroupId: entryGroupId
            },
            success: function () {
                loadEditChecklistDetails(entryGroupId);
            },
            error: function (xhr) {
                if (xhr.status === 401) {
                    showChecklistToast('Please login first.');
                    cleanCategoryChecklistModal();
                    return;
                }

                if (xhr.status === 403) {
                    showChecklistToast('Access denied. You do not have permission.');
                    cleanCategoryChecklistModal();
                    return;
                }

                showChecklistToast('Failed to load entry.');
                cleanCategoryChecklistModal();
            }
        });
    }

    function loadEditChecklistDetails(entryGroupId) {
        $.ajax({
            url: '/CategoryChecklist/GetDetails',
            type: 'GET',
            headers: {
                'RequestVerificationToken': getAntiForgeryToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: {
                entryGroupId: entryGroupId
            },
            success: function (entries) {
                if (entries != null && entries.success === false) {
                    showChecklistToast(entries.message);
                    cleanCategoryChecklistModal();
                    return;
                }

                if (entries == null || entries.length === 0) {
                    showChecklistToast('Entry not found.');
                    cleanCategoryChecklistModal();
                    return;
                }

                var firstEntry = entries[0];
                var categoryId = firstEntry.categoryId;

                if (categoryId == null) {
                    categoryId = firstEntry.CategoryId;
                }

                $('#CategoryId').val(categoryId);
                $('#categoryChecklistModal').modal('show');

                loadCategoryChecklistForm(entries);
            },
            error: function (xhr) {
                if (xhr.status === 401 || xhr.status === 403) {
                    showChecklistToast('Access denied. You do not have permission.');
                    cleanCategoryChecklistModal();
                    return;
                }

                showChecklistToast('Failed to load entry.');
                cleanCategoryChecklistModal();
            }
        });
    }

    function loadCategoryChecklistForm(existingEntries) {
        var categoryId = $('#CategoryId').val();

        if (categoryId === '' || categoryId == null) {
            $('#dynamicChecklistArea').html('');
            return;
        }

        $.ajax({
            url: '/CategoryChecklist/GetSetup',
            type: 'GET',
            headers: {
                'RequestVerificationToken': getAntiForgeryToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: {
                categoryId: categoryId
            },
            success: function (setupJson) {
                if (setupJson != null && setupJson.success === false) {
                    showChecklistAccessError(setupJson.message);
                    return;
                }

                if (setupJson == null || setupJson === '') {
                    $('#dynamicChecklistArea').html('<div class="alert alert-warning m-2">No setup configuration found.</div>');
                    return;
                }

                var setupObject = null;

                try {
                    if (typeof setupJson === 'string') {
                        setupObject = JSON.parse(setupJson);
                    }
                    else {
                        setupObject = setupJson;
                    }
                }
                catch (e) {
                    $('#dynamicChecklistArea').html('<div class="alert alert-danger m-2">Unable to load setup configuration. Please contact administrator.</div>');
                    return;
                }

                currentSetupItems = [];

                if (Array.isArray(setupObject)) {
                    collectSetupItems(setupObject, '', '', '');
                }
                else if (setupObject.structure != null) {
                    collectSetupItems(setupObject.structure, '', '', '');
                }
                else if (setupObject.Structure != null) {
                    collectSetupItems(setupObject.Structure, '', '', '');
                }

                if (existingEntries == null) {
                    existingEntries = [];
                }

                renderChecklistForm(existingEntries);
            },
            error: function (xhr) {
                if (xhr.status === 401 || xhr.status === 403) {
                    showChecklistAccessError(getAjaxErrorMessage(xhr));
                    return;
                }

                $('#dynamicChecklistArea').html('<div class="alert alert-danger m-2">Failed to load setup.</div>');
            }
        });
    }

    function collectSetupItems(nodes, parentPath, inheritedValueType, inheritedValueTypeId) {
        if (nodes == null) {
            return;
        }

        if (parentPath == null) {
            parentPath = '';
        }

        for (var i = 0; i < nodes.length; i++) {
            var node = nodes[i];

            var nodeName = getNodeValue(node);
            var nodeId = getNodeId(node);
            var children = getNodeChildren(node);

            var nodeValueType = getNodeFieldType(node);
            var nodeValueTypeId = getNodeFieldTypeId(node);

            if (nodeValueType == null || nodeValueType === '') {
                nodeValueType = inheritedValueType;
            }

            if (nodeValueTypeId == null || nodeValueTypeId === '') {
                nodeValueTypeId = inheritedValueTypeId;
            }

            var currentPath = '';

            if (parentPath === '') {
                currentPath = nodeName;
            }
            else {
                currentPath = parentPath + ' / ' + nodeName;
            }

            if (children != null && children.length > 0) {
                collectSetupItems(children, currentPath, nodeValueType, nodeValueTypeId);
            }
            else {
                currentSetupItems.push({
                    setupNodeId: nodeId,
                    oldSetupNodeId: currentPath,
                    parentPath: parentPath,
                    displayName: nodeName,
                    valueType: nodeValueType,
                    valueTypeId: nodeValueTypeId
                });
            }
        }
    }

      function renderChecklistForm(existingEntries) {

        if (currentSetupItems.length === 0) {
            $('#dynamicChecklistArea').html('');
            return;
        }

        var rows = [];

        for (var i = 0; i < currentSetupItems.length; i++) {
            var item = currentSetupItems[i];

            var pathParts = [];

            if (item.parentPath != null && item.parentPath !== '') {
                pathParts = item.parentPath.split('/');
            }

            for (var p = 0; p < pathParts.length; p++) {
                pathParts[p] = pathParts[p].trim();
            }

            pathParts.push(item.displayName);

            rows.push({
                item: item,
                values: pathParts
            });
        }

        rows.sort(function (a, b) {
            var first = a.values.join(' / ');
            var second = b.values.join(' / ');

            if (first < second) {
                return -1;
            }

            if (first > second) {
                return 1;
            }

            return 0;
        });

        function getValue(rowIndex, columnIndex) {
            if (rows[rowIndex] == null || rows[rowIndex].values == null) {
                return '';
            }

            if (columnIndex >= rows[rowIndex].values.length) {
                return '';
            }

            return rows[rowIndex].values[columnIndex];
        }

        function isSamePath(firstIndex, secondIndex, columnIndex) {
            for (var i = 0; i <= columnIndex; i++) {
                if (getValue(firstIndex, i) !== getValue(secondIndex, i)) {
                    return false;
                }
            }

            return true;
        }

        function shouldDisplayCell(rowIndex, columnIndex) {
            if (rowIndex === 0) {
                return true;
            }

            return !isSamePath(rowIndex - 1, rowIndex, columnIndex);
        }

        function getRowSpan(rowIndex, columnIndex) {
            var rowSpan = 1;

            for (var i = rowIndex + 1; i < rows.length; i++) {
                if (isSamePath(rowIndex, i, columnIndex)) {
                    rowSpan++;
                }
                else {
                    break;
                }
            }

            return rowSpan;
        }

        var maxDepth = 0;

        for (var d = 0; d < rows.length; d++) {
            if (rows[d].values.length > maxDepth) {
                maxDepth = rows[d].values.length;
            }
        }

        var html = '';

        html += '<div class="table-responsive">';
        html += '<table class="table table-bordered table-sm mb-0 w-100" style="table-layout:fixed;">';
        html += '<tbody>';

        for (var rowIndex = 0; rowIndex < rows.length; rowIndex++) {
            var item = rows[rowIndex].item;

            var oldValue = getExistingValue(
                existingEntries,
                item.setupNodeId,
                item.displayName,
                item.parentPath,
                item.oldSetupNodeId,
                item.valueTypeId
            );

            html += '<tr>';

            for (var columnIndex = 0; columnIndex < maxDepth - 1; columnIndex++) {
                if (shouldDisplayCell(rowIndex, columnIndex)) {
                    var rowSpan = getRowSpan(rowIndex, columnIndex);
                    var columnValue = getValue(rowIndex, columnIndex);

                    html += '<td rowspan="' + rowSpan + '" class="align-middle text-left p-0">';
                    html += '<div class="px-2 d-flex align-items-center justify-content-start" style="min-height:' + (rowSpan * 42) + 'px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="' + escapeAttribute(columnValue) + '">';
                    html += escapeHtml(columnValue);
                    html += '</div>';
                    html += '</td>';
                }
            }

            var finalValue = getValue(rowIndex, maxDepth - 1);

            html += '<td class="align-middle text-left p-0">';
            html += '<div class="px-2 d-flex align-items-center justify-content-start" style="min-height:42px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="' + escapeAttribute(finalValue) + '">';
            html += escapeHtml(finalValue);
            html += '</div>';

            html += '<input type="hidden" name="Items[' + rowIndex + '].SetupNodeId" value="' + escapeAttribute(item.setupNodeId) + '" />';
            html += '<input type="hidden" name="Items[' + rowIndex + '].ParentPath" value="' + escapeAttribute(item.parentPath) + '" />';
            html += '<input type="hidden" name="Items[' + rowIndex + '].DisplayName" value="' + escapeAttribute(item.displayName) + '" />';
            html += '<input type="hidden" name="Items[' + rowIndex + '].ValueType" value="' + escapeAttribute(item.valueType) + '" />';
            html += '<input type="hidden" name="Items[' + rowIndex + '].ValueTypeId" value="' + escapeAttribute(item.valueTypeId) + '" />';

            html += '</td>';

            html += '<td class="align-middle text-left p-0" style="width:140px;">';
            html += '<div class="px-2 d-flex align-items-center justify-content-start" style="min-height:42px;">';
            html += createValueInput(rowIndex, oldValue, item.valueTypeId);
            html += '</div>';
            html += '</td>';

            html += '</tr>';
        }

        html += '</tbody>';
        html += '</table>';
        html += '</div>';

        $('#dynamicChecklistArea').html(html);
    }

    function createValueInput(index, oldValue, valueTypeId) {
        if (oldValue == null) {
            oldValue = '';
        }

        oldValue = oldValue.toString().replace('%', '');

        var typeId = parseInt(valueTypeId);

        if (typeId === 4) {
            return createTickCrossDropdown(index, oldValue);
        }

        if (typeId === 5) {
            return createUpDownDropdown(index, oldValue);
        }

        if (typeId === 3) {
            return '' +
                '<div class="input-group input-group-sm" style="width:100px;">' +
                '<input type="text" autocomplete="off" class="form-control form-control-sm percentage-input required-entry-value" name="Items[' + index + '].ResultValue" value="' + escapeAttribute(oldValue) + '" oninput="limitPercentageInput(this)" />' +
                '<div class="input-group-append">' +
                '<span class="input-group-text">%</span>' +
                '</div>' +
                '</div>';
        }

        if (typeId === 2) {
            return '' +
                '<input type="date" class="form-control form-control-sm required-entry-value" name="Items[' + index + '].ResultValue" value="' + escapeAttribute(oldValue) + '" style="width:140px;" />';
        }

        var textValue = oldValue;

        if (
            oldValue === '8' ||
            oldValue === '9' ||
            oldValue === '10' ||
            oldValue === '11' ||
            oldValue === 'Tick' ||
            oldValue === 'Cross' ||
            oldValue === 'Up' ||
            oldValue === 'Down'
        ) {
            textValue = '';
        }

        return '' +
            '<input type="text" autocomplete="off" class="form-control form-control-sm required-entry-value" name="Items[' + index + '].ResultValue" value="' + escapeAttribute(textValue) + '" style="width:120px;" />';
    }

    function createTickCrossDropdown(index, oldValue) {
        var selectedText = 'Select';
        var selectedValue = oldValue;

        if (oldValue === 'Tick') {
            selectedValue = '8';
        }

        if (oldValue === 'Cross') {
            selectedValue = '9';
        }

        if (selectedValue === '8') {
            selectedText = '<i class="fas fa-check text-success"></i>';
        }

        if (selectedValue === '9') {
            selectedText = '<i class="fas fa-times text-danger"></i>';
        }

        return '' +
            '<input type="hidden" class="required-entry-value" id="tickCross_' + index + '" name="Items[' + index + '].ResultValue" value="' + escapeAttribute(selectedValue) + '" />' +
            '<div class="dropdown" style="width:100px;">' +
            '<button type="button" class="btn btn-light border btn-sm dropdown-toggle" data-toggle="dropdown" id="tickCrossButton_' + index + '" style="width:100px;">' +
            selectedText +
            '</button>' +
            '<div class="dropdown-menu p-0 text-center" style="min-width:100px;">' +
            '<button type="button" class="dropdown-item" onclick="selectTickCross(' + index + ', \'8\')"><i class="fas fa-check text-success"></i></button>' +
            '<button type="button" class="dropdown-item" onclick="selectTickCross(' + index + ', \'9\')"><i class="fas fa-times text-danger"></i></button>' +
            '</div>' +
            '</div>';
    }

    function selectTickCross(index, value) {
        $('#tickCross_' + index).val(value);

        if (value === '8') {
            $('#tickCrossButton_' + index).html('<i class="fas fa-check text-success"></i>');
        }

        if (value === '9') {
            $('#tickCrossButton_' + index).html('<i class="fas fa-times text-danger"></i>');
        }
    }

    function createUpDownDropdown(index, oldValue) {
        var selectedText = 'Select';
        var selectedValue = oldValue;

        if (oldValue === 'Up') {
            selectedValue = '10';
        }

        if (oldValue === 'Down') {
            selectedValue = '11';
        }

        if (selectedValue === '10') {
            selectedText = '<span class="text-success font-weight-bold">Up</span>';
        }

        if (selectedValue === '11') {
            selectedText = '<span class="text-danger font-weight-bold">Down</span>';
        }

        return '' +
            '<input type="hidden" class="required-entry-value" id="upDown_' + index + '" name="Items[' + index + '].ResultValue" value="' + escapeAttribute(selectedValue) + '" />' +
            '<div class="dropdown" style="width:100px;">' +
            '<button type="button" class="btn btn-light border btn-sm dropdown-toggle" data-toggle="dropdown" id="upDownButton_' + index + '" style="width:100px;">' +
            selectedText +
            '</button>' +
            '<div class="dropdown-menu p-0 text-center" style="min-width:100px;">' +
            '<button type="button" class="dropdown-item" onclick="selectUpDown(' + index + ', \'10\')"><span class="text-success font-weight-bold">Up</span></button>' +
            '<button type="button" class="dropdown-item" onclick="selectUpDown(' + index + ', \'11\')"><span class="text-danger font-weight-bold">Down</span></button>' +
            '</div>' +
            '</div>';
    }

    function selectUpDown(index, value) {
        $('#upDown_' + index).val(value);

        if (value === '10') {
            $('#upDownButton_' + index).html('<span class="text-success font-weight-bold">Up</span>');
        }

        if (value === '11') {
            $('#upDownButton_' + index).html('<span class="text-danger font-weight-bold">Down</span>');
        }
    }

    function limitPercentageInput(input) {
        if (input == null) {
            return;
        }

        var value = input.value.replace(/[^0-9]/g, '');

        if (value === '') {
            input.value = '';
            return;
        }

        var numberValue = parseInt(value);

        if (numberValue > 100) {
            input.value = '';
            showChecklistToast('Percentage value cannot be greater than 100.');
            return;
        }

        input.value = numberValue.toString();
    }

    function getExistingValue(existingEntries, setupNodeId, displayName, parentPath, oldSetupNodeId, valueTypeId) {
        if (existingEntries == null) {
            return '';
        }

        var foundValue = '';

        for (var i = 0; i < existingEntries.length; i++) {
            var entry = existingEntries[i];

            var entrySetupNodeId = entry.setupNodeId || entry.SetupNodeId;
            var entryResultValue = entry.resultValue;

            if (entryResultValue == null) {
                entryResultValue = entry.ResultValue;
            }

            if (entrySetupNodeId === setupNodeId || entrySetupNodeId === oldSetupNodeId) {
                foundValue = entryResultValue;
                break;
            }
        }

        if (foundValue === '') {
            for (var j = 0; j < existingEntries.length; j++) {
                var entry2 = existingEntries[j];

                var entryDisplayName = entry2.displayName || entry2.DisplayName;
                var entryParentPath = entry2.parentPath || entry2.ParentPath;
                var entryResultValue2 = entry2.resultValue;

                if (entryResultValue2 == null) {
                    entryResultValue2 = entry2.ResultValue;
                }

                if (entryDisplayName === displayName && entryParentPath === parentPath) {
                    foundValue = entryResultValue2;
                    break;
                }
            }
        }

        if (foundValue === '') {
            return '';
        }

        if (parseInt(valueTypeId) === 3) {
            if (isNaN(foundValue.replace('%', ''))) {
                return '';
            }
        }

        if (parseInt(valueTypeId) === 4) {
            if (foundValue !== 'Tick' && foundValue !== 'Cross' && foundValue !== '8' && foundValue !== '9') {
                return '';
            }
        }

        if (parseInt(valueTypeId) === 5) {
            if (foundValue !== 'Up' && foundValue !== 'Down' && foundValue !== '10' && foundValue !== '11') {
                return '';
            }
        }

        return foundValue;
    }

    $('#categoryChecklistForm').off('submit').on('submit', function (e) {
        var categoryId = $('#CategoryId').val();

        if (categoryId === '' || categoryId == null) {
            e.preventDefault();
            showChecklistToast('Please select a main item.');
            return false;
        }

        var isValid = true;

        $('.required-entry-value').each(function () {
            var value = $(this).val();

            if (value == null || value.trim() === '') {
                isValid = false;
                return false;
            }
        });

        if (!isValid) {
            e.preventDefault();
            showChecklistToast('Please fill all required values.');
            return false;
        }

        return true;
    });

    function confirmCloseCategoryChecklist() {
        $('#closeConfirmModal').modal('show');
    }

    function closeCategoryChecklistModalNow() {
        $('#closeConfirmModal').modal('hide');
        $('#categoryChecklistModal').modal('hide');
    }

    function getNodeId(node) {
        var id = node.id;

        if (id == null) {
            id = node.Id;
        }

        if (id == null) {
            id = node.nodeId;
        }

        if (id == null) {
            id = node.NodeId;
        }

        if (id == null || id === '') {
            id = getNodeValue(node);
        }

        return id;
    }

    function getNodeValue(node) {
        var value = node.value;

        if (value == null) {
            value = node.Value;
        }

        if (value == null) {
            value = node.label;
        }

        if (value == null) {
            value = node.Label;
        }

        if (value == null) {
            value = '';
        }

        return value;
    }

    function getNodeFieldType(node) {
        var fieldType = node.fieldType;

        if (fieldType == null) {
            fieldType = node.FieldType;
        }

        if (fieldType == null) {
            fieldType = node.valueType;
        }

        if (fieldType == null) {
            fieldType = node.ValueType;
        }

        if (fieldType == null) {
            fieldType = '';
        }

        return fieldType.trim();
    }

    function getNodeFieldTypeId(node) {
        var fieldTypeId = node.fieldTypeId;

        if (fieldTypeId == null) {
            fieldTypeId = node.FieldTypeId;
        }

        if (fieldTypeId == null) {
            fieldTypeId = node.valueTypeId;
        }

        if (fieldTypeId == null) {
            fieldTypeId = node.ValueTypeId;
        }

        if (fieldTypeId == null || fieldTypeId === '') {
            return '';
        }

        return fieldTypeId;
    }

    function getNodeChildren(node) {
        var children = node.children;

        if (children == null) {
            children = node.Children;
        }

        return children;
    }

    function escapeHtml(value) {
        if (value == null) {
            return '';
        }

        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function escapeAttribute(value) {
        return escapeHtml(value);
    }
</script>