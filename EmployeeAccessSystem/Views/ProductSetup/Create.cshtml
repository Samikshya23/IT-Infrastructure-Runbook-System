@model EmployeeAccessSystem.Models.ProductSetup

@{
    Layout = null;
}

<form asp-action="Create" method="post" id="createProductForm">
    @Html.AntiForgeryToken()

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <div class="form-group">
        <label asp-for="ProductName" class="font-weight-bold">Product Name</label>
        <input asp-for="ProductName" class="form-control" placeholder="Enter product name" maxlength="100" />
        <span asp-validation-for="ProductName" class="text-danger small"></span>
    </div>

    <div class="form-group mb-4">
        <div class="custom-control custom-switch">
            <input asp-for="IsActive" class="custom-control-input" id="CreateIsActive" />
            <label class="custom-control-label font-weight-bold" for="CreateIsActive" id="createStatusLabel">Active</label>
        </div>
        <span asp-validation-for="IsActive" class="text-danger small"></span>
    </div>

    <div class="modal-footer px-0 pb-0">
        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">
            Back
        </button>

        <button type="submit" class="btn btn-primary btn-sm">
            Save
        </button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />

<script>
    $(document).ready(function () {

        function updateCreateStatus() {
            if ($('#CreateIsActive').is(':checked')) {
                $('#createStatusLabel').text('Active');
            } else {
                $('#createStatusLabel').text('Inactive');
            }
        }

        updateCreateStatus();

        $('#CreateIsActive').change(function () {
            updateCreateStatus();
        });

    });
</script>