@model IEnumerable<EmployeeAccessSystem.Models.ProductSetup>

@{
    ViewData["Title"] = "Product Setup";
    int sn = 1;
}

<section class="content pt-2 pb-0">

    <div class="container-fluid px-0">

        <!-- Page header -->
        <div class="row mb-2 mx-0 align-items-center">

            <div class="col-sm-6 px-0">

                <h3 class="mb-0">
                 Product Setup
                </h3>

            </div>

            <div class="col-sm-6 text-right px-0">

                <!-- Add button -->
                <a asp-action="Create"
                   asp-controller="ProductSetup"
                   class="btn btn-primary btn-sm open-modal-btn"
                   data-title="Add Product Setup">

                    <i class="fas fa-plus mr-1"></i>
                    Add

                </a>

            </div>

        </div>

        <!-- Main card -->
        <div class="card card-outline card-primary mb-0 shadow-none">

            <!-- Card header -->
            <div class="card-header bg-white border-bottom-0 pt-2 pb-2 px-3">

                <div class="row align-items-center">

                    <!-- Page length -->
                    <div class="col-md-6 d-flex align-items-center">

                        <label class="mb-0 mr-2 font-weight-normal">
                            Show
                        </label>

                        <select id="customLength"
                                class="custom-select custom-select-sm form-control form-control-sm"
                                style="width:70px;">

                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>

                        </select>

                        <label class="mb-0 ml-2 font-weight-normal">
                            entries
                        </label>

                    </div>

                    <!-- Search -->
                    <div class="col-md-6">

                        <div class="d-flex justify-content-end">

                            <input type="text"
                                   id="customSearch"
                                   class="form-control form-control-sm"
                                   placeholder="Search"
                                   style="width:220px;" />

                        </div>

                    </div>

                </div>

            </div>

            <!-- Card body -->
            <div class="card-body p-0">

                <table id="productSetupTable"
                       class="table table-bordered table-hover table-sm mb-0 rounded-0"
                       style="border-color:#dee2e6;">

                    <thead class="bg-light border-bottom">

                        <tr>

                            <th class="text-center align-middle"
                                style="width:70px;">
                                SN
                            </th>

                            <th class="text-center align-middle">
                                Name
                            </th>

                            <th class="text-center align-middle"
                                style="width:110px;">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <!-- Serial number -->
                                    <td class="text-center align-middle">
                                        @sn
                                    </td>

                                    <!-- Name -->
                                    <td class="align-middle">

                                        @item.ProductName

                                        @if (!item.IsActive)
                                        {
                                            <span class="text-muted ml-2">
                                                (Inactive)
                                            </span>
                                        }

                                    </td>

                                    <!-- Action buttons -->
                                    <td class="text-center align-middle">

                                        <!-- Edit -->
                                        <a asp-action="Edit"
                                           asp-controller="ProductSetup"
                                           asp-route-id="@item.ProductId"
                                           class="btn btn-xs btn-light border open-modal-btn"
                                           data-title="Edit Product Setup"
                                           title="Edit">

                                            <i class="fas fa-pen"></i>

                                        </a>

                                        <!-- Delete -->
                                        <a asp-action="Delete"
                                           asp-controller="ProductSetup"
                                           asp-route-id="@item.ProductId"
                                           class="btn btn-xs btn-outline-danger open-modal-btn ml-1"
                                           data-title=""
                                           title="Delete">

                                            <i class="fas fa-trash-alt"></i>

                                        </a>

                                    </td>

                                </tr>

                                sn++;
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</section>

<!-- Main modal -->
<div class="modal fade"
     id="mainActionModal"
     tabindex="-1"
     role="dialog"
     aria-labelledby="mainActionModalTitle"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered"
         style="max-width:360px;"
         role="document">

        <div class="modal-content rounded-0">

            <!-- Modal header -->
            <div class="modal-header">

                <h5 class="modal-title"
                    id="mainActionModalTitle">

                    Product Setup

                </h5>

                <button type="button"
                        class="close"
                        data-dismiss="modal">

                    <span>&times;</span>

                </button>

            </div>

            <!-- Modal body -->
            <div class="modal-body"
                 id="mainActionModalBody">

                <div class="text-center py-3">

                    <i class="fas fa-spinner fa-spin mr-2"></i>
                    Loading...

                </div>

            </div>

        </div>

    </div>

</div>

<!-- Toast messages -->
@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div class="position-fixed"
         style="top:15px; right:15px; z-index:1055;">

        <!-- Success toast -->
        @if (TempData["Success"] != null)
        {
            <div class="toast bg-success text-white fade"
                 id="successToast"
                 data-delay="3000">

                <div class="toast-header bg-success text-white border-0">

                    <strong class="mr-auto">
                        Success
                    </strong>

                    <small>
                        Now
                    </small>

                    <button type="button"
                            class="close text-white"
                            data-dismiss="toast">

                        <span>&times;</span>

                    </button>

                </div>

                <div class="toast-body">
                    @TempData["Success"]
                </div>

            </div>
        }

        <!-- Error toast -->
        @if (TempData["Error"] != null)
        {
            <div class="toast bg-danger text-white fade"
                 id="errorToast"
                 data-delay="4000">

                <div class="toast-header bg-danger text-white border-0">

                    <strong class="mr-auto">
                        Error
                    </strong>

                    <small>
                        Now
                    </small>

                    <button type="button"
                            class="close text-white"
                            data-dismiss="toast">

                        <span>&times;</span>

                    </button>

                </div>

                <div class="toast-body">
                    @TempData["Error"]
                </div>

            </div>
        }

    </div>
}

@section Scripts {

    <!-- Product setup page JavaScript -->
    <script src="~/js/productsetup/index.js"></script>

}