@model EmployeeAccessSystem.Models.ProductSetup

@{
    Layout = null;
}

@await Component.InvokeAsync("DeleteConfirmation", new
{
    formId = "deleteProductForm",
    actionName = "Delete",
    controllerName = "ProductSetup",
    hiddenInputName = "productId",
    hiddenInputValue = Model.ProductId,
    message = "Do you want to delete this record?",
    itemName = Model.ProductName
})