@model EmployeeAccessSystem.Models.ProductConfiguration

@{
    Layout = null;
}

<div class="modal-header bg-white border-bottom">

    <h5 class="modal-title font-weight-bold">
        Delete Record
    </h5>

    <button type="button"
            class="close"
            data-dismiss="modal">

        <span>&times;</span>

    </button>

</div>

<form asp-action="DeleteNodeConfirmed"
      method="post">

    @Html.AntiForgeryToken()

    <div class="modal-body">

        <input type="hidden"
               name="nodeId"
               value="@Model.NodeId" />

        <input type="hidden"
               name="productId"
               value="@Model.ProductId" />

        @* Delete confirmation *@
        <div class="text-center py-2">

            <div class="mb-3">

                <span class="bg-danger rounded-circle d-inline-flex align-items-center justify-content-center"
                      style="width:60px;height:60px;">

                    <i class="fas fa-exclamation-triangle text-white fa-lg"></i>

                </span>

            </div>

            <h4 class="font-weight-bold mb-2">
                Are you sure?
            </h4>

            <p class="text-muted mb-0">
                Do you want to delete this record?
            </p>

        </div>

        <div class="card card-outline card-secondary mt-3 mb-0">

            <div class="card-body py-2 px-3">

                <strong>Name:</strong>
                @Model.NodeName

            </div>

        </div>

    </div>

    <div class="modal-footer justify-content-center">

        <button type="button"
                class="btn btn-secondary btn-sm px-4"
                data-dismiss="modal">

            Cancel

        </button>

        <button type="submit"
                class="btn btn-danger btn-sm px-4">

            Delete

        </button>

    </div>

</form>