@{
    Layout = null;

    int selectedProductId = ViewBag.SelectedProductId;
    string existingJson = ViewBag.ExistingJson;
}

<div class="modal-header bg-white border-bottom">
    <h5 class="modal-title font-weight-bold">Product Configuration</h5>
</div>

<div class="modal-body">
    <div id="msgArea"></div>
    <div class="card card-outline card-secondary mb-2">
        <div class="card-body p-2">
            <div class="row align-items-end">

                <div class="col-md-11">
                    <label class="font-weight-bold mb-1">Product</label>

                    <select id="ProductId"
                            class="form-control form-control-sm"
                            asp-items="ViewBag.ProductList">
                        <option value="">Select Product</option>
                    </select>
                </div>
                <div class="col-md-1 text-right">
                    <button type="button"
                            id="btnAddRoot"
                            class="btn btn-outline-primary btn-sm px-2 py-0"
                            title="Add Label"
                            style="display:none;">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>

            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header py-2">
            <h3 class="card-title font-weight-bold">Structure Builder</h3>
        </div>

        <div class="card-body p-2">
            <div id="nodeContainer">
                <div class="text-muted text-center py-3" id="emptyMessage">
                    Select product first, then click plus to add structure.
                 </div>
            </div>
        </div>
    </div>
</div>
<div class="modal-footer">
    <button type="button"
            id="btnFooterClose"
            class="btn btn-secondary btn-sm">
        Close
    </button>
    <button type="button"
            id="btnSave"
            class="btn btn-primary btn-sm">
        Save Structure
    </button>
</div>
<div class="modal fade"
     id="confirmCloseModal"
     tabindex="-1"
     role="dialog"
     data-backdrop="static"
     data-keyboard="false">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <div class="modal-header bg-white border-bottom">
                <h5 class="modal-title font-weight-bold">Unsaved Changes</h5>
            </div>

            <div class="modal-body text-center py-4">
                <div class="font-weight-bold">
                    Do you want to close this form?
                </div>
            </div>

            <div class="modal-footer justify-content-center bg-light">
                <button type="button"
                        id="btnContinueEditing"
                        class="btn btn-secondary btn-sm px-3">
                    Continue Editing
                </button>
                <button type="button"
                        id="btnConfirmClose"
                        class="btn btn-danger btn-sm px-3">
                    Yes, Close
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    $(document).ready(function () {

        var selectedProductId = @selectedProductId;

        var modalParent = $("#ProductId").closest(".modal");

        if (modalParent.length === 0) {
            modalParent = $(".modal.show");
        }

        $("#ProductId").select2({
            theme: "bootstrap4",
            width: "100%",
            dropdownParent: modalParent
        });

        if (selectedProductId > 0) {
            $("#ProductId").val(selectedProductId).trigger("change");
            $("#btnAddRoot").show();

            $("#nodeContainer").html(
                '<div class="text-muted text-center py-3" id="emptyMessage">Click plus to add structure.</div>'
            );
        }

        $("#btnFooterClose").off("click").on("click", function (e) {
            e.preventDefault();
            $("#confirmCloseModal").modal("show");
        });

        $("#btnContinueEditing").off("click").on("click", function () {
            $("#confirmCloseModal").modal("hide");
        });

        $("#btnConfirmClose").off("click").on("click", function () {
            $("#confirmCloseModal").modal("hide");

            setTimeout(function () {
                modalParent.modal("hide");
            }, 200);
        });

        $("#ProductId").off("change").on("change", function () {

            var productId = $(this).val();

            if (productId === "") {
                $("#btnAddRoot").hide();

                $("#nodeContainer").html(
                    '<div class="text-muted text-center py-3" id="emptyMessage">Select product first, then click plus to add structure.</div>'
                );

                return;
            }

            $.get("/ProductConfiguration/Add?productId=" + productId, function (data) {
                $("#configurationModalContent").html(data);
            });
        });

        $("#btnAddRoot").off("click").on("click", function () {

            clearMessage();

            if ($("#ProductId").val() === "") {
                showError("Please select product first.");
                return;
            }

            if (!canAddNewRow($("#nodeContainer"))) {
                showError("Please fill existing label/level name first.");
                return;
            }

            $("#emptyMessage").remove();

            addRow($("#nodeContainer"), 0);
            refreshHeading();
            refreshDeleteButtons();
        });

        $("#btnSave").off("click").on("click", function () {
            saveData();
        });

        function addRow(container, level) {

            var margin = level * 30;
            var html = "";

            html += '<div class="node-row mb-2" style="margin-left:' + margin + 'px;">';
            html += '<div class="row align-items-center">';

            html += '<div class="col-md-1 text-center">';
            html += '<span class="heading-label text-dark"></span>';
            html += '</div>';

            html += '<div class="col-md-5">';
            html += '<input type="text" class="form-control form-control-sm node-name" placeholder="Type label/level name">';
            html += '</div>';

            html += '<div class="col-md-4">';
            html += '<select class="form-control form-control-sm input-type">';
            html += '<option value="Text" selected>Text</option>';
            html += '<option value="Date">Date</option>';
            html += '</select>';
            html += '</div>';

            html += '<div class="col-md-2 text-right">';
            html += '<button type="button" class="btn btn-outline-primary btn-sm px-2 py-0 btn-plus mr-1" title="Add Child">';
            html += '<i class="fas fa-plus"></i>';
            html += '</button>';

            html += '<button type="button" class="btn btn-outline-danger btn-sm px-2 py-0 btn-minus" title="Remove">';
            html += '<i class="fas fa-minus"></i>';
            html += '</button>';
            html += '</div>';

            html += '</div>';
            html += '<div class="child-area mt-2"></div>';
            html += '</div>';

            container.append(html);

            var current = container.children(".node-row").last();

            current.find(".btn-plus").off("click").on("click", function () {

                clearMessage();

                var nodeName = current.find("> .row .node-name").val();

                if ($.trim(nodeName) === "") {
                    showError("Please type label/level name first.");
                    return;
                }

                if (!canAddNewRow(current.children(".child-area"))) {
                    showError("Please fill existing child label/level name first.");
                    return;
                }

                addRow(current.children(".child-area"), level + 1);
                refreshHeading();
                refreshDeleteButtons();
            });

            current.find(".btn-minus").off("click").on("click", function () {

                clearMessage();

                if (current.children(".child-area").children(".node-row").length > 0) {
                    return;
                }

                current.remove();
                refreshHeading();
                refreshDeleteButtons();

                if ($("#nodeContainer").children(".node-row").length === 0) {
                    $("#nodeContainer").html(
                        '<div class="text-muted text-center py-3" id="emptyMessage">Click plus to add structure.</div>'
                    );
                }
            });

            current.find(".node-name, .input-type").off("input change").on("input change", function () {
                clearMessage();
            });
        }

        function canAddNewRow(container) {

            var valid = true;

            container.find(".node-row").each(function () {

                var row = $(this);
                var nodeName = row.find("> .row .node-name").val();

                if ($.trim(nodeName) === "") {
                    valid = false;
                    return false;
                }
            });

            return valid;
        }

        function refreshHeading() {

            $("#nodeContainer").children(".node-row").each(function (i) {

                var headingNumber = i + 1;

                setHeading($(this), headingNumber.toString());
            });
        }

        function setHeading(row, number) {

            row.find("> .row .heading-label").text("H" + number);

            row.children(".child-area").children(".node-row").each(function (i) {

                var childNumber = number + "." + (i + 1);

                setHeading($(this), childNumber);
            });
        }

        function refreshDeleteButtons() {

            $("#nodeContainer").find(".node-row").each(function () {

                var row = $(this);
                var childCount = row.children(".child-area").children(".node-row").length;

                if (childCount > 0) {
                    row.find("> .row .btn-minus").hide();
                }
                else {
                    row.find("> .row .btn-minus").show();
                }
            });
        }

        function saveData() {

            clearMessage();

            var productId = $("#ProductId").val();

            if (productId === "") {
                showError("Please select product.");
                return;
            }

            if ($("#nodeContainer").children(".node-row").length === 0) {
                showError("Please add structure.");
                return;
            }

            if (!validateRows($("#nodeContainer"))) {
                return;
            }

            var nodes = collectRows($("#nodeContainer"));

            $.ajax({
                url: "/ProductConfiguration/SaveStructure",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({
                    productId: parseInt(productId),
                    nodes: nodes
                }),
                success: function (response) {

                    if (response.success) {
                        window.location.href =
                            "/ProductConfiguration?selectedProductId=" +
                            productId +
                            "&successMessage=" +
                            encodeURIComponent(response.message);
                    }
                    else {
                        showError(response.message);
                    }
                },
                error: function () {
                    showError("Error while saving structure.");
                }
            });
        }

        function validateRows(container) {

            var valid = true;

            container.find(".node-row").each(function () {

                var row = $(this);
                var nodeName = row.find("> .row .node-name").val();

                if (nodeName == null || $.trim(nodeName) === "") {
                    showError("Please type label/level name for all rows.");
                    valid = false;
                    return false;
                }
            });

            return valid;
        }

        function collectRows(container) {

            var data = [];

            container.children(".node-row").each(function () {

                var row = $(this);

                var nodeName = row.find("> .row .node-name").val();
                var inputType = row.find("> .row .input-type").val();

                data.push({
                    nodeName: $.trim(nodeName),
                    nodeType: "Block",
                    inputType: $.trim(inputType),
                    children: collectRows(row.children(".child-area"))
                });
            });

            return data;
        }

        function showError(message) {

            $("#msgArea").html(
                '<div class="alert alert-danger alert-dismissible fade show mb-2">' +
                message +
                '<button type="button" class="close" data-dismiss="alert">' +
                '<span>&times;</span>' +
                '</button>' +
                '</div>'
            );

            setTimeout(function () {
                $("#msgArea").html("");
            }, 3000);
        }

        function clearMessage() {
            $("#msgArea").html("");
        }

    });
</script>