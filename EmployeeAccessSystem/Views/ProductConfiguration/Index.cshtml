@model List<EmployeeAccessSystem.Models.ProductConfigurationIndexItem>

@{
    ViewData["Title"] = "Product Configuration";

    int sn = 1;
}

<section class="content pt-2 pb-0">

    <div class="container-fluid px-0">

        <div class="row mb-2 mx-0 align-items-center">

            <div class="col-sm-6 px-0">
                
                <h3 class="mb-0">
                    Product Configuration
                </h3>

            </div>

            <div class="col-sm-6 text-right px-0 pt-1">

                <button type="button"
                        class="btn btn-primary btn-sm"
                        id="btnAddConfiguration">

                    <i class="fas fa-plus mr-1"></i>
                    Add

                </button>

            </div>

        </div>


        <!-- Main card -->
        <div class="card card-outline card-primary mb-0 shadow-none">

            <!-- Card header -->
            <div class="card-header bg-white border-bottom-0 py-1 px-2 ">
            <div class="card-body p-0">

                @if (Model != null && Model.Count > 0)
                {
                    <table id="configurationTable"
                           class="table table-bordered table-hover table-sm mb-0 rounded-0"
                           style="border-color:#dee2e6;">

                        <thead class="bg-light border-bottom">

                            <tr>

                                <th class="text-center align-middle"
                                    style="width:70px;">

                                    SN

                                </th>

                                <th class="text-center align-middle">

                                    Product Name

                                </th>

                                <th class="text-center align-middle"
                                    style="width:90px;">

                                    Actions

                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td class="text-center align-middle">
                                        @sn
                                    </td>

                                    <td class="align-middle">
                                        @item.ProductName
                                    </td>

                                    <td class="text-center align-middle">

                                        <button type="button"
                                                class="btn btn-xs btn-light border btnEditConfiguration"
                                                data-product-id="@item.ProductId"
                                                title="Edit">

                                            <i class="fas fa-pen"></i>

                                        </button>

                                    </td>

                                </tr>

                                sn++;
                            }

                        </tbody>

                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-4">

                        Click <strong>Add</strong> to create configuration.

                    </div>
                }

            </div>

        </div>

    </div>

</section>

@* Configuration modal *@
<div class="modal fade"
     id="configurationModal"
     tabindex="-1"
     role="dialog"
     data-backdrop="static"
     data-keyboard="false">

    <div class="modal-dialog modal-xl"
         role="document">

        <div class="modal-content rounded-0"
             id="configurationModalContent">
        </div>

    </div>

</div>
<input type="hidden"
       id="SuccessMessage"
       value="@TempData["Success"]" />

<input type="hidden"
       id="ErrorMessage"
       value="@TempData["Error"]" />
@section Scripts
{
    <script src="~/js/productconfiguration/index.js"></script>
}