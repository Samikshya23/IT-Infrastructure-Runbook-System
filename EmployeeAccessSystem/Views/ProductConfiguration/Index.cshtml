@model List<EmployeeAccessSystem.Models.ProductConfigurationIndexItem>

@{
    ViewData["Title"] = "Product Configuration";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2 align-items-center">
            <div class="col-sm-6">
                <h4 class="m-0 font-weight-bold">Product Configuration</h4>
            </div>

            <div class="col-sm-6 text-right">
                <button type="button"
                        class="btn btn-primary btn-sm"
                        id="btnAddConfiguration">
                    <i class="fas fa-plus"></i>
                    Add Product Configuration
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        @if (Model != null && Model.Count > 0)
        {
            for (int i = 0; i < Model.Count; i++)
            {
                var item = Model[i];

                <div class="card card-outline card-primary mb-3">
                    <div class="card-header py-2">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h3 class="card-title font-weight-bold mb-0">
                                    @item.ProductName
                                </h3>
                            </div>

                            <div class="col-md-4 text-right">
                                <button type="button"
                                        class="btn btn-warning btn-sm btnEditConfiguration"
                                        data-product-id="@item.ProductId"
                                        title="Edit Configuration">
                                    <i class="fas fa-edit"></i>
                                </button>

                                <form asp-action="Delete"
                                      method="post"
                                      class="d-inline deleteForm">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden"
                                           name="productId"
                                           value="@item.ProductId" />

                                    <button type="submit"
                                            class="btn btn-danger btn-sm"
                                            title="Delete Configuration">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="card-body p-2">
                        @if (item.Nodes != null && item.Nodes.Count > 0)
                        {
                            for (int j = 0; j < item.Nodes.Count; j++)
                            {
                                @await Html.PartialAsync("~/Views/ProductConfiguration/_TreeNode.cshtml", item.Nodes[j])
                            }
                        }
                        else
                        {
                            <div class="text-muted text-center py-2">
                                No structure found.
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="card">
                <div class="card-body text-center text-muted">
                    Click <strong>Add Product Configuration</strong> to create or edit a product structure.
                </div>
            </div>
        }

    </div>
</section>

<div class="modal fade"
     id="configurationModal"
     tabindex="-1"
     role="dialog"
     data-backdrop="static"
     data-keyboard="false">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content" id="configurationModalContent">
        </div>
    </div>
</div>

@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div class="position-fixed" style="top: 15px; right: 15px; z-index: 1055;">

        @if (TempData["Success"] != null)
        {
            <div class="toast bg-success text-white fade" id="successToast" data-delay="3000">
                <div class="toast-header bg-success text-white border-0">
                    <strong class="mr-auto">Success</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>

                <div class="toast-body">
                    @TempData["Success"]
                </div>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="toast bg-danger text-white fade" id="errorToast" data-delay="4000">
                <div class="toast-header bg-danger text-white border-0">
                    <strong class="mr-auto">Error</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>

                <div class="toast-body">
                    @TempData["Error"]
                </div>
            </div>
        }

    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {

            $("#btnAddConfiguration").click(function () {
                $.get("/ProductConfiguration/Add", function (data) {
                    $("#configurationModalContent").html(data);
                    $("#configurationModal").modal("show");
                });
            });

            $(document).on("click", ".btnEditConfiguration", function () {
                var productId = $(this).attr("data-product-id");

                $.get("/ProductConfiguration/Add?productId=" + productId, function (data) {
                    $("#configurationModalContent").html(data);
                    $("#configurationModal").modal("show");
                });
            });

            $(document).on("submit", ".deleteForm", function () {
                return confirm("Are you sure you want to delete this product configuration?");
            });

            if ($("#successToast").length) {
                $("#successToast").toast("show");
            }

            if ($("#errorToast").length) {
                $("#errorToast").toast("show");
            }
        });
    </script>
}