@model List<EmployeeAccessSystem.Models.ProductConfigurationIndexItem>

@{
    ViewData["Title"] = "Product Configuration";
    int selectedProductId = ViewBag.SelectedProductId;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2 align-items-center">
            <div class="col-sm-6">
                <h4 class="m-0 font-weight-bold">
                    Product Configuration
                </h4>
            </div>
            <div class="col-sm-6 text-right">
                <button type="button"
                        class="btn btn-primary btn-sm"
                        id="btnAddConfiguration">
                    <i class="fas fa-plus"></i>
                    Add Product Configuration
                </button>
            </div>
        </div>
    </div>
</div>
<section class="content">
    <div class="container-fluid">

        @await Component.InvokeAsync("ProductConfiguration", new { selectedProductId = selectedProductId })

    </div>
</section>

<div class="modal fade" id="configurationModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content" id="configurationModalContent">
        </div>
    </div>
</div>

@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div class="position-fixed" style="top: 15px; right: 15px; z-index: 1055;">

        @if (TempData["Success"] != null)
        {
            <div class="toast bg-success text-white fade" id="successToast" data-delay="3000">
                <div class="toast-header bg-success text-white border-0">
                    <strong class="mr-auto">Success</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>

                <div class="toast-body">
                    @TempData["Success"]
                </div>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="toast bg-danger text-white fade" id="errorToast" data-delay="4000">
                <div class="toast-header bg-danger text-white border-0">
                    <strong class="mr-auto">Error</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>

                <div class="toast-body">
                    @TempData["Error"]
                </div>
            </div>
        }

    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {

            $("#btnAddConfiguration").click(function () {
                $.get("/ProductConfiguration/Add", function (data) {
                    $("#configurationModalContent").html(data);
                    $("#configurationModal").modal("show");
                });
            });

            $(document).on("click", ".btnEditConfiguration", function () {
                var productId = $(this).attr("data-product-id");

                $.get("/ProductConfiguration/Add?productId=" + productId, function (data) {
                    $("#configurationModalContent").html(data);
                    $("#configurationModal").modal("show");
                });
            });

            $(document).on("click", ".btnEditNode", function () {
                var nodeId = $(this).attr("data-node-id");

                $.get("/ProductConfiguration/EditNode?nodeId=" + nodeId, function (data) {
                    $("#configurationModalContent").html(data);
                    $("#configurationModal").modal("show");
                });
            });

            $(document).on("click", ".btnDeleteNode", function () {
                var nodeId = $(this).attr("data-node-id");

                $.get("/ProductConfiguration/DeleteNode?nodeId=" + nodeId, function (data) {
                    $("#configurationModalContent").html(data);
                    $("#configurationModal").modal("show");
                });
            });

            $(document).on("submit", ".deleteForm", function () {
                return confirm("Are you sure you want to delete this product configuration?");
            });

            if ($("#successToast").length) {
                $("#successToast").toast("show");
            }

            if ($("#errorToast").length) {
                $("#errorToast").toast("show");
            }

        });
    </script>
}