@model List<EmployeeAccessSystem.Models.CategorySetup>

@{
    ViewData["Title"] = "Category Setup";

    int selectedCategoryId = ViewBag.SelectedCategoryId;

    string successMessage = ViewBag.SuccessMessage;

    var categories =
        ViewBag.Categories as IEnumerable<EmployeeAccessSystem.Models.CategorySetup>;
}

<section class="content pt-2 pb-0">

    <div class="container-fluid px-2">

        <input type="hidden" id="successMessage" value="@successMessage" />
        <input type="hidden" id="tempSuccessMessage" value="@TempData["Success"]" />
        <input type="hidden" id="tempErrorMessage" value="@TempData["Error"]" />
        <input type="hidden" id="selectedCategoryId" value="@selectedCategoryId" />

        <div class="row mb-2 mx-0 align-items-center">

            <div class="col-sm-6 px-0">

                <h3 class="mb-0">
                    Category Setup
                </h3>

            </div>

            <div class="col-sm-6 text-right px-0">

                <button type="button"
                        id="btnAddSetupConfiguration"
                        class="btn btn-primary btn-sm">

                    <i class="fas fa-plus mr-1"></i>
                    Add

                </button>

            </div>

        </div>

        <div class="card card-outline card-primary mb-0 shadow-none">

            <div class="card-header bg-white py-2 px-2">

                <div class="row mx-0">

                    <div class="col-md-4 px-0">

                        <label class="font-weight-bold mb-1">
                            Select
                        </label>

                        <select id="showCategoryId"
                                class="form-control form-control-sm">

                            <option value="">
                                Select
                            </option>

                            @if (categories != null)
                            {
                                foreach (var category in categories)
                                {
                                    if (selectedCategoryId == category.CategoryId)
                                    {
                                        <option value="@category.CategoryId" selected>
                                            @category.Name
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@category.CategoryId">
                                            @category.Name
                                        </option>
                                    }
                                }
                            }

                        </select>

                    </div>

                </div>

            </div>

            <div id="setupTableContainer"></div>

        </div>

    </div>

</section>

<div class="modal fade"
     id="setupConfigurationModal"
     tabindex="-1"
     role="dialog"
     data-backdrop="static"
     data-keyboard="false">

    <div class="modal-dialog modal-xl"
         role="document">

        <div class="modal-content rounded-0"
             id="setupConfigurationModalContent">
        </div>

    </div>

</div>

@section Scripts {

    <script src="~/js/categorysetup/index.js" asp-append-version="true"></script>

}