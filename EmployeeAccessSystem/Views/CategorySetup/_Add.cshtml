@using System.Text.Json

@{
    Layout = null;

    int selectedCategoryId = ViewBag.SelectedCategoryId;
    int rootIndex = ViewBag.RootIndex;

    var categories = ViewBag.Categories as IEnumerable<EmployeeAccessSystem.Models.CategorySetup>;
    var valueTypes = ViewBag.ValueTypes as IEnumerable<EmployeeAccessSystem.Models.DropdownItemModel>;

    string valueTypeJson = JsonSerializer.Serialize(valueTypes);
}

<div class="modal-header bg-white border-bottom">
    <h5 class="modal-title font-weight-bold">
        @(rootIndex >= 0 ? "Edit" : "Category Setup")
    </h5>
</div>

<div class="modal-body">

    @Html.AntiForgeryToken()

    <input type="hidden" id="RootIndex" value="@rootIndex" />
    <input type="hidden" id="SelectedCategoryId" value="@selectedCategoryId" />

    <div class="card card-outline card-primary mb-0 shadow-none">

        <div class="card-header bg-white border-bottom-0 py-1 px-2">

            <div class="card-body p-2">

                <div class="form-group mb-0">

                    <label class="font-weight-bold mb-1">
                        Select
                    </label>

                    <select id="CategoryId"
                            class="form-control form-control-sm"
                            @(rootIndex >= 0 ? "disabled" : "")>

                        <option value="">
                            Select
                        </option>

                        @if (categories != null)
                        {
                            foreach (var category in categories)
                            {
                                if (selectedCategoryId == category.CategoryId)
                                {
                                    <option value="@category.CategoryId" selected>
                                        @category.Name
                                    </option>
                                }
                                else
                                {
                                    <option value="@category.CategoryId">
                                        @category.Name
                                    </option>
                                }
                            }
                        }

                    </select>

                </div>

            </div>

        </div>

        <div id="generatedSetupArea"
             class="border-top"
             style="display:none;">

            <div class="card-body p-2">

                <div id="nodeContainer"></div>

            </div>

        </div>

    </div>

</div>

<div class="modal-footer">

    <button type="button"
            id="btnFooterClose"
            class="btn btn-secondary btn-sm">
        Close
    </button>

    <button type="button"
            id="btnSave"
            class="btn btn-primary btn-sm">
        Save
    </button>

</div>

<div class="modal fade"
     id="confirmCloseModal"
     tabindex="-1"
     role="dialog"
     data-backdrop="static"
     data-keyboard="false">

    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">

        <div class="modal-content border-0 shadow">

            <div class="modal-body text-center py-4">

                <div class="mb-3">
                    <i class="fas fa-exclamation-circle text-warning" style="font-size:50px;"></i>
                </div>

                <h4 class="font-weight-bold mb-3">
                    Are you sure?
                </h4>

                <p class="mb-0">
                    Do you want to close this form?
                </p>

            </div>

            <div class="modal-footer justify-content-center bg-light border-top-0">

                <button type="button"
                        id="btnContinueEditing"
                        class="btn btn-secondary btn-sm px-4">
                    No
                </button>

                <button type="button"
                        id="btnConfirmClose"
                        class="btn btn-danger btn-sm px-4">
                    Yes
                </button>

            </div>

        </div>

    </div>

</div>

<script>
    window.categorySetupValueTypes = @Html.Raw(valueTypeJson);
</script>

<script src="~/js/categorysetup/add.js" asp-append-version="true"></script>