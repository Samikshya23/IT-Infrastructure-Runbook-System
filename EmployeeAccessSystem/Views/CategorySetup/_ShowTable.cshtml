@model List<EmployeeAccessSystem.Models.CategorySetup>
@using System.Collections.Generic

@functions {
    private int GetMaxDepth(List<EmployeeAccessSystem.Models.CategorySetup> nodes)
    {
        int maxDepth = 0;

        if (nodes == null)
        {
            return maxDepth;
        }

        foreach (var node in nodes)
        {
            int depth = GetNodeDepth(node, 1);

            if (depth > maxDepth)
            {
                maxDepth = depth;
            }
        }

        if (maxDepth < 2)
        {
            maxDepth = 2;
        }

        return maxDepth;
    }

    private int GetNodeDepth(EmployeeAccessSystem.Models.CategorySetup node, int currentDepth)
    {
        if (node == null || node.Children == null || node.Children.Count == 0)
        {
            return currentDepth;
        }

        int maxDepth = currentDepth;

        foreach (var child in node.Children)
        {
            int childDepth = GetNodeDepth(child, currentDepth + 1);

            if (childDepth > maxDepth)
            {
                maxDepth = childDepth;
            }
        }

        return maxDepth;
    }

    private void BuildLeafRows(
        EmployeeAccessSystem.Models.CategorySetup node,
        List<EmployeeAccessSystem.Models.CategorySetup> path,
        List<List<EmployeeAccessSystem.Models.CategorySetup>> rows)
    {
        if (node == null)
        {
            return;
        }

        path.Add(node);

        if (node.Children == null || node.Children.Count == 0)
        {
            rows.Add(new List<EmployeeAccessSystem.Models.CategorySetup>(path));
        }
        else
        {
            foreach (var child in node.Children)
            {
                BuildLeafRows(child, path, rows);
            }
        }

        path.RemoveAt(path.Count - 1);
    }

    private string GetHeadingName(List<EmployeeAccessSystem.Models.CategorySetup> model, int level)
    {
        if (model == null)
        {
            return "Level " + level;
        }

        foreach (var root in model)
        {
            string name = FindHeadingName(root, 1, level);

            if (!string.IsNullOrWhiteSpace(name))
            {
                return name;
            }
        }

        return "Level " + level;
    }

    private string FindHeadingName(EmployeeAccessSystem.Models.CategorySetup node, int currentLevel, int requiredLevel)
    {
        if (node == null)
        {
            return "";
        }

        if (currentLevel == requiredLevel)
        {
            return node.ConfigurationNodeName;
        }

        if (node.Children != null)
        {
            foreach (var child in node.Children)
            {
                string result = FindHeadingName(child, currentLevel + 1, requiredLevel);

                if (!string.IsNullOrWhiteSpace(result))
                {
                    return result;
                }
            }
        }

        return "";
    }

    private string GetColumnValue(List<EmployeeAccessSystem.Models.CategorySetup> row, int index)
    {
        if (row == null)
        {
            return "-";
        }

        if (index >= row.Count)
        {
            return "-";
        }

        if (string.IsNullOrWhiteSpace(row[index].NodeValue))
        {
            return "-";
        }

        return row[index].NodeValue;
    }
}

@if (Model == null || Model.Count == 0)
{
    <div class="p-3 text-center text-muted">
        No setup data found.
    </div>
}
else
{
    int sn = 1;
    int maxDepth = GetMaxDepth(Model);
    int totalColumnCount = maxDepth + 2;

    <div class="card-body p-0">
        <table id="setupDynamicTable"
               class="table table-bordered table-hover table-sm mb-0"
               style="table-layout:fixed;width:100%;">

            <thead class="bg-light">
                <tr>
                    <th class="text-center align-middle" style="width:60px;">SN</th>

                    @for (int i = 1; i <= maxDepth; i++)
                    {
                        <th class="text-center align-middle">
                            @GetHeadingName(Model, i)
                        </th>
                    }

                    
                    <th class="text-center align-middle" style="width:100px;">Action</th>
                </tr>
            </thead>

            <tbody>
                @for (int rootIndex = 0; rootIndex < Model.Count; rootIndex++)
                {
                    var root = Model[rootIndex];

                    var rows = new List<List<EmployeeAccessSystem.Models.CategorySetup>>();

                    BuildLeafRows(root, new List<EmployeeAccessSystem.Models.CategorySetup>(), rows);

                    if (rows.Count == 0)
                    {
                        rows.Add(new List<EmployeeAccessSystem.Models.CategorySetup> { root });
                    }

                    int rowHeight = rows.Count * 36;

                    <tr>
                        <td class="text-center align-middle">
                            @sn
                        </td>

                        <td class="p-0 align-top">
                            <div class="d-flex align-items-center px-2"
                                 style="height:@(rowHeight)px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"
                                 title="@root.NodeValue">
                                @root.NodeValue
                            </div>
                        </td>

                        @for (int columnIndex = 1; columnIndex < maxDepth; columnIndex++)
                        {
                            <td class="p-0 align-top">
                                <table class="table table-sm mb-0" style="table-layout:fixed;width:100%;">
                                    <tbody>
                                        @for (int rowIndex = 0; rowIndex < rows.Count; rowIndex++)
                                        {
                                            string columnValue = GetColumnValue(rows[rowIndex], columnIndex);

                                            <tr>
                                                <td class="p-0 align-middle @(rowIndex != rows.Count - 1 ? "border-bottom" : "")">
                                                    <div class="d-flex align-items-center px-2"
                                                         style="height:36px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"
                                                         title="@columnValue">
                                                        @columnValue
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </td>
                        }

                        

                        <td class="text-center align-middle">
                            <button type="button"
                                    class="btn btn-light border btn-sm p-0 btnEditRoot"
                                    data-root-index="@rootIndex"
                                    title="Edit"
                                    style="width:24px;height:24px;line-height:22px;">
                                <i class="fas fa-pen" style="font-size:10px;"></i>
                            </button>
                        </td>
                    </tr>

                    sn++;
                }
            </tbody>
        </table>
    </div>
}