<form asp-action="@ViewBag.ActionName"
      asp-controller="@ViewBag.ControllerName"
      method="post"
      id="@ViewBag.FormId">

    @Html.AntiForgeryToken()

    <input type="hidden"
           name="@ViewBag.HiddenInputName"
           value="@ViewBag.HiddenInputValue" />

    <div class="text-center py-3">

        <div class="mb-3">
            <span class="bg-danger rounded-circle d-inline-flex align-items-center justify-content-center"
                  style="width:70px; height:70px;">

                <i class="fas fa-exclamation-triangle text-white fa-2x"></i>

            </span>
        </div>

        <h4 class="font-weight-bold mb-3">
            Are you sure?
        </h4>

        <p class="text-muted mb-4">
            @ViewBag.Message
            <strong>"@ViewBag.ItemName"</strong>
        </p>

        <div class="d-flex justify-content-center">

            <button type="button"
                    class="btn btn-secondary btn-sm px-4 mr-2"
                    data-dismiss="modal">
                Cancel
            </button>

            <button type="submit"
                    class="btn btn-danger btn-sm px-4">
                Confirm
            </button>

        </div>

    </div>
</form>