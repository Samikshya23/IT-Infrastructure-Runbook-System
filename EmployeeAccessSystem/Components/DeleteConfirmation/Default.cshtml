<form asp-action="@ViewBag.ActionName"
      asp-controller="@ViewBag.ControllerName"
      method="post"
      id="@ViewBag.FormId">

    @Html.AntiForgeryToken()

    <input type="hidden"
           name="@ViewBag.HiddenInputName"
           value="@ViewBag.HiddenInputValue" />

    <div class="text-center py-2">
        <h5 class="font-weight-bold mb-2">Are you sure?</h5>

        <p class="mb-4 text-dark">
            @ViewBag.Message
            <span>"@ViewBag.ItemName"</span>
        </p>

        <div class="d-flex justify-content-center">
            <button type="button"
                    class="btn btn-secondary btn-sm mr-2"
                    data-dismiss="modal">
                Cancel
            </button>

            <button type="submit"
                    class="btn btn-danger btn-sm">
                Confirm
            </button>
        </div>
    </div>
</form>