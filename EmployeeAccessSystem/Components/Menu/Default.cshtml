@using EmployeeAccessSystem.Models
@model List<EmployeeAccessSystem.Models.MenuModel>

@{
    string currentController = "";
    string currentAction = "";

    if (ViewContext.RouteData.Values["controller"] != null)
    {
        currentController = ViewContext.RouteData.Values["controller"].ToString();
    }

    if (ViewContext.RouteData.Values["action"] != null)
    {
        currentAction = ViewContext.RouteData.Values["action"].ToString();
    }
}

@if (Model != null && Model.Count > 0)
{
    foreach (MenuModel menu in Model)
    {
        bool hasChildren = menu.Children != null && menu.Children.Count > 0;
        bool isParentActive = false;

        if (!string.IsNullOrWhiteSpace(menu.ControllerName) && menu.ControllerName == currentController)
        {
            isParentActive = true;
        }

        if (hasChildren)
        {
            foreach (MenuModel child in menu.Children)
            {
                if (!string.IsNullOrWhiteSpace(child.ControllerName) && child.ControllerName == currentController)
                {
                    isParentActive = true;
                    break;
                }
            }
        }

        if (hasChildren)
        {
            <li class="nav-item has-treeview @(isParentActive ? "menu-open" : "")">

                <a href="#" class="nav-link @(isParentActive ? "active" : "")">

                    <i class="nav-icon @(string.IsNullOrWhiteSpace(menu.IconClass) ? "fas fa-folder" : menu.IconClass)"></i>

                    <p>
                        @menu.MenuName
                        <i class="right fas fa-angle-left"></i>
                    </p>

                </a>

                <ul class="nav nav-treeview">

                    @foreach (MenuModel child in menu.Children)
                    {
                        bool isChildActive = false;

                        if (!string.IsNullOrWhiteSpace(child.ControllerName) &&
                        child.ControllerName == currentController)
                        {
                            isChildActive = true;
                        }

                        string childUrl = "#";

                        if (!string.IsNullOrWhiteSpace(child.ControllerName) &&
                        !string.IsNullOrWhiteSpace(child.ActionName))
                        {
                            childUrl = Url.Action(child.ActionName, child.ControllerName);
                        }

                        <li class="nav-item">

                            <a href="@childUrl" class="nav-link @(isChildActive ? "active" : "")">

                                <i class="far fa-circle nav-icon"></i>

                                <p>@child.MenuName</p>

                            </a>

                        </li>
                    }

                </ul>

            </li>
        }
        else
        {
            bool isMenuActive = false;

            if (!string.IsNullOrWhiteSpace(menu.ControllerName) &&
                menu.ControllerName == currentController)
            {
                isMenuActive = true;
            }

            string menuUrl = "#";

            if (!string.IsNullOrWhiteSpace(menu.ControllerName) &&
                !string.IsNullOrWhiteSpace(menu.ActionName))
            {
                menuUrl = Url.Action(menu.ActionName, menu.ControllerName);
            }

            <li class="nav-item">

                <a href="@menuUrl" class="nav-link @(isMenuActive ? "active" : "")">

                    <i class="nav-icon @(string.IsNullOrWhiteSpace(menu.IconClass) ? "fas fa-circle" : menu.IconClass)"></i>

                    <p>@menu.MenuName</p>

                </a>

            </li>
        }
    }
}